#import "../libquran.typ": quran-verse

= Al-Balad (البلد)

#quran-verse(
  ("لَآ", "أُقْسِمُ", "بِهَـٰذَا", "ٱلْبَلَدِ", "١"),
  ("lā", "uq'simu", "bihādhā", "l-baladi", "(1)"),
  ("不", "我盟誓", "这个|以", "城市(麦加)", ""),
)

我以这个地方盟誓--

#quran-verse(
  ("وَأَنتَ", "حِلٌّۢ", "بِهَـٰذَا", "ٱلْبَلَدِ", "٢"),
  ("wa-anta", "ḥillun", "bihādhā", "l-baladi", "(2)"),
  ("你|和", "自由", "这个|在", "城市", ""),
)

你将在那里，不受羁束--

#quran-verse(
  ("وَوَالِدٍۢ", "وَمَا", "وَلَدَ", "٣"),
  ("wawālidin", "wamā", "walada", "(3)"),
  ("生者(亚当)|和", "什么|和", "他生(子孙)", ""),
)

我以一个父亲和他所生的子孙盟誓，

#quran-verse(
  ("لَقَدْ", "خَلَقْنَا", "ٱلْإِنسَـٰنَ", "فِى", "كَبَدٍ", "٤"),
  ("laqad", "khalaqnā", "l-insāna", "fī", "kabadin", "(4)"),
  ("必定", "我们创造", "人", "在", "苦难", ""),
)

我确已把人创造在苦难里。

#quran-verse(
  ("أَيَحْسَبُ", "أَن", "لَّن", "يَقْدِرَ", "عَلَيْهِ", "أَحَدٌۭ", "٥"),
  ("ayaḥsabu", "an", "lan", "yaqdira", "ʿalayhi", "aḥadun", "(5)"),
  ("他以为|吗?", "那个", "不", "他能制裁", "他|在", "任何人", ""),
)

他以为任何人都不能制裁他吗？

#quran-verse(
  ("يَقُولُ", "أَهْلَكْتُ", "مَالًۭا", "لُّبَدًا", "٦"),
  ("yaqūlu", "ahlaktu", "mālan", "lubadan", "(6)"),
  ("他说", "我花费", "财产", "很多", ""),
)

他说：我花费了许多财产！

#quran-verse(
  ("أَيَحْسَبُ", "أَن", "لَّمْ", "يَرَهُۥٓ", "أَحَدٌ", "٧"),
  ("ayaḥsabu", "an", "lam", "yarahu", "aḥadun", "(7)"),
  ("他以为|吗?", "那个", "不", "他|他看见", "任何人", ""),
)

他以为任何人都没有看见他吗？

#quran-verse(
  ("أَلَمْ", "نَجْعَل", "لَّهُۥ", "عَيْنَيْنِ", "٨"),
  ("alam", "najʿal", "lahu", "ʿaynayni", "(8)"),
  ("不|吗?", "我们(真主)制造", "他|为", "两只眼睛", ""),
)

难道我没有为他创造两只眼睛、

#quran-verse(
  ("وَلِسَانًۭا", "وَشَفَتَيْنِ", "٩"),
  ("walisānan", "washafatayni", "(9)"),
  ("一条舌头|和", "两片嘴唇|和", ""),
)

一条舌头、两片嘴唇，

#quran-verse(
  ("وَهَدَيْنَـٰهُ", "ٱلنَّجْدَيْنِ", "١٠"),
  ("wahadaynāhu", "l-najdayni", "(10)"),
  ("他|我们指示|和", "两条道路", ""),
)

并指示他两条明显的道路吗？

#quran-verse(
  ("فَلَا", "ٱقْتَحَمَ", "ٱلْعَقَبَةَ", "١١"),
  ("falā", "iq'taḥama", "l-ʿaqabata", "(11)"),
  ("不|然后", "他企图超越", "山径", ""),
)

他怎麽不超越山径呢？

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "ٱلْعَقَبَةُ", "١٢"),
  ("wamā", "adrāka", "mā", "l-ʿaqabatu", "(12)"),
  ("什么？|和", "你|他使知道", "什么？", "山径", ""),
)

你怎能知道超越山径是什麽事？

#quran-verse(
  ("فَكُّ", "رَقَبَةٍ", "١٣"),
  ("fakku", "raqabatin", "(13)"),
  ("释放", "颈的", ""),
)

是释放奴隶，

#quran-verse(
  ("أَوْ", "إِطْعَـٰمٌۭ", "فِى", "يَوْمٍۢ", "ذِى", "مَسْغَبَةٍۢ", "١٤"),
  ("aw", "iṭ'ʿāmun", "fī", "yawmin", "dhī", "masghabatin", "(14)"),
  ("或", "食物", "在", "日子", "有", "饥荒的", ""),
)

或在饥荒日赈济

#quran-verse(
  ("يَتِيمًۭا", "ذَا", "مَقْرَبَةٍ", "١٥"),
  ("yatīman", "dhā", "maqrabatin", "(15)"),
  ("孤儿", "有的", "亲戚关系的", ""),
)

亲戚的孤儿，

#quran-verse(
  ("أَوْ", "مِسْكِينًۭا", "ذَا", "مَتْرَبَةٍۢ", "١٦"),
  ("aw", "mis'kīnan", "dhā", "matrabatin", "(16)"),
  ("或", "贫民", "有的", "卧土(穷困)的", ""),
)

或困穷的贫民；

#quran-verse(
  ("ثُمَّ", "كَانَ", "مِنَ", "ٱلَّذِينَ", "ءَامَنُوا۟", "وَتَوَاصَوْا۟", "بِٱلصَّبْرِ", "وَتَوَاصَوْا۟", "بِٱلْمَرْحَمَةِ", "١٧"),
  ("thumma", "kāna", "mina", "alladhīna", "āmanū", "watawāṣaw", "bil-ṣabri", "watawāṣaw", "bil-marḥamati", "(17)"),
  ("然后", "他是", "属于", "那个", "他们信道", "他们互相勉励|和", "坚忍|以", "他们互相勉励|和", "慈潣|以", ""),
)

同时，他是一个信道而且行善，并以坚忍相勉，以慈悯相助者。

#quran-verse(
  ("أُو۟لَـٰٓئِكَ", "أَصْحَـٰبُ", "ٱلْمَيْمَنَةِ", "١٨"),
  ("ulāika", "aṣḥābu", "l-maymanati", "(18)"),
  ("这等人", "同伴", "右手的", ""),
)

这等人是幸福的。

#quran-verse(
  ("وَٱلَّذِينَ", "كَفَرُوا۟", "بِـَٔايَـٰتِنَا", "هُمْ", "أَصْحَـٰبُ", "ٱلْمَشْـَٔمَةِ", "١٩"),
  ("wa-alladhīna", "kafarū", "biāyātinā", "hum", "aṣḥābu", "l-mashamati", "(19)"),
  ("那些|和", "他们不信", "我们的|众迹象|在", "他们", "同伴", "左手的", ""),
)

不信我的迹象者，是薄命的，

#quran-verse(
  ("عَلَيْهِمْ", "نَارٌۭ", "مُّؤْصَدَةٌۢ", "٢٠"),
  ("ʿalayhim", "nārun", "mu'ṣadatun", "(20)"),
  ("他们|在", "烈火", "被关(帐篷)的", ""),
)

他们将被关在火狱里。

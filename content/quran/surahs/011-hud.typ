  ("falaʿallaka", "tārikun", "baʿḍa", "mā", "yūḥā", "ilayka", "waḍāiqun", "bihi", "ṣadruka", "an", "yaqūlū", "lawlā", "unzila", "ʿalayhi", "kanzun", "aw", "jāa", "maʿahu", "malakun", "innamā", "anta", "nadhīrun", "wal-lahu", "ʿalā", "kulli", "shayin", "wakīlun", "(12)"),

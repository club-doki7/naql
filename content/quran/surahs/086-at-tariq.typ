#import "../libquran.typ": quran-verse

= At-Tariq (الطارق)

#quran-verse(
  ("وَٱلسَّمَآءِ", "وَٱلطَّارِقِ", "١"),
  ("wal-samāi", "wal-ṭāriqi", "(1)"),
  ("天空|誓", "启明星|和", ""),
)

以穷苍和启明星盟誓，

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "ٱلطَّارِقُ", "٢"),
  ("wamā", "adrāka", "mā", "l-ṭāriqu", "(2)"),
  ("什么？|和", "你|它使知道", "什么？", "启明星", ""),
)

你怎能知道启明星是什麽？

#quran-verse(
  ("ٱلنَّجْمُ", "ٱلثَّاقِبُ", "٣"),
  ("al-najmu", "l-thāqibu", "(3)"),
  ("星", "灿烂的", ""),
)

是那灿烂的明星。

#quran-verse(
  ("إِن", "كُلُّ", "نَفْسٍۢ", "لَّمَّا", "عَلَيْهَا", "حَافِظٌۭ", "٤"),
  ("in", "kullu", "nafsin", "lammā", "ʿalayhā", "ḥāfiẓun", "(4)"),
  ("不", "每个", "人的", "除了", "她|在", "一个保护者", ""),
)

每个人，都有一个保护者。

#quran-verse(
  ("فَلْيَنظُرِ", "ٱلْإِنسَـٰنُ", "مِمَّ", "خُلِقَ", "٥"),
  ("falyanẓuri", "l-insānu", "mimma", "khuliqa", "(5)"),
  ("他思考|应该|因此", "世人", "什么？|从", "他被创造", ""),
)

人应当想一想，他自己是用什麽造成的？

#quran-verse(
  ("خُلِقَ", "مِن", "مَّآءٍۢ", "دَافِقٍۢ", "٦"),
  ("khuliqa", "min", "māin", "dāfiqin", "(6)"),
  ("他被创造", "从", "水", "被射出的", ""),
)

他是射出的精液造成的。

#quran-verse(
  ("يَخْرُجُ", "مِنۢ", "بَيْنِ", "ٱلصُّلْبِ", "وَٱلتَّرَآئِبِ", "٧"),
  ("yakhruju", "min", "bayni", "l-ṣul'bi", "wal-tarāibi", "(7)"),
  ("它(水)出自", "从", "之间", "脊柱的", "胸肋的|和", ""),
)

那精液是从脊柱和肋骨之间发出的。

#quran-verse(
  ("إِنَّهُۥ", "عَلَىٰ", "رَجْعِهِۦ", "لَقَادِرٌۭ", "٨"),
  ("innahu", "ʿalā", "rajʿihi", "laqādirun", "(8)"),
  ("他(真主)|确实", "在", "他的|复原", "大能的|必定", ""),
)

真主确是能使他复原的，

#quran-verse(
  ("يَوْمَ", "تُبْلَى", "ٱلسَّرَآئِرُ", "٩"),
  ("yawma", "tub'lā", "l-sarāiru", "(9)"),
  ("日子", "它被揭穿", "众秘密", ""),
)

那是在一切秘密被揭穿之日。

#quran-verse(
  ("فَمَا", "لَهُۥ", "مِن", "قُوَّةٍۢ", "وَلَا", "نَاصِرٍۢ", "١٠"),
  ("famā", "lahu", "min", "quwwatin", "walā", "nāṣirin", "(10)"),
  ("没有|然后", "他|为", "从", "力量", "不|和", "援助者", ""),
)

他绝没有能力，也没有援助者。

#quran-verse(
  ("وَٱلسَّمَآءِ", "ذَاتِ", "ٱلرَّجْعِ", "١١"),
  ("wal-samāi", "dhāti", "l-rajʿi", "(11)"),
  ("天|誓", "有的", "云的", ""),
)

以含雨的云

#quran-verse(
  ("وَٱلْأَرْضِ", "ذَاتِ", "ٱلصَّدْعِ", "١٢"),
  ("wal-arḍi", "dhāti", "l-ṣadʿi", "(12)"),
  ("大地|和", "有的", "缝的", ""),
)

和有缝的地发誓，

#quran-verse(
  ("إِنَّهُۥ", "لَقَوْلٌۭ", "فَصْلٌۭ", "١٣"),
  ("innahu", "laqawlun", "faṣlun", "(13)"),
  ("它(古兰)|确实", "言辞|必定", "辨真伪的", ""),
)

这确是分别真伪的言辞，

#quran-verse(
  ("وَمَا", "هُوَ", "بِٱلْهَزْلِ", "١٤"),
  ("wamā", "huwa", "bil-hazli", "(14)"),
  ("不|和", "它(古兰)", "笑话|在", ""),
)

这不是笑话。

#quran-verse(
  ("إِنَّهُمْ", "يَكِيدُونَ", "كَيْدًۭا", "١٥"),
  ("innahum", "yakīdūna", "kaydan", "(15)"),
  ("他们|确实", "他们用计谋", "计谋", ""),
)

他们必定要用计谋，

#quran-verse(
  ("وَأَكِيدُ", "كَيْدًۭا", "١٦"),
  ("wa-akīdu", "kaydan", "(16)"),
  ("我用计谋|和", "计谋", ""),
)

我也要用计谋。

#quran-verse(
  ("فَمَهِّلِ", "ٱلْكَـٰفِرِينَ", "أَمْهِلْهُمْ", "رُوَيْدًۢا", "١٧"),
  ("famahhili", "l-kāfirīna", "amhil'hum", "ruwaydan", "(17)"),
  ("你应宽限|然后", "不信道的人们", "他们|你应宽限", "稍微的", ""),
)

所以你当宽限不信道的人们，你当宽限他们一下。

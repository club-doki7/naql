#import "../libquran.typ": *

#show: quran-page.with(title: "An-Nazi'at", title-ar: "النازعات", title-tl: "An-Nazi'at", locator: "079-an-nazi-at")

#quran-verse(
  ("وَٱلنَّـٰزِعَـٰتِ", "غَرْقًۭا", "١"),
  ("wal-nāziʿāti", "gharqan", "(1)"),
)

誓以急掣的，

#quran-verse(
  ("وَٱلنَّـٰشِطَـٰتِ", "نَشْطًۭا", "٢"),
  ("wal-nāshiṭāti", "nashṭan", "(2)"),
)

轻曳的，

#quran-verse(
  ("وَٱلسَّـٰبِحَـٰتِ", "سَبْحًۭا", "٣"),
  ("wal-sābiḥāti", "sabḥan", "(3)"),
)

奔驰的，

#quran-verse(
  ("فَٱلسَّـٰبِقَـٰتِ", "سَبْقًۭا", "٤"),
  ("fal-sābiqāti", "sabqan", "(4)"),
)

先驱的，

#quran-verse(
  ("فَٱلْمُدَبِّرَٰتِ", "أَمْرًۭا", "٥"),
  ("fal-mudabirāti", "amran", "(5)"),
)

决策的，

#quran-verse(
  ("يَوْمَ", "تَرْجُفُ", "ٱلرَّاجِفَةُ", "٦"),
  ("yawma", "tarjufu", "l-rājifatu", "(6)"),
)

当震动者震动，

#quran-verse(
  ("تَتْبَعُهَا", "ٱلرَّادِفَةُ", "٧"),
  ("tatbaʿuhā", "l-rādifatu", "(7)"),
)

而续发者续发之日，

#quran-verse(
  ("قُلُوبٌۭ", "يَوْمَئِذٍۢ", "وَاجِفَةٌ", "٨"),
  ("qulūbun", "yawma-idhin", "wājifatun", "(8)"),
)

在那日，许多心将忐忑不安，

#quran-verse(
  ("أَبْصَـٰرُهَا", "خَـٰشِعَةٌۭ", "٩"),
  ("abṣāruhā", "khāshiʿatun", "(9)"),
)

许多眼将不敢仰视。

#quran-verse(
  ("يَقُولُونَ", "أَءِنَّا", "لَمَرْدُودُونَ", "فِى", "ٱلْحَافِرَةِ", "١٠"),
  ("yaqūlūna", "a-innā", "lamardūdūna", "fī", "l-ḥāfirati", "(10)"),
)

他们说：我们必定复元吗？

#quran-verse(
  ("أَءِذَا", "كُنَّا", "عِظَـٰمًۭا", "نَّخِرَةًۭ", "١١"),
  ("a-idhā", "kunnā", "ʿiẓāman", "nakhiratan", "(11)"),
)

那是在我们已变成朽骨的时候吗？

#quran-verse(
  ("قَالُوا۟", "تِلْكَ", "إِذًۭا", "كَرَّةٌ", "خَاسِرَةٌۭ", "١٢"),
  ("qālū", "til'ka", "idhan", "karratun", "khāsiratun", "(12)"),
)

他们说：然则，那是一次亏折的复原。

#quran-verse(
  ("فَإِنَّمَا", "هِىَ", "زَجْرَةٌۭ", "وَٰحِدَةٌۭ", "١٣"),
  ("fa-innamā", "hiya", "zajratun", "wāḥidatun", "(13)"),
)

那只是一次吼声，

#quran-verse(
  ("فَإِذَا", "هُم", "بِٱلسَّاهِرَةِ", "١٤"),
  ("fa-idhā", "hum", "bil-sāhirati", "(14)"),
)

他们忽然在地面之上。

#quran-verse(
  ("هَلْ", "أَتَىٰكَ", "حَدِيثُ", "مُوسَىٰٓ", "١٥"),
  ("hal", "atāka", "ḥadīthu", "mūsā", "(15)"),
)

穆萨的故事已来临你了吗？

#quran-verse(
  ("إِذْ", "نَادَىٰهُ", "رَبُّهُۥ", "بِٱلْوَادِ", "ٱلْمُقَدَّسِ", "طُوًى", "١٦"),
  ("idh", "nādāhu", "rabbuhu", "bil-wādi", "l-muqadasi", "ṭuwan", "(16)"),
)

当时，他的主，曾在圣谷杜洼中召唤他说：

#quran-verse(
  ("ٱذْهَبْ", "إِلَىٰ", "فِرْعَوْنَ", "إِنَّهُۥ", "طَغَىٰ", "١٧"),
  ("idh'hab", "ilā", "fir'ʿawna", "innahu", "ṭaghā", "(17)"),
)

你到法老那里去吧！他确是悖逆的。

#quran-verse(
  ("فَقُلْ", "هَل", "لَّكَ", "إِلَىٰٓ", "أَن", "تَزَكَّىٰ", "١٨"),
  ("faqul", "hal", "laka", "ilā", "an", "tazakkā", "(18)"),
)

你对他说：'你愿意成为纯洁的人吗？

#quran-verse(
  ("وَأَهْدِيَكَ", "إِلَىٰ", "رَبِّكَ", "فَتَخْشَىٰ", "١٩"),
  ("wa-ahdiyaka", "ilā", "rabbika", "fatakhshā", "(19)"),
)

你愿意我引导你认识你的主，而你畏惧他吗？'

#quran-verse(
  ("فَأَرَىٰهُ", "ٱلْـَٔايَةَ", "ٱلْكُبْرَىٰ", "٢٠"),
  ("fa-arāhu", "l-āyata", "l-kub'rā", "(20)"),
)

他把那最大的迹象昭示了法老，

#quran-verse(
  ("فَكَذَّبَ", "وَعَصَىٰ", "٢١"),
  ("fakadhaba", "waʿaṣā", "(21)"),
)

但他否认，而且违抗。

#quran-verse(
  ("ثُمَّ", "أَدْبَرَ", "يَسْعَىٰ", "٢٢"),
  ("thumma", "adbara", "yasʿā", "(22)"),
)

然后，他转身而奔走。

#quran-verse(
  ("فَحَشَرَ", "فَنَادَىٰ", "٢٣"),
  ("faḥashara", "fanādā", "(23)"),
)

於是，召集民众，而且喊叫，

#quran-verse(
  ("فَقَالَ", "أَنَا۠", "رَبُّكُمُ", "ٱلْأَعْلَىٰ", "٢٤"),
  ("faqāla", "anā", "rabbukumu", "l-aʿlā", "(24)"),
)

说：我是你们的至尊的主。

#quran-verse(
  ("فَأَخَذَهُ", "ٱللَّهُ", "نَكَالَ", "ٱلْـَٔاخِرَةِ", "وَٱلْأُولَىٰٓ", "٢٥"),
  ("fa-akhadhahu", "l-lahu", "nakāla", "l-ākhirati", "wal-ūlā", "(25)"),
)

故真主以后世和今世的刑罚惩治他。

#quran-verse(
  ("إِنَّ", "فِى", "ذَٰلِكَ", "لَعِبْرَةًۭ", "لِّمَن", "يَخْشَىٰٓ", "٢٦"),
  ("inna", "fī", "dhālika", "laʿib'ratan", "liman", "yakhshā", "(26)"),
)

对於畏惧的人们，此中确有一种鉴戒。

#quran-verse(
  ("ءَأَنتُمْ", "أَشَدُّ", "خَلْقًا", "أَمِ", "ٱلسَّمَآءُ ۚ", "بَنَىٰهَا", "٢٧"),
  ("a-antum", "ashaddu", "khalqan", "ami", "l-samāu", "banāhā", "(27)"),
)

你们是更难造的呢？还是天是更难造的呢？他曾建造了天，

#quran-verse(
  ("رَفَعَ", "سَمْكَهَا", "فَسَوَّىٰهَا", "٢٨"),
  ("rafaʿa", "samkahā", "fasawwāhā", "(28)"),
)

他升起它的高度，而成全它的形体，

#quran-verse(
  ("وَأَغْطَشَ", "لَيْلَهَا", "وَأَخْرَجَ", "ضُحَىٰهَا", "٢٩"),
  ("wa-aghṭasha", "laylahā", "wa-akhraja", "ḍuḥāhā", "(29)"),
)

他使它的夜间黑暗，并显出它的光明。

#quran-verse(
  ("وَٱلْأَرْضَ", "بَعْدَ", "ذَٰلِكَ", "دَحَىٰهَآ", "٣٠"),
  ("wal-arḍa", "baʿda", "dhālika", "daḥāhā", "(30)"),
)

此后，他将地面展开，

#quran-verse(
  ("أَخْرَجَ", "مِنْهَا", "مَآءَهَا", "وَمَرْعَىٰهَا", "٣١"),
  ("akhraja", "min'hā", "māahā", "wamarʿāhā", "(31)"),
)

他使地面涌出泉水来，生出植物来。

#quran-verse(
  ("وَٱلْجِبَالَ", "أَرْسَىٰهَا", "٣٢"),
  ("wal-jibāla", "arsāhā", "(32)"),
)

他使山峦稳定，

#quran-verse(
  ("مَتَـٰعًۭا", "لَّكُمْ", "وَلِأَنْعَـٰمِكُمْ", "٣٣"),
  ("matāʿan", "lakum", "wali-anʿāmikum", "(33)"),
)

以便你们和你们的牲畜获得享受。

#quran-verse(
  ("فَإِذَا", "جَآءَتِ", "ٱلطَّآمَّةُ", "ٱلْكُبْرَىٰ", "٣٤"),
  ("fa-idhā", "jāati", "l-ṭāmatu", "l-kub'rā", "(34)"),
)

大难来临的时候，

#quran-verse(
  ("يَوْمَ", "يَتَذَكَّرُ", "ٱلْإِنسَـٰنُ", "مَا", "سَعَىٰ", "٣٥"),
  ("yawma", "yatadhakkaru", "l-insānu", "mā", "saʿā", "(35)"),
)

就是人将记起自己所作的善恶，

#quran-verse(
  ("وَبُرِّزَتِ", "ٱلْجَحِيمُ", "لِمَن", "يَرَىٰ", "٣٦"),
  ("waburrizati", "l-jaḥīmu", "liman", "yarā", "(36)"),
)

火狱将为能见的人显露出来的日子。

#quran-verse(
  ("فَأَمَّا", "مَن", "طَغَىٰ", "٣٧"),
  ("fa-ammā", "man", "ṭaghā", "(37)"),
)

悖逆

#quran-verse(
  ("وَءَاثَرَ", "ٱلْحَيَوٰةَ", "ٱلدُّنْيَا", "٣٨"),
  ("waāthara", "l-ḥayata", "l-dun'yā", "(38)"),
)

而且选择今世生活的人，

#quran-verse(
  ("فَإِنَّ", "ٱلْجَحِيمَ", "هِىَ", "ٱلْمَأْوَىٰ", "٣٩"),
  ("fa-inna", "l-jaḥīma", "hiya", "l-mawā", "(39)"),
)

火狱必为他的归宿。

#quran-verse(
  ("وَأَمَّا", "مَنْ", "خَافَ", "مَقَامَ", "رَبِّهِۦ", "وَنَهَى", "ٱلنَّفْسَ", "عَنِ", "ٱلْهَوَىٰ", "٤٠"),
  ("wa-ammā", "man", "khāfa", "maqāma", "rabbihi", "wanahā", "l-nafsa", "ʿani", "l-hawā", "(40)"),
)

至於怕站在主的御前受审问，并戒除私欲的人，

#quran-verse(
  ("فَإِنَّ", "ٱلْجَنَّةَ", "هِىَ", "ٱلْمَأْوَىٰ", "٤١"),
  ("fa-inna", "l-janata", "hiya", "l-mawā", "(41)"),
)

乐园必为他的归宿。

#quran-verse(
  ("يَسْـَٔلُونَكَ", "عَنِ", "ٱلسَّاعَةِ", "أَيَّانَ", "مُرْسَىٰهَا", "٤٢"),
  ("yasalūnaka", "ʿani", "l-sāʿati", "ayyāna", "mur'sāhā", "(42)"),
)

他们问你复活时在什么时候实现，

#quran-verse(
  ("فِيمَ", "أَنتَ", "مِن", "ذِكْرَىٰهَآ", "٤٣"),
  ("fīma", "anta", "min", "dhik'rāhā", "(43)"),
)

你怎能说明它呢？

#quran-verse(
  ("إِلَىٰ", "رَبِّكَ", "مُنتَهَىٰهَآ", "٤٤"),
  ("ilā", "rabbika", "muntahāhā", "(44)"),
)

惟有你的主能知它的究竟。

#quran-verse(
  ("إِنَّمَآ", "أَنتَ", "مُنذِرُ", "مَن", "يَخْشَىٰهَا", "٤٥"),
  ("innamā", "anta", "mundhiru", "man", "yakhshāhā", "(45)"),
)

你的警告只有裨於畏惧它的人，

#quran-verse(
  ("كَأَنَّهُمْ", "يَوْمَ", "يَرَوْنَهَا", "لَمْ", "يَلْبَثُوٓا۟", "إِلَّا", "عَشِيَّةً", "أَوْ", "ضُحَىٰهَا", "٤٦"),
  ("ka-annahum", "yawma", "yarawnahā", "lam", "yalbathū", "illā", "ʿashiyyatan", "aw", "ḍuḥāhā", "(46)"),
)

他们在见它的那日，好像在坟里只逗留过一朝或一夕。

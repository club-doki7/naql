)

#quran-verse(
  ("وَلَن", "يُؤَخِّرَ", "ٱللَّهُ", "نَفْسًا", "إِذَا", "جَآءَ", "أَجَلُهَا ۚ", "وَٱللَّهُ", "خَبِيرٌۢ", "بِمَا", "تَعْمَلُونَ", "١١"),
  ("walan", "yu-akhira", "l-lahu", "nafsan", "idhā", "jāa", "ajaluhā", "wal-lahu", "khabīrun", "bimā", "taʿmalūna", "(11)"),
  ([但寿限一到，真主绝不让任何人延迟，真主是彻知你们的行为的。]),
)

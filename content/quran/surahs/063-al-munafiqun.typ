  ([他们说：如果我们返回麦地那，尊荣者必将卑贱者驱逐出城。尊荣只是真主和使者以及信士们的，而伪信的人们却不知道！]),
)

#quran-verse(
  ("يَـٰٓأَيُّهَا", "ٱلَّذِينَ", "ءَامَنُوا۟", "لَا", "تُلْهِكُمْ", "أَمْوَٰلُكُمْ", "وَلَآ", "أَوْلَـٰدُكُمْ", "عَن", "ذِكْرِ", "ٱللَّهِ ۚ", "وَمَن", "يَفْعَلْ", "ذَٰلِكَ", "فَأُو۟لَـٰٓئِكَ", "هُمُ", "ٱلْخَـٰسِرُونَ", "٩"),
  ("yāayyuhā", "alladhīna", "āmanū", "lā", "tul'hikum", "amwālukum", "walā", "awlādukum", "ʿan", "dhik'ri", "l-lahi", "waman", "yafʿal", "dhālika", "fa-ulāika", "humu", "l-khāsirūna", "(9)"),
  ([信道的人们啊！你们的财产和子女，不要使你们忽略了记念真主。谁那样做，谁是亏折的。]),
)

#quran-verse(
  ("وَأَنفِقُوا۟", "مِن", "مَّا", "رَزَقْنَـٰكُم", "مِّن", "قَبْلِ", "أَن", "يَأْتِىَ", "أَحَدَكُمُ", "ٱلْمَوْتُ", "فَيَقُولَ", "رَبِّ", "لَوْلَآ", "أَخَّرْتَنِىٓ", "إِلَىٰٓ", "أَجَلٍۢ", "قَرِيبٍۢ", "فَأَصَّدَّقَ", "وَأَكُن", "مِّنَ", "ٱلصَّـٰلِحِينَ", "١٠"),
  ("wa-anfiqū", "min", "mā", "razaqnākum", "min", "qabli", "an", "yatiya", "aḥadakumu", "l-mawtu", "fayaqūla", "rabbi", "lawlā", "akhartanī", "ilā", "ajalin", "qarībin", "fa-aṣṣaddaqa", "wa-akun", "mina", "l-ṣāliḥīna", "(10)"),

  ("ittakhadhū", "aymānahum", "junnatan", "faṣaddū", "ʿan", "sabīli", "l-lahi", "innahum", "sāa", "mā", "kānū", "yaʿmalūna", "(2)"),
  ([他们以自己的盟誓为护符，妨碍主道。他们的行为真恶劣！]),
)

#quran-verse(
  ("ذَٰلِكَ", "بِأَنَّهُمْ", "ءَامَنُوا۟", "ثُمَّ", "كَفَرُوا۟", "فَطُبِعَ", "عَلَىٰ", "قُلُوبِهِمْ", "فَهُمْ", "لَا", "يَفْقَهُونَ", "٣"),

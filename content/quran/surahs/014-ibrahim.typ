  "256",
  ("ﱸ", "ﱹ", "ﱺ", "ﱻ", "ﱼ", "ﱽ", "ﱾ", "ﱿ", "ﲀ", "ﲁ", "ﲂ", "ﲃ", "ﲄ", "ﲅ", "ﲆ", "ﲇ", "ﲈﲉ", "ﲊ", "ﲋ", "ﲌ", "ﲍ", "ﲎ", "ﲏ", "ﲐ", "ﲑ", "ﲒ", "ﲓ", "ﲔ", "ﲕ", "ﲖ", "ﲗ", "ﲘ", "ﲙ", "ﲚ", "ﲛ", "ﲜ", "ﲝ", "ﲞ"),

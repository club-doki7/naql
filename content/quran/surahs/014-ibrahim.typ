  [艾列弗，俩目，拉仪。（这是）一章经，我把它降示你，以便你奉主的命令而把众人从重重黑暗中引入光明，引入强大的、可颂的主的大道。],
)

#quran-verse(
  verse-num: 2,
  "255",
  ("ﱤ", "ﱥ", "ﱦ", "ﱧ", "ﱨ", "ﱩ", "ﱪ", "ﱫ", "ﱬﱭ", "ﱮ", "ﱯ", "ﱰ", "ﱱ", "ﱲ", "ﱳ"),

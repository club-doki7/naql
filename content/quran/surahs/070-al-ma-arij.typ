#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Ma'arij", title-ar: "المعارج", title-tl: "Al-Ma'arij", locator: "070-al-ma-arij")

#quran-verse(
  ("سَأَلَ", "سَآئِلٌۢ", "بِعَذَابٍۢ", "وَاقِعٍۢ", "١"),
  ("sa-ala", "sāilun", "biʿadhābin", "wāqiʿin", "(1)"),
)

有人曾请求一种将发生的刑罚。

#quran-verse(
  ("لِّلْكَـٰفِرِينَ", "لَيْسَ", "لَهُۥ", "دَافِعٌۭ", "٢"),
  ("lil'kāfirīna", "laysa", "lahu", "dāfiʿun", "(2)"),
)

那是为不信的人们而预定的，没有任何人能加以抵抗。

#quran-verse(
  ("مِّنَ", "ٱللَّهِ", "ذِى", "ٱلْمَعَارِجِ", "٣"),
  ("mina", "l-lahi", "dhī", "l-maʿāriji", "(3)"),
)

那是真主--天梯的主宰--发出的，

#quran-verse(
  ("تَعْرُجُ", "ٱلْمَلَـٰٓئِكَةُ", "وَٱلرُّوحُ", "إِلَيْهِ", "فِى", "يَوْمٍۢ", "كَانَ", "مِقْدَارُهُۥ", "خَمْسِينَ", "أَلْفَ", "سَنَةٍۢ", "٤"),
  ("taʿruju", "l-malāikatu", "wal-rūḥu", "ilayhi", "fī", "yawmin", "kāna", "miq'dāruhu", "khamsīna", "alfa", "sanatin", "(4)"),
)

众天神和精神在一日之内升到他那里。那一日的长度是五万年。

#quran-verse(
  ("فَٱصْبِرْ", "صَبْرًۭا", "جَمِيلًا", "٥"),
  ("fa-iṣ'bir", "ṣabran", "jamīlan", "(5)"),
)

你安然地忍受吧。

#quran-verse(
  ("إِنَّهُمْ", "يَرَوْنَهُۥ", "بَعِيدًۭا", "٦"),
  ("innahum", "yarawnahu", "baʿīdan", "(6)"),
)

他们以为那刑罚是很远的，

#quran-verse(
  ("وَنَرَىٰهُ", "قَرِيبًۭا", "٧"),
  ("wanarāhu", "qarīban", "(7)"),
)

我却以为那是很近的。

#quran-verse(
  ("يَوْمَ", "تَكُونُ", "ٱلسَّمَآءُ", "كَٱلْمُهْلِ", "٨"),
  ("yawma", "takūnu", "l-samāu", "kal-muh'li", "(8)"),
)

在那日天像熔铜，

#quran-verse(
  ("وَتَكُونُ", "ٱلْجِبَالُ", "كَٱلْعِهْنِ", "٩"),
  ("watakūnu", "l-jibālu", "kal-ʿih'ni", "(9)"),
)

山像彩绒。

#quran-verse(
  ("وَلَا", "يَسْـَٔلُ", "حَمِيمٌ", "حَمِيمًۭا", "١٠"),
  ("walā", "yasalu", "ḥamīmun", "ḥamīman", "(10)"),
)

亲戚相见不相问。

#quran-verse(
  ("يُبَصَّرُونَهُمْ ۚ", "يَوَدُّ", "ٱلْمُجْرِمُ", "لَوْ", "يَفْتَدِى", "مِنْ", "عَذَابِ", "يَوْمِئِذٍۭ", "بِبَنِيهِ", "١١"),
  ("yubaṣṣarūnahum", "yawaddu", "l-muj'rimu", "law", "yaftadī", "min", "ʿadhābi", "yawmi-idhin", "bibanīhi", "(11)"),
)

罪人愿意赎取那日的刑罚，即使牺牲他的儿女、

#quran-verse(
  ("وَصَـٰحِبَتِهِۦ", "وَأَخِيهِ", "١٢"),
  ("waṣāḥibatihi", "wa-akhīhi", "(12)"),
)

他的妻子、他的弟兄，

#quran-verse(
  ("وَفَصِيلَتِهِ", "ٱلَّتِى", "تُـْٔوِيهِ", "١٣"),
  ("wafaṣīlatihi", "allatī", "tu'wīhi", "(13)"),
)

和那收容他的血族，

#quran-verse(
  ("وَمَن", "فِى", "ٱلْأَرْضِ", "جَمِيعًۭا", "ثُمَّ", "يُنجِيهِ", "١٤"),
  ("waman", "fī", "l-arḍi", "jamīʿan", "thumma", "yunjīhi", "(14)"),
)

以及大地上所有的人，但愿那能拯救自己。

#quran-verse(
  ("كَلَّآ ۖ", "إِنَّهَا", "لَظَىٰ", "١٥"),
  ("kallā", "innahā", "laẓā", "(15)"),
)

绝不然，那确是发焰的烈火，

#quran-verse(
  ("نَزَّاعَةًۭ", "لِّلشَّوَىٰ", "١٦"),
  ("nazzāʿatan", "lilshawā", "(16)"),
)

能揭去头皮，

#quran-verse(
  ("تَدْعُوا۟", "مَنْ", "أَدْبَرَ", "وَتَوَلَّىٰ", "١٧"),
  ("tadʿū", "man", "adbara", "watawallā", "(17)"),
)

能召唤转身而逃避的人。

#quran-verse(
  ("وَجَمَعَ", "فَأَوْعَىٰٓ", "١٨"),
  ("wajamaʿa", "fa-awʿā", "(18)"),
)

他曾聚积财产而加以保藏，

#quran-verse(
  ("۞ إِنَّ", "ٱلْإِنسَـٰنَ", "خُلِقَ", "هَلُوعًا", "١٩"),
  ("inna", "l-insāna", "khuliqa", "halūʿan", "(19)"),
)

人确是被造成浮躁的，

#quran-verse(
  ("إِذَا", "مَسَّهُ", "ٱلشَّرُّ", "جَزُوعًۭا", "٢٠"),
  ("idhā", "massahu", "l-sharu", "jazūʿan", "(20)"),
)

遭遇灾殃的时候是烦恼的，

#quran-verse(
  ("وَإِذَا", "مَسَّهُ", "ٱلْخَيْرُ", "مَنُوعًا", "٢١"),
  ("wa-idhā", "massahu", "l-khayru", "manūʿan", "(21)"),
)

获得财富的时候是吝啬的。

#quran-verse(
  ("إِلَّا", "ٱلْمُصَلِّينَ", "٢٢"),
  ("illā", "l-muṣalīna", "(22)"),
)

只有礼拜的人们，不是那样，

#quran-verse(
  ("ٱلَّذِينَ", "هُمْ", "عَلَىٰ", "صَلَاتِهِمْ", "دَآئِمُونَ", "٢٣"),
  ("alladhīna", "hum", "ʿalā", "ṣalātihim", "dāimūna", "(23)"),
)

他们是常守拜功的；

#quran-verse(
  ("وَٱلَّذِينَ", "فِىٓ", "أَمْوَٰلِهِمْ", "حَقٌّۭ", "مَّعْلُومٌۭ", "٢٤"),
  ("wa-alladhīna", "fī", "amwālihim", "ḥaqqun", "maʿlūmun", "(24)"),
)

他们的财产中有一个定份，

#quran-verse(
  ("لِّلسَّآئِلِ", "وَٱلْمَحْرُومِ", "٢٥"),
  ("lilssāili", "wal-maḥrūmi", "(25)"),
)

是用於施济乞丐和贫民的；

#quran-verse(
  ("وَٱلَّذِينَ", "يُصَدِّقُونَ", "بِيَوْمِ", "ٱلدِّينِ", "٢٦"),
  ("wa-alladhīna", "yuṣaddiqūna", "biyawmi", "l-dīni", "(26)"),
)

他们是承认报应之日的；

#quran-verse(
  ("وَٱلَّذِينَ", "هُم", "مِّنْ", "عَذَابِ", "رَبِّهِم", "مُّشْفِقُونَ", "٢٧"),
  ("wa-alladhīna", "hum", "min", "ʿadhābi", "rabbihim", "mush'fiqūna", "(27)"),
)

他们是畏惧他们的主的刑罚的。

#quran-verse(
  ("إِنَّ", "عَذَابَ", "رَبِّهِمْ", "غَيْرُ", "مَأْمُونٍۢ", "٢٨"),
  ("inna", "ʿadhāba", "rabbihim", "ghayru", "mamūnin", "(28)"),
)

他们的主的刑罚，确是难保不降临的。

#quran-verse(
  ("وَٱلَّذِينَ", "هُمْ", "لِفُرُوجِهِمْ", "حَـٰفِظُونَ", "٢٩"),
  ("wa-alladhīna", "hum", "lifurūjihim", "ḥāfiẓūna", "(29)"),
)

他们是保守贞操的，

#quran-verse(
  ("إِلَّا", "عَلَىٰٓ", "أَزْوَٰجِهِمْ", "أَوْ", "مَا", "مَلَكَتْ", "أَيْمَـٰنُهُمْ", "فَإِنَّهُمْ", "غَيْرُ", "مَلُومِينَ", "٣٠"),
  ("illā", "ʿalā", "azwājihim", "aw", "mā", "malakat", "aymānuhum", "fa-innahum", "ghayru", "malūmīna", "(30)"),
)

除非对自己的妻子和奴婢，他们确是不因此而受责备的；

#quran-verse(
  ("فَمَنِ", "ٱبْتَغَىٰ", "وَرَآءَ", "ذَٰلِكَ", "فَأُو۟لَـٰٓئِكَ", "هُمُ", "ٱلْعَادُونَ", "٣١"),
  ("famani", "ib'taghā", "warāa", "dhālika", "fa-ulāika", "humu", "l-ʿādūna", "(31)"),
)

凡在这个范围之外有所要求的人，都是过份的。

#quran-verse(
  ("وَٱلَّذِينَ", "هُمْ", "لِأَمَـٰنَـٰتِهِمْ", "وَعَهْدِهِمْ", "رَٰعُونَ", "٣٢"),
  ("wa-alladhīna", "hum", "li-amānātihim", "waʿahdihim", "rāʿūna", "(32)"),
)

他们是尊重自己所受的信托，和自己所缔的盟约的；

#quran-verse(
  ("وَٱلَّذِينَ", "هُم", "بِشَهَـٰدَٰتِهِمْ", "قَآئِمُونَ", "٣٣"),
  ("wa-alladhīna", "hum", "bishahādātihim", "qāimūna", "(33)"),
)

他们是秉公作证的；

#quran-verse(
  ("وَٱلَّذِينَ", "هُمْ", "عَلَىٰ", "صَلَاتِهِمْ", "يُحَافِظُونَ", "٣٤"),
  ("wa-alladhīna", "hum", "ʿalā", "ṣalātihim", "yuḥāfiẓūna", "(34)"),
)

他们是谨守拜功的。

#quran-verse(
  ("أُو۟لَـٰٓئِكَ", "فِى", "جَنَّـٰتٍۢ", "مُّكْرَمُونَ", "٣٥"),
  ("ulāika", "fī", "jannātin", "muk'ramūna", "(35)"),
)

这等人，是在乐园中受优待的。

#quran-verse(
  ("فَمَالِ", "ٱلَّذِينَ", "كَفَرُوا۟", "قِبَلَكَ", "مُهْطِعِينَ", "٣٦"),
  ("famāli", "alladhīna", "kafarū", "qibalaka", "muh'ṭiʿīna", "(36)"),
)

不信道的人们，怎么注视著你，三五成群的分列

#quran-verse(
  ("عَنِ", "ٱلْيَمِينِ", "وَعَنِ", "ٱلشِّمَالِ", "عِزِينَ", "٣٧"),
  ("ʿani", "l-yamīni", "waʿani", "l-shimāli", "ʿizīna", "(37)"),
)

在你的左右呢？

#quran-verse(
  ("أَيَطْمَعُ", "كُلُّ", "ٱمْرِئٍۢ", "مِّنْهُمْ", "أَن", "يُدْخَلَ", "جَنَّةَ", "نَعِيمٍۢ", "٣٨"),
  ("ayaṭmaʿu", "kullu", "im'ri-in", "min'hum", "an", "yud'khala", "jannata", "naʿīmin", "(38)"),
)

难道他们每个人都希望入恩泽的乐园吗？

#quran-verse(
  ("كَلَّآ ۖ", "إِنَّا", "خَلَقْنَـٰهُم", "مِّمَّا", "يَعْلَمُونَ", "٣٩"),
  ("kallā", "innā", "khalaqnāhum", "mimmā", "yaʿlamūna", "(39)"),
)

绝不然！我确已用他们所知道的物质创造了他们。

#quran-verse(
  ("فَلَآ", "أُقْسِمُ", "بِرَبِّ", "ٱلْمَشَـٰرِقِ", "وَٱلْمَغَـٰرِبِ", "إِنَّا", "لَقَـٰدِرُونَ", "٤٠"),
  ("falā", "uq'simu", "birabbi", "l-mashāriqi", "wal-maghāribi", "innā", "laqādirūna", "(40)"),
)

不然，我以一切东方和西方的主盟誓，我确是全能的，

#quran-verse(
  ("عَلَىٰٓ", "أَن", "نُّبَدِّلَ", "خَيْرًۭا", "مِّنْهُمْ", "وَمَا", "نَحْنُ", "بِمَسْبُوقِينَ", "٤١"),
  ("ʿalā", "an", "nubaddila", "khayran", "min'hum", "wamā", "naḥnu", "bimasbūqīna", "(41)"),
)

我能以比他们更好的人代替他们，我不是无能的。

#quran-verse(
  ("فَذَرْهُمْ", "يَخُوضُوا۟", "وَيَلْعَبُوا۟", "حَتَّىٰ", "يُلَـٰقُوا۟", "يَوْمَهُمُ", "ٱلَّذِى", "يُوعَدُونَ", "٤٢"),
  ("fadharhum", "yakhūḍū", "wayalʿabū", "ḥattā", "yulāqū", "yawmahumu", "alladhī", "yūʿadūna", "(42)"),
)

你应当任他们妄谈，任他们游戏，直到他们看到他们所被警告的日子。

#quran-verse(
  ("يَوْمَ", "يَخْرُجُونَ", "مِنَ", "ٱلْأَجْدَاثِ", "سِرَاعًۭا", "كَأَنَّهُمْ", "إِلَىٰ", "نُصُبٍۢ", "يُوفِضُونَ", "٤٣"),
  ("yawma", "yakhrujūna", "mina", "l-ajdāthi", "sirāʿan", "ka-annahum", "ilā", "nuṣubin", "yūfiḍūna", "(43)"),
)

在那日，他们将从坟中出来奔走，他们好像奔到牌位一样，

#quran-verse(
  ("خَـٰشِعَةً", "أَبْصَـٰرُهُمْ", "تَرْهَقُهُمْ", "ذِلَّةٌۭ ۚ", "ذَٰلِكَ", "ٱلْيَوْمُ", "ٱلَّذِى", "كَانُوا۟", "يُوعَدُونَ", "٤٤"),
  ("khāshiʿatan", "abṣāruhum", "tarhaquhum", "dhillatun", "dhālika", "l-yawmu", "alladhī", "kānū", "yūʿadūna", "(44)"),
)

同时，他们身遭凌辱，不敢仰视。那是他们被警告的日子。

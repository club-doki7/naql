  ("akuffārukum", "khayrun", "min", "ulāikum", "am", "lakum", "barāatun", "fī", "l-zuburi", "(43)"),
  ([你们中不信道的人们比这等人还优秀呢！还是天经中有关于你们的赦条呢？]),
)

#quran-verse(
  ("أَمْ", "يَقُولُونَ", "نَحْنُ", "جَمِيعٌۭ", "مُّنتَصِرٌۭ", "٤٤"),
  ("am", "yaqūlūna", "naḥnu", "jamīʿun", "muntaṣirun", "(44)"),
  ([难道他们说：我们是一个常胜的团体。]),
)

#quran-verse(
  ("سَيُهْزَمُ", "ٱلْجَمْعُ", "وَيُوَلُّونَ", "ٱلدُّبُرَ", "٤٥"),
  ("sayuh'zamu", "l-jamʿu", "wayuwallūna", "l-dubura", "(45)"),
  ([那个团体将败北，他们将转背。]),
)

#quran-verse(
  ("بَلِ", "ٱلسَّاعَةُ", "مَوْعِدُهُمْ", "وَٱلسَّاعَةُ", "أَدْهَىٰ", "وَأَمَرُّ", "٤٦"),
  ("bali", "l-sāʿatu", "mawʿiduhum", "wal-sāʿatu", "adhā", "wa-amarru", "(46)"),
  ([不然，复活时是他们的约期；复活时是更艰难的，是更辛苦的。]),
)

#quran-verse(
  ("إِنَّ", "ٱلْمُجْرِمِينَ", "فِى", "ضَلَـٰلٍۢ", "وَسُعُرٍۢ", "٤٧"),
  ("inna", "l-muj'rimīna", "fī", "ḍalālin", "wasuʿurin", "(47)"),
  ([犯罪者的确在迷误和烈火中。]),
)

#quran-verse(
  ("يَوْمَ", "يُسْحَبُونَ", "فِى", "ٱلنَّارِ", "عَلَىٰ", "وُجُوهِهِمْ", "ذُوقُوا۟", "مَسَّ", "سَقَرَ", "٤٨"),
  ("yawma", "yus'ḥabūna", "fī", "l-nāri", "ʿalā", "wujūhihim", "dhūqū", "massa", "saqara", "(48)"),
  ([他们匍匐着被拖入火狱之日，将对他们说：你们尝试火狱的烧灼吧！]),
)

#quran-verse(
  ("إِنَّا", "كُلَّ", "شَىْءٍ", "خَلَقْنَـٰهُ", "بِقَدَرٍۢ", "٤٩"),
  ("innā", "kulla", "shayin", "khalaqnāhu", "biqadarin", "(49)"),
  ([我确已依定量而创造万物，]),
)

#quran-verse(
  ("وَمَآ", "أَمْرُنَآ", "إِلَّا", "وَٰحِدَةٌۭ", "كَلَمْحٍۭ", "بِٱلْبَصَرِ", "٥٠"),
  ("wamā", "amrunā", "illā", "wāḥidatun", "kalamḥin", "bil-baṣari", "(50)"),
  ([我的命令只是快如转瞬的一句话。]),
)

#quran-verse(
  ("وَلَقَدْ", "أَهْلَكْنَآ", "أَشْيَاعَكُمْ", "فَهَلْ", "مِن", "مُّدَّكِرٍۢ", "٥١"),
  ("walaqad", "ahlaknā", "ashyāʿakum", "fahal", "min", "muddakirin", "(51)"),
  ([我确已将你们的宗派毁灭了。有接受劝告的人吗？]),
)

#quran-verse(
  ("وَكُلُّ", "شَىْءٍۢ", "فَعَلُوهُ", "فِى", "ٱلزُّبُرِ", "٥٢"),
  ("wakullu", "shayin", "faʿalūhu", "fī", "l-zuburi", "(52)"),
  ([凡他们所做的事，都记载在天经中。]),
)

#quran-verse(
  ("وَكُلُّ", "صَغِيرٍۢ", "وَكَبِيرٍۢ", "مُّسْتَطَرٌ", "٥٣"),
  ("wakullu", "ṣaghīrin", "wakabīrin", "mus'taṭarun", "(53)"),
  ([一切小事和大事，都是被记录的。]),
)

#quran-verse(
  ("إِنَّ", "ٱلْمُتَّقِينَ", "فِى", "جَنَّـٰتٍۢ", "وَنَهَرٍۢ", "٥٤"),
  ("inna", "l-mutaqīna", "fī", "jannātin", "wanaharin", "(54)"),
  ([敬畏的人们，必定在乐园里，在光明中，]),
)

#quran-verse(
  ("فِى", "مَقْعَدِ", "صِدْقٍ", "عِندَ", "مَلِيكٍۢ", "مُّقْتَدِرٍۭ", "٥٥"),
  ("fī", "maqʿadi", "ṣid'qin", "ʿinda", "malīkin", "muq'tadirin", "(55)"),
  ([在全能的主那里，得居一个如意的地位。]),
)

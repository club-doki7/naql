#quran-verse(
  ("ٱنظُرْ", "كَيْفَ", "ضَرَبُوا۟", "لَكَ", "ٱلْأَمْثَـٰلَ", "فَضَلُّوا۟", "فَلَا", "يَسْتَطِيعُونَ", "سَبِيلًۭا", "٩"),
  ("unẓur", "kayfa", "ḍarabū", "laka", "l-amthāla", "faḍallū", "falā", "yastaṭīʿūna", "sabīlan", "(9)"),

  ("لَّهُمْ", "فِيهَا", "مَا", "يَشَآءُونَ", "خَـٰلِدِينَ ۚ", "كَانَ", "عَلَىٰ", "رَبِّكَ", "وَعْدًۭا", "مَّسْـُٔولًۭا", "١٦"),

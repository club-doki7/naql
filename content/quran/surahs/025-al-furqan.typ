  ("لَّا", "تَدْعُوا۟", "ٱلْيَوْمَ", "ثُبُورًۭا", "وَٰحِدًۭا", "وَٱدْعُوا۟", "ثُبُورًۭا", "كَثِيرًۭا", "١٤"),

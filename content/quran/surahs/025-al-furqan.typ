#quran-verse(
  ("وَإِذَآ", "أُلْقُوا۟", "مِنْهَا", "مَكَانًۭا", "ضَيِّقًۭا", "مُّقَرَّنِينَ", "دَعَوْا۟", "هُنَالِكَ", "ثُبُورًۭا", "١٣"),

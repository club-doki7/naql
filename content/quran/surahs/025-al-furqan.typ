#quran-verse(
  ("قُلْ", "أَذَٰلِكَ", "خَيْرٌ", "أَمْ", "جَنَّةُ", "ٱلْخُلْدِ", "ٱلَّتِى", "وُعِدَ", "ٱلْمُتَّقُونَ ۚ", "كَانَتْ", "لَهُمْ", "جَزَآءًۭ", "وَمَصِيرًۭا", "١٥"),

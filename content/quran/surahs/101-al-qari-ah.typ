#import "../libquran.typ": quran-verse

= Al-Qari'ah (القارعة)

#quran-verse(
  ("ٱلْقَارِعَةُ", "١"),
  ("al-qāriʿatu", "(1)"),
  ("敲(大难)", ""),
)

大难,

#quran-verse(
  ("مَا", "ٱلْقَارِعَةُ", "٢"),
  ("mā", "l-qāriʿatu", "(2)"),
  ("什么?", "敲(大难)", ""),
)

大难是什么？

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "ٱلْقَارِعَةُ", "٣"),
  ("wamā", "adrāka", "mā", "l-qāriʿatu", "(3)"),
  ("什么?|和", "你|它使知道", "什么?", "敲(大难)", ""),
)

你怎能知道大难是什么？

#quran-verse(
  ("يَوْمَ", "يَكُونُ", "ٱلنَّاسُ", "كَٱلْفَرَاشِ", "ٱلْمَبْثُوثِ", "٤"),
  ("yawma", "yakūnu", "l-nāsu", "kal-farāshi", "l-mabthūthi", "(4)"),
  ("日子", "他是", "世人", "飞蛾|像", "分散的", ""),
)

在那日, 众人将似分散的飞蛾,

#quran-verse(
  ("وَتَكُونُ", "ٱلْجِبَالُ", "كَٱلْعِهْنِ", "ٱلْمَنفُوشِ", "٥"),
  ("watakūnu", "l-jibālu", "kal-ʿih'ni", "l-manfūshi", "(5)"),
  ("它(她)是|和", "众山", "羊毛|像", "疏松的", ""),
)

山岳将似疏松的采绒。

#quran-verse(
  ("فَأَمَّا", "مَن", "ثَقُلَتْ", "مَوَٰزِينُهُۥ", "٦"),
  ("fa-ammā", "man", "thaqulat", "mawāzīnuhu", "(6)"),
  ("至于|然后", "谁", "她(它)重", "他的|份量", ""),
)

至於善功的份量较重者,

#quran-verse(
  ("فَهُوَ", "فِى", "عِيشَةٍۢ", "رَّاضِيَةٍۢ", "٧"),
  ("fahuwa", "fī", "ʿīshatin", "rāḍiyatin", "(7)"),
  ("他|然后", "在", "生活", "满是的(指天园)", ""),
)

将在满意的生活中;

#quran-verse(
  ("وَأَمَّا", "مَنْ", "خَفَّتْ", "مَوَٰزِينُهُۥ", "٨"),
  ("wa-ammā", "man", "khaffat", "mawāzīnuhu", "(8)"),
  ("至于|和", "谁", "(她)它轻", "他的|份量", ""),
)

至於善功的份量较轻者,

#quran-verse(
  ("فَأُمُّهُۥ", "هَاوِيَةٌۭ", "٩"),
  ("fa-ummuhu", "hāwiyatun", "(9)"),
  ("它(居所)的|母亲(归宿)|然后", "深坑", ""),
)

他的归宿是深坑。

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "هِيَهْ", "١٠"),
  ("wamā", "adrāka", "mā", "hiyah", "(10)"),
  ("什么？|和", "你|它使知道", "什么？", "静止的ُْه|她(它)", ""),
)

你怎能知道深坑里有什么？

#quran-verse(
  ("نَارٌ", "حَامِيَةٌۢ", "١١"),
  ("nārun", "ḥāmiyatun", "(11)"),
  ("烈火", "猛烈的", ""),
)

有烈火。

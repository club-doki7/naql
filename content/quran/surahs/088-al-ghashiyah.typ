#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Ghashiyah", title-ar: "الغاشية", title-tl: "Al-Ghashiyah", locator: "088-al-ghashiyah")

#quran-verse(
  ("هَلْ", "أَتَىٰكَ", "حَدِيثُ", "ٱلْغَـٰشِيَةِ", "١"),
  ("hal", "atāka", "ḥadīthu", "l-ghāshiyati", "(1)"),
)

大灾的消息，确已降临你了，

#quran-verse(
  ("وُجُوهٌۭ", "يَوْمَئِذٍ", "خَـٰشِعَةٌ", "٢"),
  ("wujūhun", "yawma-idhin", "khāshiʿatun", "(2)"),
)

在那日，将有许多人，是恭敬的、

#quran-verse(
  ("عَامِلَةٌۭ", "نَّاصِبَةٌۭ", "٣"),
  ("ʿāmilatun", "nāṣibatun", "(3)"),
)

劳动的、辛苦的，

#quran-verse(
  ("تَصْلَىٰ", "نَارًا", "حَامِيَةًۭ", "٤"),
  ("taṣlā", "nāran", "ḥāmiyatan", "(4)"),
)

他们将入烈火，

#quran-verse(
  ("تُسْقَىٰ", "مِنْ", "عَيْنٍ", "ءَانِيَةٍۢ", "٥"),
  ("tus'qā", "min", "ʿaynin", "āniyatin", "(5)"),
)

将饮沸泉，

#quran-verse(
  ("لَّيْسَ", "لَهُمْ", "طَعَامٌ", "إِلَّا", "مِن", "ضَرِيعٍۢ", "٦"),
  ("laysa", "lahum", "ṭaʿāmun", "illā", "min", "ḍarīʿin", "(6)"),
)

他们没有食物，但有荆棘，

#quran-verse(
  ("لَّا", "يُسْمِنُ", "وَلَا", "يُغْنِى", "مِن", "جُوعٍۢ", "٧"),
  ("lā", "yus'minu", "walā", "yugh'nī", "min", "jūʿin", "(7)"),
)

既不能肥人，又不能充饥；

#quran-verse(
  ("وُجُوهٌۭ", "يَوْمَئِذٍۢ", "نَّاعِمَةٌۭ", "٨"),
  ("wujūhun", "yawma-idhin", "nāʿimatun", "(8)"),
)

在那日，将有许多人，是享福的，

#quran-verse(
  ("لِّسَعْيِهَا", "رَاضِيَةٌۭ", "٩"),
  ("lisaʿyihā", "rāḍiyatun", "(9)"),
)

是为其劳绩而愉快的，

#quran-verse(
  ("فِى", "جَنَّةٍ", "عَالِيَةٍۢ", "١٠"),
  ("fī", "jannatin", "ʿāliyatin", "(10)"),
)

他们将在崇高的乐园中，

#quran-verse(
  ("لَّا", "تَسْمَعُ", "فِيهَا", "لَـٰغِيَةًۭ", "١١"),
  ("lā", "tasmaʿu", "fīhā", "lāghiyatan", "(11)"),
)

听不到恶言，

#quran-verse(
  ("فِيهَا", "عَيْنٌۭ", "جَارِيَةٌۭ", "١٢"),
  ("fīhā", "ʿaynun", "jāriyatun", "(12)"),
)

里面有流泉，

#quran-verse(
  ("فِيهَا", "سُرُرٌۭ", "مَّرْفُوعَةٌۭ", "١٣"),
  ("fīhā", "sururun", "marfūʿatun", "(13)"),
)

里面有高榻，

#quran-verse(
  ("وَأَكْوَابٌۭ", "مَّوْضُوعَةٌۭ", "١٤"),
  ("wa-akwābun", "mawḍūʿatun", "(14)"),
)

有陈设著的杯盏，

#quran-verse(
  ("وَنَمَارِقُ", "مَصْفُوفَةٌۭ", "١٥"),
  ("wanamāriqu", "maṣfūfatun", "(15)"),
)

有排列著的靠枕，

#quran-verse(
  ("وَزَرَابِىُّ", "مَبْثُوثَةٌ", "١٦"),
  ("wazarābiyyu", "mabthūthatun", "(16)"),
)

有铺展开的绒毯。

#quran-verse(
  ("أَفَلَا", "يَنظُرُونَ", "إِلَى", "ٱلْإِبِلِ", "كَيْفَ", "خُلِقَتْ", "١٧"),
  ("afalā", "yanẓurūna", "ilā", "l-ibili", "kayfa", "khuliqat", "(17)"),
)

难道他们不观察吗？骆驼是怎样造成的，

#quran-verse(
  ("وَإِلَى", "ٱلسَّمَآءِ", "كَيْفَ", "رُفِعَتْ", "١٨"),
  ("wa-ilā", "l-samāi", "kayfa", "rufiʿat", "(18)"),
)

天是怎样升高的，

#quran-verse(
  ("وَإِلَى", "ٱلْجِبَالِ", "كَيْفَ", "نُصِبَتْ", "١٩"),
  ("wa-ilā", "l-jibāli", "kayfa", "nuṣibat", "(19)"),
)

山峦是怎样竖起的，

#quran-verse(
  ("وَإِلَى", "ٱلْأَرْضِ", "كَيْفَ", "سُطِحَتْ", "٢٠"),
  ("wa-ilā", "l-arḍi", "kayfa", "suṭiḥat", "(20)"),
)

大地是怎样展开的。

#quran-verse(
  ("فَذَكِّرْ", "إِنَّمَآ", "أَنتَ", "مُذَكِّرٌۭ", "٢١"),
  ("fadhakkir", "innamā", "anta", "mudhakkirun", "(21)"),
)

你当教诲，你只是教诲（他们的），

#quran-verse(
  ("لَّسْتَ", "عَلَيْهِم", "بِمُصَيْطِرٍ", "٢٢"),
  ("lasta", "ʿalayhim", "bimuṣayṭirin", "(22)"),
)

你绝不是监察他们的，

#quran-verse(
  ("إِلَّا", "مَن", "تَوَلَّىٰ", "وَكَفَرَ", "٢٣"),
  ("illā", "man", "tawallā", "wakafara", "(23)"),
)

但谁转身离去而且不信道，

#quran-verse(
  ("فَيُعَذِّبُهُ", "ٱللَّهُ", "ٱلْعَذَابَ", "ٱلْأَكْبَرَ", "٢٤"),
  ("fayuʿadhibuhu", "l-lahu", "l-ʿadhāba", "l-akbara", "(24)"),
)

真主将以最大的刑罚惩治谁。

#quran-verse(
  ("إِنَّ", "إِلَيْنَآ", "إِيَابَهُمْ", "٢٥"),
  ("inna", "ilaynā", "iyābahum", "(25)"),
)

他们必定只归於我，

#quran-verse(
  ("ثُمَّ", "إِنَّ", "عَلَيْنَا", "حِسَابَهُم", "٢٦"),
  ("thumma", "inna", "ʿalaynā", "ḥisābahum", "(26)"),
)

他们的稽核，必定由我负责。

#quran-verse(
  ("دَعْوَىٰهُمْ", "فِيهَا", "سُبْحَـٰنَكَ", "ٱللَّهُمَّ", "وَتَحِيَّتُهُمْ", "فِيهَا", "سَلَـٰمٌۭ ۚ", "وَءَاخِرُ", "دَعْوَىٰهُمْ", "أَنِ", "ٱلْحَمْدُ", "لِلَّهِ", "رَبِّ", "ٱلْعَـٰلَمِينَ", "١٠"),

#import "../libquran.typ": quran-verse

= Al-Qiyamah (القيامة)

#quran-verse(
  ("لَآ", "أُقْسِمُ", "بِيَوْمِ", "ٱلْقِيَـٰمَةِ", "١"),
  ("lā", "uq'simu", "biyawmi", "l-qiyāmati", "(1)"),
  ("不", "我起誓", "日子|在", "复活的", ""),
)

我以复活日盟誓，

#quran-verse(
  ("وَلَآ", "أُقْسِمُ", "بِٱلنَّفْسِ", "ٱللَّوَّامَةِ", "٢"),
  ("walā", "uq'simu", "bil-nafsi", "l-lawāmati", "(2)"),
  ("不|和", "我起誓", "世人|在", "自责的", ""),
)

我以自责的灵魂盟誓，

#quran-verse(
  ("أَيَحْسَبُ", "ٱلْإِنسَـٰنُ", "أَلَّن", "نَّجْمَعَ", "عِظَامَهُۥ", "٣"),
  ("ayaḥsabu", "l-insānu", "allan", "najmaʿa", "ʿiẓāmahu", "(3)"),
  ("他猜测|吗?", "世人", "不|那个", "我集合", "他的|骸骨", ""),
)

难道人猜想我绝不能集合他的骸骨吗？

#quran-verse(
  ("بَلَىٰ", "قَـٰدِرِينَ", "عَلَىٰٓ", "أَن", "نُّسَوِّىَ", "بَنَانَهُۥ", "٤"),
  ("balā", "qādirīna", "ʿalā", "an", "nusawwiya", "banānahu", "(4)"),
  ("是的", "能够", "在", "那个", "我们复原", "他的|众手指", ""),
)

不然，（我将集合他的骸骨），而且能使他的每个手指复原。

#quran-verse(
  ("بَلْ", "يُرِيدُ", "ٱلْإِنسَـٰنُ", "لِيَفْجُرَ", "أَمَامَهُۥ", "٥"),
  ("bal", "yurīdu", "l-insānu", "liyafjura", "amāmahu", "(5)"),
  ("不然", "他希望", "世人", "他放荡|至", "他的|之前", ""),
)

不然，人欲长此放荡下去。

#quran-verse(
  ("يَسْـَٔلُ", "أَيَّانَ", "يَوْمُ", "ٱلْقِيَـٰمَةِ", "٦"),
  ("yasalu", "ayyāna", "yawmu", "l-qiyāmati", "(6)"),
  ("他问", "何时?", "日子", "复活的", ""),
)

他问复活日在甚么时候。

#quran-verse(
  ("فَإِذَا", "بَرِقَ", "ٱلْبَصَرُ", "٧"),
  ("fa-idhā", "bariqa", "l-baṣaru", "(7)"),
  ("当|然后", "它昏花", "眼睛", ""),
)

当眼目昏花，

#quran-verse(
  ("وَخَسَفَ", "ٱلْقَمَرُ", "٨"),
  ("wakhasafa", "l-qamaru", "(8)"),
  ("它昏暗|和", "月亮", ""),
)

月亮昏暗，

#quran-verse(
  ("وَجُمِعَ", "ٱلشَّمْسُ", "وَٱلْقَمَرُ", "٩"),
  ("wajumiʿa", "l-shamsu", "wal-qamaru", "(9)"),
  ("它被相合|和", "太阳", "月亮|和", ""),
)

日月相合的时候，

#quran-verse(
  ("يَقُولُ", "ٱلْإِنسَـٰنُ", "يَوْمَئِذٍ", "أَيْنَ", "ٱلْمَفَرُّ", "١٠"),
  ("yaqūlu", "l-insānu", "yawma-idhin", "ayna", "l-mafaru", "(10)"),
  ("他说", "世人", "那日", "何处?", "逃避", ""),
)

在那日，人将说：逃到哪里去呢？

#quran-verse(
  ("كَلَّا", "لَا", "وَزَرَ", "١١"),
  ("kallā", "lā", "wazara", "(11)"),
  ("不然", "不", "庇护所", ""),
)

绝不然，绝无任何避难所。

#quran-verse(
  ("إِلَىٰ", "رَبِّكَ", "يَوْمَئِذٍ", "ٱلْمُسْتَقَرُّ", "١٢"),
  ("ilā", "rabbika", "yawma-idhin", "l-mus'taqaru", "(12)"),
  ("至", "你的|养主", "那日", "安定之所", ""),
)

在那日，唯你的主那里，有安定之所。

#quran-verse(
  ("يُنَبَّؤُا۟", "ٱلْإِنسَـٰنُ", "يَوْمَئِذٍۭ", "بِمَا", "قَدَّمَ", "وَأَخَّرَ", "١٣"),
  ("yunabba-u", "l-insānu", "yawma-idhin", "bimā", "qaddama", "wa-akhara", "(13)"),
  ("他被告之", "世人", "那日", "什么|在", "他前做", "他后做|和", ""),
)

在那日，各人将被告知自己前前后后做过的事情。

#quran-verse(
  ("بَلِ", "ٱلْإِنسَـٰنُ", "عَلَىٰ", "نَفْسِهِۦ", "بَصِيرَةٌۭ", "١٤"),
  ("bali", "l-insānu", "ʿalā", "nafsihi", "baṣīratun", "(14)"),
  ("不然", "世人", "在", "他的|自己", "明证", ""),
)

不然，各人对自己就是明证，

#quran-verse(
  ("وَلَوْ", "أَلْقَىٰ", "مَعَاذِيرَهُۥ", "١٥"),
  ("walaw", "alqā", "maʿādhīrahu", "(15)"),
  ("如果|和", "他提出", "他的|托词", ""),
)

即使他多方托辞。

#quran-verse(
  ("لَا", "تُحَرِّكْ", "بِهِۦ", "لِسَانَكَ", "لِتَعْجَلَ", "بِهِۦٓ", "١٦"),
  ("lā", "tuḥarrik", "bihi", "lisānaka", "litaʿjala", "bihi", "(16)"),
  ("不", "你摆动", "它|在", "你的|舌头", "你匆促|至", "它|在", ""),
)

你不要摇动你的舌头，以便你仓卒地诵读它。

#quran-verse(
  ("إِنَّ", "عَلَيْنَا", "جَمْعَهُۥ", "وَقُرْءَانَهُۥ", "١٧"),
  ("inna", "ʿalaynā", "jamʿahu", "waqur'ānahu", "(17)"),
  ("确实", "我们|在", "它的|集合", "它的|诵读|和", ""),
)

集合它和诵读它，确是我的责任。

#quran-verse(
  ("فَإِذَا", "قَرَأْنَـٰهُ", "فَٱتَّبِعْ", "قُرْءَانَهُۥ", "١٨"),
  ("fa-idhā", "qaranāhu", "fa-ittabiʿ", "qur'ānahu", "(18)"),
  ("当|然后", "它|我们诵读", "你应静听|然后", "它的|诵读", ""),
)

当我诵读它的时候，你当静听我的诵读。

#quran-verse(
  ("ثُمَّ", "إِنَّ", "عَلَيْنَا", "بَيَانَهُۥ", "١٩"),
  ("thumma", "inna", "ʿalaynā", "bayānahu", "(19)"),
  ("然后", "确实", "我们|在", "它的|解释", ""),
)

然后解释它，也是我的责任。

#quran-verse(
  ("كَلَّا", "بَلْ", "تُحِبُّونَ", "ٱلْعَاجِلَةَ", "٢٠"),
  ("kallā", "bal", "tuḥibbūna", "l-ʿājilata", "(20)"),
  ("真的", "不然", "你们喜爱", "今世生活", ""),
)

真的，你们喜爱现世的生活，

#quran-verse(
  ("وَتَذَرُونَ", "ٱلْـَٔاخِرَةَ", "٢١"),
  ("watadharūna", "l-ākhirata", "(21)"),
  ("他不顾|和", "后世", ""),
)

而不顾后世的生活。

#quran-verse(
  ("وُجُوهٌۭ", "يَوْمَئِذٍۢ", "نَّاضِرَةٌ", "٢٢"),
  ("wujūhun", "yawma-idhin", "nāḍiratun", "(22)"),
  ("众脸", "那日", "光华的", ""),
)

在那日，许多面目是光华的，

#quran-verse(
  ("إِلَىٰ", "رَبِّهَا", "نَاظِرَةٌۭ", "٢٣"),
  ("ilā", "rabbihā", "nāẓiratun", "(23)"),
  ("至", "她的|养主", "仰视", ""),
)

是仰视著他们的主的。

#quran-verse(
  ("وَوُجُوهٌۭ", "يَوْمَئِذٍۭ", "بَاسِرَةٌۭ", "٢٤"),
  ("wawujūhun", "yawma-idhin", "bāsiratun", "(24)"),
  ("众脸|和", "那日", "愁苦的", ""),
)

在那日，许多面目是愁苦的，

#quran-verse(
  ("تَظُنُّ", "أَن", "يُفْعَلَ", "بِهَا", "فَاقِرَةٌۭ", "٢٥"),
  ("taẓunnu", "an", "yuf'ʿala", "bihā", "fāqiratun", "(25)"),
  ("她确信", "那个", "它被遭受", "她|在", "大难", ""),
)

他们确信自己必遭大难。

#quran-verse(
  ("كَلَّآ", "إِذَا", "بَلَغَتِ", "ٱلتَّرَاقِىَ", "٢٦"),
  ("kallā", "idhā", "balaghati", "l-tarāqiya", "(26)"),
  ("真的", "当", "她达到", "锁骨", ""),
)

真的，灵魂达到锁骨，

#quran-verse(
  ("وَقِيلَ", "مَنْ ۜ", "رَاقٍۢ", "٢٧"),
  ("waqīla", "man", "rāqin", "(27)"),
  ("它被说|和", "谁?", "治疗", ""),
)

有人说：谁是祝由的？

#quran-verse(
  ("وَظَنَّ", "أَنَّهُ", "ٱلْفِرَاقُ", "٢٨"),
  ("waẓanna", "annahu", "l-firāqu", "(28)"),
  ("他猜测|和", "它|那个", "离别", ""),
)

他确信那是离别。

#quran-verse(
  ("وَٱلْتَفَّتِ", "ٱلسَّاقُ", "بِٱلسَّاقِ", "٢٩"),
  ("wal-tafati", "l-sāqu", "bil-sāqi", "(29)"),
  ("它缠结|和", "胫", "胫|在", ""),
)

（死时）胫与胫相缠结。

#quran-verse(
  ("إِلَىٰ", "رَبِّكَ", "يَوْمَئِذٍ", "ٱلْمَسَاقُ", "٣٠"),
  ("ilā", "rabbika", "yawma-idhin", "l-masāqu", "(30)"),
  ("至", "你的|养主", "那日", "被驱赶", ""),
)

在那日，他只被驱赶到你的主那里。

#quran-verse(
  ("فَلَا", "صَدَّقَ", "وَلَا", "صَلَّىٰ", "٣١"),
  ("falā", "ṣaddaqa", "walā", "ṣallā", "(31)"),
  ("不|然后", "他信道", "不|和", "他礼拜", ""),
)

他没有信道，也没有礼拜。

#quran-verse(
  ("وَلَـٰكِن", "كَذَّبَ", "وَتَوَلَّىٰ", "٣٢"),
  ("walākin", "kadhaba", "watawallā", "(32)"),
  ("但是|和", "他否认", "他背弃|和", ""),
)

他否认真理，背弃正道，

#quran-verse(
  ("ثُمَّ", "ذَهَبَ", "إِلَىٰٓ", "أَهْلِهِۦ", "يَتَمَطَّىٰٓ", "٣٣"),
  ("thumma", "dhahaba", "ilā", "ahlihi", "yatamaṭṭā", "(33)"),
  ("然后", "他走", "至", "他的|家人", "他傲慢", ""),
)

然后傲慢地走回家去。

#quran-verse(
  ("أَوْلَىٰ", "لَكَ", "فَأَوْلَىٰ", "٣٤"),
  ("awlā", "laka", "fa-awlā", "(34)"),
  ("毁灭", "你|为", "毁灭|然后", ""),
)

毁灭已逐渐地临近你。

#quran-verse(
  ("ثُمَّ", "أَوْلَىٰ", "لَكَ", "فَأَوْلَىٰٓ", "٣٥"),
  ("thumma", "awlā", "laka", "fa-awlā", "(35)"),
  ("然后", "毁灭", "你|为", "毁灭|然后", ""),
)

毁灭已逐渐地临近你。

#quran-verse(
  ("أَيَحْسَبُ", "ٱلْإِنسَـٰنُ", "أَن", "يُتْرَكَ", "سُدًى", "٣٦"),
  ("ayaḥsabu", "l-insānu", "an", "yut'raka", "sudan", "(36)"),
  ("他猜想|吗?", "世人", "那个", "他被放任", "报偿", ""),
)

难道人猜想自己是被放任的吗？

#quran-verse(
  ("أَلَمْ", "يَكُ", "نُطْفَةًۭ", "مِّن", "مَّنِىٍّۢ", "يُمْنَىٰ", "٣٧"),
  ("alam", "yaku", "nuṭ'fatan", "min", "maniyyin", "yum'nā", "(37)"),
  ("不|吗?", "他是", "精液", "从", "射出", "他射出", ""),
)

难道他不曾是被射出精液吗？

#quran-verse(
  ("ثُمَّ", "كَانَ", "عَلَقَةًۭ", "فَخَلَقَ", "فَسَوَّىٰ", "٣٨"),
  ("thumma", "kāna", "ʿalaqatan", "fakhalaqa", "fasawwā", "(38)"),
  ("然后", "他是", "血块", "他创造|然后", "他使完美|然后", ""),
)

然后，他变成血块，而真主加以创造他，使之成为肢体完全的人吗？

#quran-verse(
  ("فَجَعَلَ", "مِنْهُ", "ٱلزَّوْجَيْنِ", "ٱلذَّكَرَ", "وَٱلْأُنثَىٰٓ", "٣٩"),
  ("fajaʿala", "min'hu", "l-zawjayni", "l-dhakara", "wal-unthā", "(39)"),
  ("他造化|然后", "他|从", "两性", "男性", "女性|和", ""),
)

他用精液造化两性，男的和女的。

#quran-verse(
  ("أَلَيْسَ", "ذَٰلِكَ", "بِقَـٰدِرٍ", "عَلَىٰٓ", "أَن", "يُحْـِۧىَ", "ٱلْمَوْتَىٰ", "٤٠"),
  ("alaysa", "dhālika", "biqādirin", "ʿalā", "an", "yuḥ'yiya", "l-mawtā", "(40)"),
  ("他不|吗?", "那个", "造化者|在", "在", "那个", "他复活", "死者", ""),
)

难道那样的造化者不能使死人复活吗？

= Al-Kafirun (الكافرون)

#quran-verse(
  ("قُلْ", "يَـٰٓأَيُّهَا", "ٱلْكَـٰفِرُونَ", "١"),
  ("qul", "yāayyuhā", "l-kāfirūna", "(1)"),
  ("你说", "喂", "不信道的人们", ""),
)

你说：不信道的人们啊！

#quran-verse(
  ("لَآ", "أَعْبُدُ", "مَا", "تَعْبُدُونَ", "٢"),
  ("lā", "aʿbudu", "mā", "taʿbudūna", "(2)"),
  ("不", "我崇拜", "什么", "你们崇拜", ""),
)

我不崇拜你们所崇拜的,

#quran-verse(
  ("وَلَآ", "أَنتُمْ", "عَـٰبِدُونَ", "مَآ", "أَعْبُدُ", "٣"),
  ("walā", "antum", "ʿābidūna", "mā", "aʿbudu", "(3)"),
  ("不|和", "你们", "崇拜", "什么", "我崇拜", ""),
)

你们也不崇拜我所崇拜的;

#quran-verse(
  ("وَلَآ", "أَنَا۠", "عَابِدٌۭ", "مَّا", "عَبَدتُّمْ", "٤"),
  ("walā", "anā", "ʿābidun", "mā", "ʿabadttum", "(4)"),
  ("不|和", "我", "崇拜", "什么", "你们崇拜", ""),
)

我不会崇拜你们所崇拜的,

#quran-verse(
  ("وَلَآ", "أَنتُمْ", "عَـٰبِدُونَ", "مَآ", "أَعْبُدُ", "٥"),
  ("walā", "antum", "ʿābidūna", "mā", "aʿbudu", "(5)"),
  ("不|和", "你们", "崇拜", "什么", "我崇拜", ""),
)

你们也不会崇拜我所崇拜的;

#quran-verse(
  ("لَكُمْ", "دِينُكُمْ", "وَلِىَ", "دِينِ", "٦"),
  ("lakum", "dīnukum", "waliya", "dīni", "(6)"),
  ("你们|为", "你们的|宗教", "我|为|和", "我的|宗教", ""),

#import "../libquran.typ": *

#show: quran-page.with(title: "Al-A'la", title-ar: "الأعلى", title-tl: "Al-A'la", locator: "087-al-a-la")

#quran-verse(
  ("سَبِّحِ", "ٱسْمَ", "رَبِّكَ", "ٱلْأَعْلَى", "١"),
  ("sabbiḥi", "is'ma", "rabbika", "l-aʿlā", "(1)"),
  ("你应赞超绝", "名字", "你的|养主的", "最高的", ""),
)

你当赞颂你至尊主的大名超绝万物，

#quran-verse(
  ("ٱلَّذِى", "خَلَقَ", "فَسَوَّىٰ", "٢"),
  ("alladhī", "khalaqa", "fasawwā", "(2)"),
  ("那个的", "他创造", "他使完美|然后", ""),
)

他创造万物，并使各物匀称。

#quran-verse(
  ("وَٱلَّذِى", "قَدَّرَ", "فَهَدَىٰ", "٣"),
  ("wa-alladhī", "qaddara", "fahadā", "(3)"),
  ("那个的|和", "他预定", "他引导|然后", ""),
)

他预定万物，而加以引导。

#quran-verse(
  ("وَٱلَّذِىٓ", "أَخْرَجَ", "ٱلْمَرْعَىٰ", "٤"),
  ("wa-alladhī", "akhraja", "l-marʿā", "(4)"),
  ("那个的|和", "他使生出", "牧草", ""),
)

他生出牧草，

#quran-verse(
  ("فَجَعَلَهُۥ", "غُثَآءً", "أَحْوَىٰ", "٥"),
  ("fajaʿalahu", "ghuthāan", "aḥwā", "(5)"),
  ("它|他使变成|然后", "干枯", "黑色的", ""),
)

然後使它变成黑色的枯草。

#quran-verse(
  ("سَنُقْرِئُكَ", "فَلَا", "تَنسَىٰٓ", "٦"),
  ("sanuq'ri-uka", "falā", "tansā", "(6)"),
  ("你|我们使读|将", "不|因此", "你忘记", ""),
)

我将使你诵读，故你不会忘记，

#quran-verse(
  ("إِلَّا", "مَا", "شَآءَ", "ٱللَّهُ ۚ", "إِنَّهُۥ", "يَعْلَمُ", "ٱلْجَهْرَ", "وَمَا", "يَخْفَىٰ", "٧"),
  ("illā", "mā", "shāa", "l-lahu", "innahu", "yaʿlamu", "l-jahra", "wamā", "yakhfā", "(7)"),
  ("除了", "什么", "他意欲", "真主", "他|确实", "他知道", "明显的", "什么|和", "他隐藏", ""),
)

除非真主所欲你忘记的。他的确知道显著的和隐微的言行。

#quran-verse(
  ("وَنُيَسِّرُكَ", "لِلْيُسْرَىٰ", "٨"),
  ("wanuyassiruka", "lil'yus'rā", "(8)"),
  ("你|我们使容易|和", "容易|为了", ""),
)

我将使你遵循平易的道路，

#quran-verse(
  ("فَذَكِّرْ", "إِن", "نَّفَعَتِ", "ٱلذِّكْرَىٰ", "٩"),
  ("fadhakkir", "in", "nafaʿati", "l-dhik'rā", "(9)"),
  ("你劝化|因此", "如果", "它有益", "教诲", ""),
)

故你当教诲众人，如果教诲有裨於他们的话。

#quran-verse(
  ("سَيَذَّكَّرُ", "مَن", "يَخْشَىٰ", "١٠"),
  ("sayadhakkaru", "man", "yakhshā", "(10)"),
  ("他觉悟|将", "谁", "他敬畏", ""),
)

畏主的人，将觉悟；

#quran-verse(
  ("وَيَتَجَنَّبُهَا", "ٱلْأَشْقَى", "١١"),
  ("wayatajannabuhā", "l-ashqā", "(11)"),
  ("它(教诲)|他退避|和", "最薄福的人", ""),
)

薄命的人，将退避，

#quran-verse(
  ("ٱلَّذِى", "يَصْلَى", "ٱلنَّارَ", "ٱلْكُبْرَىٰ", "١٢"),
  ("alladhī", "yaṣlā", "l-nāra", "l-kub'rā", "(12)"),
  ("那个人", "他烧烤", "火", "大的", ""),
)

他将入於大火，

#quran-verse(
  ("ثُمَّ", "لَا", "يَمُوتُ", "فِيهَا", "وَلَا", "يَحْيَىٰ", "١٣"),
  ("thumma", "lā", "yamūtu", "fīhā", "walā", "yaḥyā", "(13)"),
  ("然后", "不", "他死", "它(火)|在", "不|和", "他活", ""),
)

然後，在火里不死也不活。

#quran-verse(
  ("قَدْ", "أَفْلَحَ", "مَن", "تَزَكَّىٰ", "١٤"),
  ("qad", "aflaḥa", "man", "tazakkā", "(14)"),
  ("的确", "他成功", "谁", "他洁净", ""),
)

有教养的人确已成功，

#quran-verse(
  ("وَذَكَرَ", "ٱسْمَ", "رَبِّهِۦ", "فَصَلَّىٰ", "١٥"),
  ("wadhakara", "is'ma", "rabbihi", "faṣallā", "(15)"),
  ("他纪念|和", "名字", "他的|养主的", "他礼拜|然后", ""),
)

他记念他的主的尊名，而谨守拜功。

#quran-verse(
  ("بَلْ", "تُؤْثِرُونَ", "ٱلْحَيَوٰةَ", "ٱلدُّنْيَا", "١٦"),
  ("bal", "tu'thirūna", "l-ḥayata", "l-dun'yā", "(16)"),
  ("不然", "你们选择", "生活", "今世的", ""),
)

不然，你们却选择今世的生活；

#quran-verse(
  ("وَٱلْـَٔاخِرَةُ", "خَيْرٌۭ", "وَأَبْقَىٰٓ", "١٧"),
  ("wal-ākhiratu", "khayrun", "wa-abqā", "(17)"),
  ("后世|和", "最美好", "更长久|和", ""),
)

其实，後世是更好的，是更久长的。

#quran-verse(
  ("إِنَّ", "هَـٰذَا", "لَفِى", "ٱلصُّحُفِ", "ٱلْأُولَىٰ", "١٨"),
  ("inna", "hādhā", "lafī", "l-ṣuḥufi", "l-ūlā", "(18)"),
  ("确实", "这个", "在|必定", "经典", "前人的", ""),
)

这确是载在古经典中的，

#quran-verse(
  ("صُحُفِ", "إِبْرَٰهِيمَ", "وَمُوسَىٰ", "١٩"),
  ("ṣuḥufi", "ib'rāhīma", "wamūsā", "(19)"),
  ("经典", "易卜拉欣的", "穆萨的|和", ""),
)

载在易卜拉欣和穆萨的经典中的。

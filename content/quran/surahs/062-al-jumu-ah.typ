当礼拜完毕的时候，你们当散布在地方上，寻求真主的恩惠，你们应当多多地记念真主，以便你们成功。

#quran-verse(
  ("وَإِذَا", "رَأَوْا۟", "تِجَـٰرَةً", "أَوْ", "لَهْوًا", "ٱنفَضُّوٓا۟", "إِلَيْهَا", "وَتَرَكُوكَ", "قَآئِمًۭا ۚ", "قُلْ", "مَا", "عِندَ", "ٱللَّهِ", "خَيْرٌۭ", "مِّنَ", "ٱللَّهْوِ", "وَمِنَ", "ٱلتِّجَـٰرَةِ ۚ", "وَٱللَّهُ", "خَيْرُ", "ٱلرَّٰزِقِينَ", "١١"),
  ("wa-idhā", "ra-aw", "tijāratan", "aw", "lahwan", "infaḍḍū", "ilayhā", "watarakūka", "qāiman", "qul", "mā", "ʿinda", "l-lahi", "khayrun", "mina", "l-lahwi", "wamina", "l-tijārati", "wal-lahu", "khayru", "l-rāziqīna", "(11)"),
  ("当|和", "他们看见", "生意", "或者", "游戏", "他们离开", "它|至", "你|他们使|和", "站立", "你说", "什么", "那里", "真主的", "较好", "比", "游戏", "比|和", "生意", "真主|和", "最好", "供应者的", ""),

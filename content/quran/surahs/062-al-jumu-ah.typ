  ("يَـٰٓأَيُّهَا", "ٱلَّذِينَ", "ءَامَنُوٓا۟", "إِذَا", "نُودِىَ", "لِلصَّلَوٰةِ", "مِن", "يَوْمِ", "ٱلْجُمُعَةِ", "فَٱسْعَوْا۟", "إِلَىٰ", "ذِكْرِ", "ٱللَّهِ", "وَذَرُوا۟", "ٱلْبَيْعَ ۚ", "ذَٰلِكُمْ", "خَيْرٌۭ", "لَّكُمْ", "إِن", "كُنتُمْ", "تَعْلَمُونَ", "٩"),

  ("huwa", "alladhī", "baʿatha", "fī", "l-umiyīna", "rasūlan", "min'hum", "yatlū", "ʿalayhim", "āyātihi", "wayuzakkīhim", "wayuʿallimuhumu", "l-kitāba", "wal-ḥik'mata", "wa-in", "kānū", "min", "qablu", "lafī", "ḍalālin", "mubīnin", "(2)"),

= Al-Jumu'ah (الجمعة)

#quran-verse(
  ("يُسَبِّحُ", "لِلَّهِ", "مَا", "فِى", "ٱلسَّمَـٰوَٰتِ", "وَمَا", "فِى", "ٱلْأَرْضِ", "ٱلْمَلِكِ", "ٱلْقُدُّوسِ", "ٱلْعَزِيزِ", "ٱلْحَكِيمِ", "١"),
  ("yusabbiḥu", "lillahi", "mā", "fī", "l-samāwāti", "wamā", "fī", "l-arḍi", "l-maliki", "l-qudūsi", "l-ʿazīzi", "l-ḥakīmi", "(1)"),

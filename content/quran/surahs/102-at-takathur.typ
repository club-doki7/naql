)

#quran-verse(
  verse-num: 4,
  "600",
  ("ﲞ", "ﲟ", "ﲠ", "ﲡ", "ﲢ"),
  ("thumma", "kallā", "sawfa", "taʿlamūna", "(4)"),
  [真的, 你们将来就知道了。],
)

#quran-verse(

  [他们想吹灭真主的光明，但真主要完成他的光明，即使不信道的人不愿意。],
)

#quran-verse(
  verse-num: 9,
  "552",
  ("ﲀ", "ﲁ", "ﲂ", "ﲃ", "ﲄ", "ﲅ", "ﲆ", "ﲇ", "ﲈ", "ﲉ", "ﲊ", "ﲋ", "ﲌ", "ﲍ", "ﲎ"),

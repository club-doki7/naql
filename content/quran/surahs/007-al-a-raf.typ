  [我确已使你们在大地上安居，并为你们在大地上设生活所需。你们很少感谢。],
)

#quran-verse(
  verse-num: 11,
  "151",
  ("ﲬ", "ﲭ", "ﲮ", "ﲯ", "ﲰ", "ﲱ", "ﲲ", "ﲳ", "ﲴ", "ﲵ", "ﲶ", "ﲷ", "ﲸ", "ﲹ", "ﲺ", "ﲻ", "ﲼ"),

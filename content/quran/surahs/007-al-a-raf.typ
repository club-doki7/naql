#quran-verse(
  ("وَكَم", "مِّن", "قَرْيَةٍ", "أَهْلَكْنَـٰهَا", "فَجَآءَهَا", "بَأْسُنَا", "بَيَـٰتًا", "أَوْ", "هُمْ", "قَآئِلُونَ", "٤"),
  ("wakam", "min", "qaryatin", "ahlaknāhā", "fajāahā", "basunā", "bayātan", "aw", "hum", "qāilūna", "(4)"),
  ("多少|和", "从", "众城镇", "她|我们毁减", "她|她来立|因此", "我们的|刑罚", "夜间", "或者", "他们", "午觉", ""),

善功的分量较轻的人，将因生前不信我的迹象而亏折自身。

#quran-verse(
  ("وَلَقَدْ", "مَكَّنَّـٰكُمْ", "فِى", "ٱلْأَرْضِ", "وَجَعَلْنَا", "لَكُمْ", "فِيهَا", "مَعَـٰيِشَ ۗ", "قَلِيلًۭا", "مَّا", "تَشْكُرُونَ", "١٠"),

)

#quran-verse(
  verse-num: 10,
  "151",
  ("ﲟ", "ﲠ", "ﲡ", "ﲢ", "ﲣ", "ﲤ", "ﲥ", "ﲦﲧ", "ﲨ", "ﲩ", "ﲪ", "ﲫ"),

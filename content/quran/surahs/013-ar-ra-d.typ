#quran-verse(
  ("وَيَقُولُ", "ٱلَّذِينَ", "كَفَرُوا۟", "لَسْتَ", "مُرْسَلًۭا ۚ", "قُلْ", "كَفَىٰ", "بِٱللَّهِ", "شَهِيدًۢا", "بَيْنِى", "وَبَيْنَكُمْ", "وَمَنْ", "عِندَهُۥ", "عِلْمُ", "ٱلْكِتَـٰبِ", "٤٣"),

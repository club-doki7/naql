#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Layl", title-ar: "الليل", title-tl: "Al-Layl", locator: "092-al-layl")

#quran-verse(
  ("وَٱلَّيْلِ", "إِذَا", "يَغْشَىٰ", "١"),
  ("wa-al-layli", "idhā", "yaghshā", "(1)"),
)

以笼罩时的黑夜发誓，

#quran-verse(
  ("وَٱلنَّهَارِ", "إِذَا", "تَجَلَّىٰ", "٢"),
  ("wal-nahāri", "idhā", "tajallā", "(2)"),
)

以显著时的白昼发誓，

#quran-verse(
  ("وَمَا", "خَلَقَ", "ٱلذَّكَرَ", "وَٱلْأُنثَىٰٓ", "٣"),
  ("wamā", "khalaqa", "l-dhakara", "wal-unthā", "(3)"),
)

以创造男性和女性的主发誓，

#quran-verse(
  ("إِنَّ", "سَعْيَكُمْ", "لَشَتَّىٰ", "٤"),
  ("inna", "saʿyakum", "lashattā", "(4)"),
)

你们的行为，确是不同的。

#quran-verse(
  ("فَأَمَّا", "مَنْ", "أَعْطَىٰ", "وَٱتَّقَىٰ", "٥"),
  ("fa-ammā", "man", "aʿṭā", "wa-ittaqā", "(5)"),
)

至於赈济贫民，敬畏真主，

#quran-verse(
  ("وَصَدَّقَ", "بِٱلْحُسْنَىٰ", "٦"),
  ("waṣaddaqa", "bil-ḥus'nā", "(6)"),
)

且承认至善者，

#quran-verse(
  ("فَسَنُيَسِّرُهُۥ", "لِلْيُسْرَىٰ", "٧"),
  ("fasanuyassiruhu", "lil'yus'rā", "(7)"),
)

我将使他易於达到最易的结局。

#quran-verse(
  ("وَأَمَّا", "مَنۢ", "بَخِلَ", "وَٱسْتَغْنَىٰ", "٨"),
  ("wa-ammā", "man", "bakhila", "wa-is'taghnā", "(8)"),
)

至於吝惜钱财，自谓无求，

#quran-verse(
  ("وَكَذَّبَ", "بِٱلْحُسْنَىٰ", "٩"),
  ("wakadhaba", "bil-ḥus'nā", "(9)"),
)

且否认至善者，

#quran-verse(
  ("فَسَنُيَسِّرُهُۥ", "لِلْعُسْرَىٰ", "١٠"),
  ("fasanuyassiruhu", "lil'ʿus'rā", "(10)"),
)

我将使他易於达到最难的结局。

#quran-verse(
  ("وَمَا", "يُغْنِى", "عَنْهُ", "مَالُهُۥٓ", "إِذَا", "تَرَدَّىٰٓ", "١١"),
  ("wamā", "yugh'nī", "ʿanhu", "māluhu", "idhā", "taraddā", "(11)"),
)

当他沦亡的时候，他的财产於他有什麽裨益呢！

#quran-verse(
  ("إِنَّ", "عَلَيْنَا", "لَلْهُدَىٰ", "١٢"),
  ("inna", "ʿalaynā", "lalhudā", "(12)"),
)

我确有指导的责任，

#quran-verse(
  ("وَإِنَّ", "لَنَا", "لَلْـَٔاخِرَةَ", "وَٱلْأُولَىٰ", "١٣"),
  ("wa-inna", "lanā", "lalākhirata", "wal-ūlā", "(13)"),
)

我确有後世和今世的主权。

#quran-verse(
  ("فَأَنذَرْتُكُمْ", "نَارًۭا", "تَلَظَّىٰ", "١٤"),
  ("fa-andhartukum", "nāran", "talaẓẓā", "(14)"),
)

故我警告你们一种发焰的火，

#quran-verse(
  ("لَا", "يَصْلَىٰهَآ", "إِلَّا", "ٱلْأَشْقَى", "١٥"),
  ("lā", "yaṣlāhā", "illā", "l-ashqā", "(15)"),
)

唯薄命者坠入其中，

#quran-verse(
  ("ٱلَّذِى", "كَذَّبَ", "وَتَوَلَّىٰ", "١٦"),
  ("alladhī", "kadhaba", "watawallā", "(16)"),
)

他否认真理，而背弃之。

#quran-verse(
  ("وَسَيُجَنَّبُهَا", "ٱلْأَتْقَى", "١٧"),
  ("wasayujannabuhā", "l-atqā", "(17)"),
)

敬畏者，得免於火刑。

#quran-verse(
  ("ٱلَّذِى", "يُؤْتِى", "مَالَهُۥ", "يَتَزَكَّىٰ", "١٨"),
  ("alladhī", "yu'tī", "mālahu", "yatazakkā", "(18)"),
)

他虔诚地施舍他的财产，

#quran-verse(
  ("وَمَا", "لِأَحَدٍ", "عِندَهُۥ", "مِن", "نِّعْمَةٍۢ", "تُجْزَىٰٓ", "١٩"),
  ("wamā", "li-aḥadin", "ʿindahu", "min", "niʿ'matin", "tuj'zā", "(19)"),
)

他没有受过任何人的应报的恩德，

#quran-verse(
  ("إِلَّا", "ٱبْتِغَآءَ", "وَجْهِ", "رَبِّهِ", "ٱلْأَعْلَىٰ", "٢٠"),
  ("illā", "ib'tighāa", "wajhi", "rabbihi", "l-aʿlā", "(20)"),
)

但他施舍只是为了求他的至尊主的喜悦，

#quran-verse(
  ("وَلَسَوْفَ", "يَرْضَىٰ", "٢١"),
  ("walasawfa", "yarḍā", "(21)"),
)

他自己将来必定喜悦。

  [舍真主而择取保护者的人，真主是监视他们的。你绝不是他们的监护者。],
)

#quran-verse(
  verse-num: 7,
  "483",
  ("ﱿ", "ﲀ", "ﲁ", "ﲂ", "ﲃ", "ﲄ", "ﲅ", "ﲆ", "ﲇ", "ﲈ", "ﲉ", "ﲊ", "ﲋ", "ﲌ", "ﲍ", "ﲎﲏ", "ﲐ", "ﲑ", "ﲒ", "ﲓ", "ﲔ", "ﲕ", "ﲖ"),

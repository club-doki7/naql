  [他们怎么舍他而择取保护者呢？真主才是保护者，他能使死者复活，他对于万事是全能的。],
)

#quran-verse(
  verse-num: 10,
  "483",
  ("ﲾ", "ﲿ", "ﳀ", "ﳁ", "ﳂ", "ﳃ", "ﳄ", "ﳅﳆ", "ﳇ", "ﳈ", "ﳉ", "ﳊ", "ﳋ", "ﳌ", "ﳍ", "ﳎ"),

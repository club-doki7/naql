  [诸天体几乎从上面破裂，众天神赞颂他们的主，并为地面上的人求饶。真的，真主确是至赦的，确是至慈的。],
)

#quran-verse(
  verse-num: 6,
  "483",
  ("ﱲ", "ﱳ", "ﱴ", "ﱵ", "ﱶ", "ﱷ", "ﱸ", "ﱹ", "ﱺ", "ﱻ", "ﱼ", "ﱽ", "ﱾ"),

#import "../libquran.typ": *

#show: quran-page.with(title: "At-Takwir", title-ar: "التكوير", title-tl: "At-Takwir", locator: "081-at-takwir")

#quran-verse(
  ("إِذَا", "ٱلشَّمْسُ", "كُوِّرَتْ", "١"),
  ("idhā", "l-shamsu", "kuwwirat", "(1)"),
)

当太阳黯黜的时候，

#quran-verse(
  ("وَإِذَا", "ٱلنُّجُومُ", "ٱنكَدَرَتْ", "٢"),
  ("wa-idhā", "l-nujūmu", "inkadarat", "(2)"),
)

当星宿零落的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْجِبَالُ", "سُيِّرَتْ", "٣"),
  ("wa-idhā", "l-jibālu", "suyyirat", "(3)"),
)

当山峦崩溃的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْعِشَارُ", "عُطِّلَتْ", "٤"),
  ("wa-idhā", "l-ʿishāru", "ʿuṭṭilat", "(4)"),
)

当孕驼被抛弃的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْوُحُوشُ", "حُشِرَتْ", "٥"),
  ("wa-idhā", "l-wuḥūshu", "ḥushirat", "(5)"),
)

当野兽被集合的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْبِحَارُ", "سُجِّرَتْ", "٦"),
  ("wa-idhā", "l-biḥāru", "sujjirat", "(6)"),
)

当海洋澎湃的时候，

#quran-verse(
  ("وَإِذَا", "ٱلنُّفُوسُ", "زُوِّجَتْ", "٧"),
  ("wa-idhā", "l-nufūsu", "zuwwijat", "(7)"),
)

当灵魂被配合的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْمَوْءُۥدَةُ", "سُئِلَتْ", "٨"),
  ("wa-idhā", "l-mawūdatu", "su-ilat", "(8)"),
)

当被活埋的女孩被询问的时候：

#quran-verse(
  ("بِأَىِّ", "ذَنۢبٍۢ", "قُتِلَتْ", "٩"),
  ("bi-ayyi", "dhanbin", "qutilat", "(9)"),
)

她为什么罪过而遭杀害呢？

#quran-verse(
  ("وَإِذَا", "ٱلصُّحُفُ", "نُشِرَتْ", "١٠"),
  ("wa-idhā", "l-ṣuḥufu", "nushirat", "(10)"),
)

当功过簿被展开的时候，　

#quran-verse(
  ("وَإِذَا", "ٱلسَّمَآءُ", "كُشِطَتْ", "١١"),
  ("wa-idhā", "l-samāu", "kushiṭat", "(11)"),
)

当天皮被揭去的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْجَحِيمُ", "سُعِّرَتْ", "١٢"),
  ("wa-idhā", "l-jaḥīmu", "suʿʿirat", "(12)"),
)

当火狱被燃著的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْجَنَّةُ", "أُزْلِفَتْ", "١٣"),
  ("wa-idhā", "l-janatu", "uz'lifat", "(13)"),
)

当乐园被送近的时候，

#quran-verse(
  ("عَلِمَتْ", "نَفْسٌۭ", "مَّآ", "أَحْضَرَتْ", "١٤"),
  ("ʿalimat", "nafsun", "mā", "aḥḍarat", "(14)"),
)

每个人都知道他所作过的善恶。

#quran-verse(
  ("فَلَآ", "أُقْسِمُ", "بِٱلْخُنَّسِ", "١٥"),
  ("falā", "uq'simu", "bil-khunasi", "(15)"),
)

我誓以运行的众星--

#quran-verse(
  ("ٱلْجَوَارِ", "ٱلْكُنَّسِ", "١٦"),
  ("al-jawāri", "l-kunasi", "(16)"),
)

没落的行星，

#quran-verse(
  ("وَٱلَّيْلِ", "إِذَا", "عَسْعَسَ", "١٧"),
  ("wa-al-layli", "idhā", "ʿasʿasa", "(17)"),
)

和逝去时的黑夜，

#quran-verse(
  ("وَٱلصُّبْحِ", "إِذَا", "تَنَفَّسَ", "١٨"),
  ("wal-ṣub'ḥi", "idhā", "tanaffasa", "(18)"),
)

照耀时的早晨，

#quran-verse(
  ("إِنَّهُۥ", "لَقَوْلُ", "رَسُولٍۢ", "كَرِيمٍۢ", "١٩"),
  ("innahu", "laqawlu", "rasūlin", "karīmin", "(19)"),
)

这确是一个尊贵的使者的言辞，

#quran-verse(
  ("ذِى", "قُوَّةٍ", "عِندَ", "ذِى", "ٱلْعَرْشِ", "مَكِينٍۢ", "٢٠"),
  ("dhī", "quwwatin", "ʿinda", "dhī", "l-ʿarshi", "makīnin", "(20)"),
)

他在宝座的主那里，是有权力的，是有地位的，

#quran-verse(
  ("مُّطَاعٍۢ", "ثَمَّ", "أَمِينٍۢ", "٢١"),
  ("muṭāʿin", "thamma", "amīnin", "(21)"),
)

是众望所归，而且忠於职守的。

#quran-verse(
  ("وَمَا", "صَاحِبُكُم", "بِمَجْنُونٍۢ", "٢٢"),
  ("wamā", "ṣāḥibukum", "bimajnūnin", "(22)"),
)

你们的朋友，不是一个疯人，

#quran-verse(
  ("وَلَقَدْ", "رَءَاهُ", "بِٱلْأُفُقِ", "ٱلْمُبِينِ", "٢٣"),
  ("walaqad", "raāhu", "bil-ufuqi", "l-mubīni", "(23)"),
)

他确已看见那个天使在明显的天边，

#quran-verse(
  ("وَمَا", "هُوَ", "عَلَى", "ٱلْغَيْبِ", "بِضَنِينٍۢ", "٢٤"),
  ("wamā", "huwa", "ʿalā", "l-ghaybi", "biḍanīnin", "(24)"),
)

他对幽玄不是吝教的。

#quran-verse(
  ("وَمَا", "هُوَ", "بِقَوْلِ", "شَيْطَـٰنٍۢ", "رَّجِيمٍۢ", "٢٥"),
  ("wamā", "huwa", "biqawli", "shayṭānin", "rajīmin", "(25)"),
)

这不是被放逐的恶魔的言辞，

#quran-verse(
  ("فَأَيْنَ", "تَذْهَبُونَ", "٢٦"),
  ("fa-ayna", "tadhhabūna", "(26)"),
)

然则, 你们将往那里去呢？

#quran-verse(
  ("إِنْ", "هُوَ", "إِلَّا", "ذِكْرٌۭ", "لِّلْعَـٰلَمِينَ", "٢٧"),
  ("in", "huwa", "illā", "dhik'run", "lil'ʿālamīna", "(27)"),
)

这只是对於全世界的教诲--

#quran-verse(
  ("لِمَن", "شَآءَ", "مِنكُمْ", "أَن", "يَسْتَقِيمَ", "٢٨"),
  ("liman", "shāa", "minkum", "an", "yastaqīma", "(28)"),
)

对於你们中欲循规蹈矩者的教诲，

#quran-verse(
  ("وَمَا", "تَشَآءُونَ", "إِلَّآ", "أَن", "يَشَآءَ", "ٱللَّهُ", "رَبُّ", "ٱلْعَـٰلَمِينَ", "٢٩"),
  ("wamā", "tashāūna", "illā", "an", "yashāa", "l-lahu", "rabbu", "l-ʿālamīna", "(29)"),
)

你们不欲循规蹈矩，除非真主--全世界的主--意欲的时候。　

  ("وَهُوَ", "ٱلْقَاهِرُ", "فَوْقَ", "عِبَادِهِۦ ۚ", "وَهُوَ", "ٱلْحَكِيمُ", "ٱلْخَبِيرُ", "١٨"),
  ("wahuwa", "l-qāhiru", "fawqa", "ʿibādihi", "wahuwa", "l-ḥakīmu", "l-khabīru", "(18)"),
  ("他|和", "全能", "上面", "他的|众仆的", "他|和", "至睿的", "彻知的", ""),
)


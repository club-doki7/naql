#quran-verse(
  ("وَقَالُوا۟", "لَوْلَآ", "أُنزِلَ", "عَلَيْهِ", "مَلَكٌۭ ۖ", "وَلَوْ", "أَنزَلْنَا", "مَلَكًۭا", "لَّقُضِىَ", "ٱلْأَمْرُ", "ثُمَّ", "لَا", "يُنظَرُونَ", "٨"),

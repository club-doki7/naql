#import "../libquran.typ": *

#show: quran-page.with(title: "Al-'Adiyat", title-ar: "العاديات", title-tl: "Al-'Adiyat", locator: "100-al--adiyat")

#quran-verse(
  ("وَٱلْعَـٰدِيَـٰتِ", "ضَبْحًۭا", "١"),
  ("wal-ʿādiyāti", "ḍabḥan", "(1)"),
)

以喘息而奔驰的马队盟誓,

#quran-verse(
  ("فَٱلْمُورِيَـٰتِ", "قَدْحًۭا", "٢"),
  ("fal-mūriyāti", "qadḥan", "(2)"),
)

以蹄发火花的马队盟誓,

#quran-verse(
  ("فَٱلْمُغِيرَٰتِ", "صُبْحًۭا", "٣"),
  ("fal-mughīrāti", "ṣub'ḥan", "(3)"),
)

以早晨出击,

#quran-verse(
  ("فَأَثَرْنَ", "بِهِۦ", "نَقْعًۭا", "٤"),
  ("fa-atharna", "bihi", "naqʿan", "(4)"),
)

卷起尘埃,

#quran-verse(
  ("فَوَسَطْنَ", "بِهِۦ", "جَمْعًا", "٥"),
  ("fawasaṭna", "bihi", "jamʿan", "(5)"),
)

攻入敌围的马队盟誓,

#quran-verse(
  ("إِنَّ", "ٱلْإِنسَـٰنَ", "لِرَبِّهِۦ", "لَكَنُودٌۭ", "٦"),
  ("inna", "l-insāna", "lirabbihi", "lakanūdun", "(6)"),
)

人对于主, 确是孤负的。

#quran-verse(
  ("وَإِنَّهُۥ", "عَلَىٰ", "ذَٰلِكَ", "لَشَهِيدٌۭ", "٧"),
  ("wa-innahu", "ʿalā", "dhālika", "lashahīdun", "(7)"),
)

他自己对那孤负确是见证的,

#quran-verse(
  ("وَإِنَّهُۥ", "لِحُبِّ", "ٱلْخَيْرِ", "لَشَدِيدٌ", "٨"),
  ("wa-innahu", "liḥubbi", "l-khayri", "lashadīdun", "(8)"),
)

他对于财产确是酷好的。

#quran-verse(
  ("۞ أَفَلَا", "يَعْلَمُ", "إِذَا", "بُعْثِرَ", "مَا", "فِى", "ٱلْقُبُورِ", "٩"),
  ("afalā", "yaʿlamu", "idhā", "buʿ'thira", "mā", "fī", "l-qubūri", "(9)"),
)

难道他不知道吗？当坟中的朽骨被揭发,

#quran-verse(
  ("وَحُصِّلَ", "مَا", "فِى", "ٱلصُّدُورِ", "١٠"),
  ("waḥuṣṣila", "mā", "fī", "l-ṣudūri", "(10)"),
)

胸中的秘密被显示的时侯,

#quran-verse(
  ("إِنَّ", "رَبَّهُم", "بِهِمْ", "يَوْمَئِذٍۢ", "لَّخَبِيرٌۢ", "١١"),
  ("inna", "rabbahum", "bihim", "yawma-idhin", "lakhabīrun", "(11)"),
)

在那日, 他们的主, 确是彻知他们的。

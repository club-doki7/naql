#quran-verse(
  ("وَحُصِّلَ", "مَا", "فِى", "ٱلصُّدُورِ", "١٠"),
  ("waḥuṣṣila", "mā", "fī", "l-ṣudūri", "(10)"),
  ("它被知道|和", "什么", "在", "众胸", ""),

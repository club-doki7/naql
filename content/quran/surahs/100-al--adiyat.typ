  ("他|确实|和", "喜好|对", "财产", "激烈|确是", ""),
)

他对于财产确是酷好的。

#quran-verse(
  ("۞ أَفَلَا", "يَعْلَمُ", "إِذَا", "بُعْثِرَ", "مَا", "فِى", "ٱلْقُبُورِ", "٩"),
  ("afalā", "yaʿlamu", "idhā", "buʿ'thira", "mā", "fī", "l-qubūri", "(9)"),
  ("不|然后|难道？", "他知道", "当", "它被揭发", "什么", "在", "众坟墓", ""),
)


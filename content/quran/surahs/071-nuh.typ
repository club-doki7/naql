)

#quran-verse(
  ("قَالَ", "رَبِّ", "إِنِّى", "دَعَوْتُ", "قَوْمِى", "لَيْلًۭا", "وَنَهَارًۭا", "٥"),
  ("qāla", "rabbi", "innī", "daʿawtu", "qawmī", "laylan", "wanahāran", "(5)"),
  ([他说：我的主啊！我确已日夜召唤我的宗族，]),
)

#quran-verse(

#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Mursalat", title-ar: "المرسلات", title-tl: "Al-Mursalat", locator: "077-al-mursalat")

#quran-verse(
  ("وَٱلْمُرْسَلَـٰتِ", "عُرْفًۭا", "١"),
  ("wal-mur'salāti", "ʿur'fan", "(1)"),
)

誓以奉派传达佳音，

#quran-verse(
  ("فَٱلْعَـٰصِفَـٰتِ", "عَصْفًۭا", "٢"),
  ("fal-ʿāṣifāti", "ʿaṣfan", "(2)"),
)

遂猛烈吹动者，

#quran-verse(
  ("وَٱلنَّـٰشِرَٰتِ", "نَشْرًۭا", "٣"),
  ("wal-nāshirāti", "nashran", "(3)"),
)

誓以传播各物，

#quran-verse(
  ("فَٱلْفَـٰرِقَـٰتِ", "فَرْقًۭا", "٤"),
  ("fal-fāriqāti", "farqan", "(4)"),
)

而使之分散，

#quran-verse(
  ("فَٱلْمُلْقِيَـٰتِ", "ذِكْرًا", "٥"),
  ("fal-mul'qiyāti", "dhik'ran", "(5)"),
)

乃传授教训者，

#quran-verse(
  ("عُذْرًا", "أَوْ", "نُذْرًا", "٦"),
  ("ʿudh'ran", "aw", "nudh'ran", "(6)"),
)

誓以示原谅或警告者，

#quran-verse(
  ("إِنَّمَا", "تُوعَدُونَ", "لَوَٰقِعٌۭ", "٧"),
  ("innamā", "tūʿadūna", "lawāqiʿun", "(7)"),
)

警告你们的事，是必定发生的。

#quran-verse(
  ("فَإِذَا", "ٱلنُّجُومُ", "طُمِسَتْ", "٨"),
  ("fa-idhā", "l-nujūmu", "ṭumisat", "(8)"),
)

当星宿黯淡的时候，

#quran-verse(
  ("وَإِذَا", "ٱلسَّمَآءُ", "فُرِجَتْ", "٩"),
  ("wa-idhā", "l-samāu", "furijat", "(9)"),
)

当天体破裂的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْجِبَالُ", "نُسِفَتْ", "١٠"),
  ("wa-idhā", "l-jibālu", "nusifat", "(10)"),
)

当山峦飞扬的时候，

#quran-verse(
  ("وَإِذَا", "ٱلرُّسُلُ", "أُقِّتَتْ", "١١"),
  ("wa-idhā", "l-rusulu", "uqqitat", "(11)"),
)

当众使者被定期召集的时候，

#quran-verse(
  ("لِأَىِّ", "يَوْمٍ", "أُجِّلَتْ", "١٢"),
  ("li-ayyi", "yawmin", "ujjilat", "(12)"),
)

期限在哪日呢？

#quran-verse(
  ("لِيَوْمِ", "ٱلْفَصْلِ", "١٣"),
  ("liyawmi", "l-faṣli", "(13)"),
)

在判决之日。

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "يَوْمُ", "ٱلْفَصْلِ", "١٤"),
  ("wamā", "adrāka", "mā", "yawmu", "l-faṣli", "(14)"),
)

你怎能知道判决之日，是什么？

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "١٥"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(15)"),
)

在那日，伤哉否认真理的人们。

#quran-verse(
  ("أَلَمْ", "نُهْلِكِ", "ٱلْأَوَّلِينَ", "١٦"),
  ("alam", "nuh'liki", "l-awalīna", "(16)"),
)

难道我没有毁灭先民吗？

#quran-verse(
  ("ثُمَّ", "نُتْبِعُهُمُ", "ٱلْـَٔاخِرِينَ", "١٧"),
  ("thumma", "nut'biʿuhumu", "l-ākhirīna", "(17)"),
)

然后，我使后民随他们而消灭。

#quran-verse(
  ("كَذَٰلِكَ", "نَفْعَلُ", "بِٱلْمُجْرِمِينَ", "١٨"),
  ("kadhālika", "nafʿalu", "bil-muj'rimīna", "(18)"),
)

我将这样处治犯罪的人。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "١٩"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(19)"),
)

在那日，伤哉否认真理的人们。

#quran-verse(
  ("أَلَمْ", "نَخْلُقكُّم", "مِّن", "مَّآءٍۢ", "مَّهِينٍۢ", "٢٠"),
  ("alam", "nakhluqkkum", "min", "māin", "mahīnin", "(20)"),
)

难道我没有用薄弱的精液创造你们吗？

#quran-verse(
  ("فَجَعَلْنَـٰهُ", "فِى", "قَرَارٍۢ", "مَّكِينٍ", "٢١"),
  ("fajaʿalnāhu", "fī", "qarārin", "makīnin", "(21)"),
)

. 我把它放在一个坚固的安息之所，

#quran-verse(
  ("إِلَىٰ", "قَدَرٍۢ", "مَّعْلُومٍۢ", "٢٢"),
  ("ilā", "qadarin", "maʿlūmin", "(22)"),
)

到一个定期。

#quran-verse(
  ("فَقَدَرْنَا", "فَنِعْمَ", "ٱلْقَـٰدِرُونَ", "٢٣"),
  ("faqadarnā", "faniʿ'ma", "l-qādirūna", "(23)"),
)

我曾判定，我是善於判定的。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٢٤"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(24)"),
)

在那日，伤哉否认真理的人们。

#quran-verse(
  ("أَلَمْ", "نَجْعَلِ", "ٱلْأَرْضَ", "كِفَاتًا", "٢٥"),
  ("alam", "najʿali", "l-arḍa", "kifātan", "(25)"),
)

难道我没有使大地成为包罗

#quran-verse(
  ("أَحْيَآءًۭ", "وَأَمْوَٰتًۭا", "٢٦"),
  ("aḥyāan", "wa-amwātan", "(26)"),
)

活物和死物的吗？

#quran-verse(
  ("وَجَعَلْنَا", "فِيهَا", "رَوَٰسِىَ", "شَـٰمِخَـٰتٍۢ", "وَأَسْقَيْنَـٰكُم", "مَّآءًۭ", "فُرَاتًۭا", "٢٧"),
  ("wajaʿalnā", "fīhā", "rawāsiya", "shāmikhātin", "wa-asqaynākum", "māan", "furātan", "(27)"),
)

我曾在大地上，安置许多崇高的山峦。我曾赏赐你们甘美的饮料。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٢٨"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(28)"),
)

在那日，伤哉否认真理的人们！

#quran-verse(
  ("ٱنطَلِقُوٓا۟", "إِلَىٰ", "مَا", "كُنتُم", "بِهِۦ", "تُكَذِّبُونَ", "٢٩"),
  ("inṭaliqū", "ilā", "mā", "kuntum", "bihi", "tukadhibūna", "(29)"),
)

你们去享受你们所否认的刑罚吧！

#quran-verse(
  ("ٱنطَلِقُوٓا۟", "إِلَىٰ", "ظِلٍّۢ", "ذِى", "ثَلَـٰثِ", "شُعَبٍۢ", "٣٠"),
  ("inṭaliqū", "ilā", "ẓillin", "dhī", "thalāthi", "shuʿabin", "(30)"),
)

你们去享受有三个权的荫影吧！

#quran-verse(
  ("لَّا", "ظَلِيلٍۢ", "وَلَا", "يُغْنِى", "مِنَ", "ٱللَّهَبِ", "٣١"),
  ("lā", "ẓalīlin", "walā", "yugh'nī", "mina", "l-lahabi", "(31)"),
)

那荫影不是阴凉的，不能遮挡火焰的热浪。

#quran-verse(
  ("إِنَّهَا", "تَرْمِى", "بِشَرَرٍۢ", "كَٱلْقَصْرِ", "٣٢"),
  ("innahā", "tarmī", "bishararin", "kal-qaṣri", "(32)"),
)

那火焰喷射出宫殿般的火星，

#quran-verse(
  ("كَأَنَّهُۥ", "جِمَـٰلَتٌۭ", "صُفْرٌۭ", "٣٣"),
  ("ka-annahu", "jimālatun", "ṣuf'run", "(33)"),
)

好像黧黑的骆驼一样。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٣٤"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(34)"),
)

在那日，伤哉否认真理的人们！

#quran-verse(
  ("هَـٰذَا", "يَوْمُ", "لَا", "يَنطِقُونَ", "٣٥"),
  ("hādhā", "yawmu", "lā", "yanṭiqūna", "(35)"),
)

这是他们不得发言之日。

#quran-verse(
  ("وَلَا", "يُؤْذَنُ", "لَهُمْ", "فَيَعْتَذِرُونَ", "٣٦"),
  ("walā", "yu'dhanu", "lahum", "fayaʿtadhirūna", "(36)"),
)

他们不蒙许可，故不能道歉。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٣٧"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(37)"),
)

在那日，伤哉否认真理的人们！

#quran-verse(
  ("هَـٰذَا", "يَوْمُ", "ٱلْفَصْلِ ۖ", "جَمَعْنَـٰكُمْ", "وَٱلْأَوَّلِينَ", "٣٨"),
  ("hādhā", "yawmu", "l-faṣli", "jamaʿnākum", "wal-awalīna", "(38)"),
)

这是判决之日，我把你们和先民集合在一处。

#quran-verse(
  ("فَإِن", "كَانَ", "لَكُمْ", "كَيْدٌۭ", "فَكِيدُونِ", "٣٩"),
  ("fa-in", "kāna", "lakum", "kaydun", "fakīdūni", "(39)"),
)

如果你们有什么计谋，你们可对我用计。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٤٠"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(40)"),
)

在那日，伤哉否认真理的人们！

#quran-verse(
  ("إِنَّ", "ٱلْمُتَّقِينَ", "فِى", "ظِلَـٰلٍۢ", "وَعُيُونٍۢ", "٤١"),
  ("inna", "l-mutaqīna", "fī", "ẓilālin", "waʿuyūnin", "(41)"),
)

敬畏的人们，必定在树荫之下，清泉之滨，

#quran-verse(
  ("وَفَوَٰكِهَ", "مِمَّا", "يَشْتَهُونَ", "٤٢"),
  ("wafawākiha", "mimmā", "yashtahūna", "(42)"),
)

享受他们爱吃的水果，

#quran-verse(
  ("كُلُوا۟", "وَٱشْرَبُوا۟", "هَنِيٓـًٔۢا", "بِمَا", "كُنتُمْ", "تَعْمَلُونَ", "٤٣"),
  ("kulū", "wa-ish'rabū", "hanīan", "bimā", "kuntum", "taʿmalūna", "(43)"),
)

将对他们说：你们曾经行善，故你们痛快地饮食吧！

#quran-verse(
  ("إِنَّا", "كَذَٰلِكَ", "نَجْزِى", "ٱلْمُحْسِنِينَ", "٤٤"),
  ("innā", "kadhālika", "najzī", "l-muḥ'sinīna", "(44)"),
)

我必定这样报酬行善的人们。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٤٥"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(45)"),
)

在那日，伤哉否认真理的人们。

#quran-verse(
  ("كُلُوا۟", "وَتَمَتَّعُوا۟", "قَلِيلًا", "إِنَّكُم", "مُّجْرِمُونَ", "٤٦"),
  ("kulū", "watamattaʿū", "qalīlan", "innakum", "muj'rimūna", "(46)"),
)

你们暂时吃喝享受吧！你们确是犯罪的人。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٤٧"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(47)"),
)

在那日，伤哉否认真理的人们！

#quran-verse(
  ("وَإِذَا", "قِيلَ", "لَهُمُ", "ٱرْكَعُوا۟", "لَا", "يَرْكَعُونَ", "٤٨"),
  ("wa-idhā", "qīla", "lahumu", "ir'kaʿū", "lā", "yarkaʿūna", "(48)"),
)

有人对他们说：你们当鞠躬。他们不肯鞠躬。

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "٤٩"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(49)"),
)

伤哉否认真理的人们！

#quran-verse(
  ("فَبِأَىِّ", "حَدِيثٍۭ", "بَعْدَهُۥ", "يُؤْمِنُونَ", "٥٠"),
  ("fabi-ayyi", "ḥadīthin", "baʿdahu", "yu'minūna", "(50)"),
)

除《古兰经》外，他们要信仰什么文辞呢？

#quran-verse(
  verse-num: 1,
  "560",
  ("ﱁ", "ﱂ", "ﱃ", "ﱄ", "ﱅ", "ﱆ", "ﱇ", "ﱈﱉ", "ﱊ", "ﱋ", "ﱌﱍ", "ﱎ", "ﱏ", "ﱐ", "ﱑ"),
  ("yāayyuhā", "l-nabiyu", "lima", "tuḥarrimu", "mā", "aḥalla", "l-lahu", "laka", "tabtaghī", "marḍāta", "azwājika", "wal-lahu", "ghafūrun", "raḥīmun", "(1)"),
  [先知啊！真主准许你享受的，你为什么加以禁戒，以便向你的妻子们讨好呢？真主是至赦的，是至慈的。],
)

#quran-verse(
  verse-num: 2,
  "560",
  ("ﱒ", "ﱓ", "ﱔ", "ﱕ", "ﱖ", "ﱗﱘ", "ﱙ", "ﱚﱛ", "ﱜ", "ﱝ", "ﱞ", "ﱟ"),
  ("qad", "faraḍa", "l-lahu", "lakum", "taḥillata", "aymānikum", "wal-lahu", "mawlākum", "wahuwa", "l-ʿalīmu", "l-ḥakīmu", "(2)"),
  [真主确已为你们规定赎誓制，真主是你们的保佑者。他是全知的，是至睿的。],
)

#quran-verse(
  verse-num: 3,
  "560",
  ("ﱠ", "ﱡ", "ﱢ", "ﱣ", "ﱤ", "ﱥ", "ﱦ", "ﱧ", "ﱨ", "ﱩ", "ﱪ", "ﱫ", "ﱬ", "ﱭ", "ﱮ", "ﱯ", "ﱰ", "ﱱﱲ", "ﱳ", "ﱴ", "ﱵ", "ﱶ", "ﱷ", "ﱸ", "ﱹﱺ", "ﱻ", "ﱼ", "ﱽ", "ﱾ", "ﱿ"),
  ("wa-idh", "asarra", "l-nabiyu", "ilā", "baʿḍi", "azwājihi", "ḥadīthan", "falammā", "nabba-at", "bihi", "wa-aẓharahu", "l-lahu", "ʿalayhi", "ʿarrafa", "baʿḍahu", "wa-aʿraḍa", "ʿan", "baʿḍin", "falammā", "nabba-ahā", "bihi", "qālat", "man", "anba-aka", "hādhā", "qāla", "nabba-aniya", "l-ʿalīmu", "l-khabīru", "(3)"),
  [当时，先知把一句话秘密地告欣他的一个妻子，她即转告了别人，而真主使先知知道他的秘密已被泄漏的时候，他使她认识一部分，而隐匿一部分。当他既以泄漏告诉她的时候，她说：谁报告你这件事的？他说：是全知的、彻知的主告诉我的。],
)

#quran-verse(
  verse-num: 4,
  "560",
  ("ﲀ", "ﲁ", "ﲂ", "ﲃ", "ﲄ", "ﲅ", "ﲆﲇ", "ﲈ", "ﲉ", "ﲊ", "ﲋ", "ﲌ", "ﲍ", "ﲎ", "ﲏ", "ﲐ", "ﲑﲒ", "ﲓ", "ﲔ", "ﲕ", "ﲖ", "ﲗ"),
  ("in", "tatūbā", "ilā", "l-lahi", "faqad", "ṣaghat", "qulūbukumā", "wa-in", "taẓāharā", "ʿalayhi", "fa-inna", "l-laha", "huwa", "mawlāhu", "wajib'rīlu", "waṣāliḥu", "l-mu'minīna", "wal-malāikatu", "baʿda", "dhālika", "ẓahīrun", "(4)"),
  [如果你们俩向真主悔罪，（那末，你们俩的悔罪是应当的），因为你们俩的心确已偏向了。如果你们俩一致对付他，那末，真主碓是他的保佑者，吉卜利里和行善的信士，也是他的保护者。此外，众天使是他的扶助者。],
)

#quran-verse(
  verse-num: 5,
  "560",
  ("ﲘ", "ﲙ", "ﲚ", "ﲛ", "ﲜ", "ﲝ", "ﲞ", "ﲟ", "ﲠ", "ﲡ", "ﲢ", "ﲣ", "ﲤ", "ﲥ", "ﲦ", "ﲧ", "ﲨ", "ﲩ"),
  ("ʿasā", "rabbuhu", "in", "ṭallaqakunna", "an", "yub'dilahu", "azwājan", "khayran", "minkunna", "mus'limātin", "mu'minātin", "qānitātin", "tāibātin", "ʿābidātin", "sāiḥātin", "thayyibātin", "wa-abkāran", "(5)"),
  [如果他休了你们，他的主或许将以胜过你们的妻子补偿他，她们是顺主的，是信道，是服从的，是悔罪的，是拜主的，是持斋的，是再醮的和初婚的。],
)

#quran-verse(
  verse-num: 6,
  "560",
  ("ﲪ", "ﲫ", "ﲬ", "ﲭ", "ﲮ", "ﲯ", "ﲰ", "ﲱ", "ﲲ", "ﲳ", "ﲴ", "ﲵ", "ﲶ", "ﲷ", "ﲸ", "ﲹ", "ﲺ", "ﲻ", "ﲼ", "ﲽ", "ﲾ", "ﲿ", "ﳀ"),
  ("yāayyuhā", "alladhīna", "āmanū", "qū", "anfusakum", "wa-ahlīkum", "nāran", "waqūduhā", "l-nāsu", "wal-ḥijāratu", "ʿalayhā", "malāikatun", "ghilāẓun", "shidādun", "lā", "yaʿṣūna", "l-laha", "mā", "amarahum", "wayafʿalūna", "mā", "yu'marūna", "(6)"),
  [信道的人们啊！你们当为自身和家属而预防那以人和石为燃料的火刑，主持火刑的，是许多残忍而严厉的天使，他们不违抗真主的命令，他们执行自己所奉的训令。],
)

#quran-verse(
  verse-num: 7,
  "560",
  ("ﳁ", "ﳂ", "ﳃ", "ﳄ", "ﳅ", "ﳆﳇ", "ﳈ", "ﳉ", "ﳊ", "ﳋ", "ﳌ", "ﳍ"),
  ("yāayyuhā", "alladhīna", "kafarū", "lā", "taʿtadhirū", "l-yawma", "innamā", "tuj'zawna", "mā", "kuntum", "taʿmalūna", "(7)"),
  [不信道的人们啊！今日，你们不要托辞，你们只受自己行为的报酬。],
)

#quran-verse(
  verse-num: 8,
  "561",
  ("ﱁ", "ﱂ", "ﱃ", "ﱄ", "ﱅ", "ﱆ", "ﱇ", "ﱈ", "ﱉ", "ﱊ", "ﱋ", "ﱌ", "ﱍ", "ﱎ", "ﱏ", "ﱐ", "ﱑ", "ﱒ", "ﱓ", "ﱔ", "ﱕ", "ﱖ", "ﱗ", "ﱘ", "ﱙ", "ﱚ", "ﱛ", "ﱜﱝ", "ﱞ", "ﱟ", "ﱠ", "ﱡ", "ﱢ", "ﱣ", "ﱤ", "ﱥ", "ﱦ", "ﱧ", "ﱨ", "ﱩﱪ", "ﱫ", "ﱬ", "ﱭ", "ﱮ", "ﱯ", "ﱰ"),
  ("yāayyuhā", "alladhīna", "āmanū", "tūbū", "ilā", "l-lahi", "tawbatan", "naṣūḥan", "ʿasā", "rabbukum", "an", "yukaffira", "ʿankum", "sayyiātikum", "wayud'khilakum", "jannātin", "tajrī", "min", "taḥtihā", "l-anhāru", "yawma", "lā", "yukh'zī", "l-lahu", "l-nabiya", "wa-alladhīna", "āmanū", "maʿahu", "nūruhum", "yasʿā", "bayna", "aydīhim", "wabi-aymānihim", "yaqūlūna", "rabbanā", "atmim", "lanā", "nūranā", "wa-igh'fir", "lanā", "innaka", "ʿalā", "kulli", "shayin", "qadīrun", "(8)"),
  [信道的人们啊！你们当向真主诚意悔罪，你们的主或许免除你们的罪恶，并且使你们入下临诸河的乐园。在那日，真主不凌辱先知，和与他一起信道的人们。他们的光明，将在他们的前面和右边奔驰，他们将说：我们的主啊！求你完成给我们的光明，求你赦宥我们。你对於万事是全能的。],
)

#quran-verse(
  verse-num: 9,
  "561",
  ("ﱱ", "ﱲ", "ﱳ", "ﱴ", "ﱵ", "ﱶ", "ﱷﱸ", "ﱹ", "ﱺﱻ", "ﱼ", "ﱽ", "ﱾ"),
  ("yāayyuhā", "l-nabiyu", "jāhidi", "l-kufāra", "wal-munāfiqīna", "wa-ugh'luẓ", "ʿalayhim", "wamawāhum", "jahannamu", "wabi'sa", "l-maṣīru", "(9)"),
  [先知啊！你当与不信道的人们和伪信的人们奋斗，你当以严厉的态度对待他们。他们的归宿是火狱，那归宿真恶劣！],
)

#quran-verse(
  verse-num: 10,
  "561",
  ("ﱿ", "ﲀ", "ﲁ", "ﲂ", "ﲃ", "ﲄ", "ﲅ", "ﲆ", "ﲇﲈ", "ﲉ", "ﲊ", "ﲋ", "ﲌ", "ﲍ", "ﲎ", "ﲏ", "ﲐ", "ﲑ", "ﲒ", "ﲓ", "ﲔ", "ﲕ", "ﲖ", "ﲗ", "ﲘ", "ﲙ", "ﲚ", "ﲛ"),
  ("ḍaraba", "l-lahu", "mathalan", "lilladhīna", "kafarū", "im'ra-ata", "nūḥin", "wa-im'ra-ata", "lūṭin", "kānatā", "taḥta", "ʿabdayni", "min", "ʿibādinā", "ṣāliḥayni", "fakhānatāhumā", "falam", "yugh'niyā", "ʿanhumā", "mina", "l-lahi", "shayan", "waqīla", "ud'khulā", "l-nāra", "maʿa", "l-dākhilīna", "(10)"),
  [真主以努哈的妻子和鲁特的妻子，为不信道的人们的殷鉴，她们俩曾在我的两个行善的仆人之下，而她们俩不忠於自己的丈夫，她们俩的丈夫，未能为她们俩抵御真主的一点刑罚。或者将说：你们俩与众人同入火狱吧！],
)

#quran-verse(
  verse-num: 11,
  "561",
  ("ﲜ", "ﲝ", "ﲞ", "ﲟ", "ﲠ", "ﲡ", "ﲢ", "ﲣ", "ﲤ", "ﲥ", "ﲦ", "ﲧ", "ﲨ", "ﲩ", "ﲪ", "ﲫ", "ﲬ", "ﲭ", "ﲮ", "ﲯ", "ﲰ", "ﲱ", "ﲲ", "ﲳ", "ﲴ"),
  ("waḍaraba", "l-lahu", "mathalan", "lilladhīna", "āmanū", "im'ra-ata", "fir'ʿawna", "idh", "qālat", "rabbi", "ib'ni", "lī", "ʿindaka", "baytan", "fī", "l-janati", "wanajjinī", "min", "fir'ʿawna", "waʿamalihi", "wanajjinī", "mina", "l-qawmi", "l-ẓālimīna", "(11)"),
  [真主以法老的妻子，为信道的人们的模范。当时，她曾说：我的主啊！求你在你那里，为我建筑一所房子在乐园里。求你拯救我脱离法老，和他的罪行。求你拯救我脱离不义的民众。],
)

#quran-verse(

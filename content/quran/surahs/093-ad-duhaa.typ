#quran-verse(
  ("وَٱلضُّحَىٰ", "١"),
  ("wal-ḍuḥā", "(1)"),
  ([誓以上午，]),
)

#quran-verse(
  ("وَٱلَّيْلِ", "إِذَا", "سَجَىٰ", "٢"),
  ("wa-al-layli", "idhā", "sajā", "(2)"),
  ([誓以黑夜，当其寂静的时候，]),
)

#quran-verse(
  ("مَا", "وَدَّعَكَ", "رَبُّكَ", "وَمَا", "قَلَىٰ", "٣"),
  ("mā", "waddaʿaka", "rabbuka", "wamā", "qalā", "(3)"),
  ([你的主没有弃绝你，也没有怨恨你；]),
)

#quran-verse(
  ("وَلَلْـَٔاخِرَةُ", "خَيْرٌۭ", "لَّكَ", "مِنَ", "ٱلْأُولَىٰ", "٤"),
  ("walalākhiratu", "khayrun", "laka", "mina", "l-ūlā", "(4)"),
  ([後世於你，确比今世更好；]),
)

#quran-verse(
  ("وَلَسَوْفَ", "يُعْطِيكَ", "رَبُّكَ", "فَتَرْضَىٰٓ", "٥"),
  ("walasawfa", "yuʿ'ṭīka", "rabbuka", "fatarḍā", "(5)"),
  ([你的主将来必赏赐你，以至你喜悦。]),
)

#quran-verse(
  ("أَلَمْ", "يَجِدْكَ", "يَتِيمًۭا", "فَـَٔاوَىٰ", "٦"),
  ("alam", "yajid'ka", "yatīman", "faāwā", "(6)"),
  ([难道他没有发现你伶仃孤苦，而使你有所归宿？]),
)

#quran-verse(
  ("وَوَجَدَكَ", "ضَآلًّۭا", "فَهَدَىٰ", "٧"),
  ("wawajadaka", "ḍāllan", "fahadā", "(7)"),
  ([他曾发现你徘徊歧途，而把你引入正路；]),
)

#quran-verse(
  ("وَوَجَدَكَ", "عَآئِلًۭا", "فَأَغْنَىٰ", "٨"),
  ("wawajadaka", "ʿāilan", "fa-aghnā", "(8)"),
  ([发现你家境寒苦，而使你衣食丰足。]),
)

#quran-verse(
  ("فَأَمَّا", "ٱلْيَتِيمَ", "فَلَا", "تَقْهَرْ", "٩"),
  ("fa-ammā", "l-yatīma", "falā", "taqhar", "(9)"),
  ([至於孤儿，你不要压迫他；]),
)

#quran-verse(
  ("وَأَمَّا", "ٱلسَّآئِلَ", "فَلَا", "تَنْهَرْ", "١٠"),
  ("wa-ammā", "l-sāila", "falā", "tanhar", "(10)"),
  ([至於乞丐，你不要喝斥他，]),
)

#quran-verse(
  ("وَأَمَّا", "بِنِعْمَةِ", "رَبِّكَ", "فَحَدِّثْ", "١١"),
  ("wa-ammā", "biniʿ'mati", "rabbika", "faḥaddith", "(11)"),
  ([至於你的主所赐你的恩典呢，你应当宣示它。]),
)

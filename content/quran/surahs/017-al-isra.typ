  ("وَكَمْ", "أَهْلَكْنَا", "مِنَ", "ٱلْقُرُونِ", "مِنۢ", "بَعْدِ", "نُوحٍۢ ۗ", "وَكَفَىٰ", "بِرَبِّكَ", "بِذُنُوبِ", "عِبَادِهِۦ", "خَبِيرًۢا", "بَصِيرًۭا", "١٧"),

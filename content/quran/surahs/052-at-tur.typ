#import "../libquran.typ": *

#show: quran-page.with(title: "At-Tur", title-ar: "الطور", title-tl: "At-Tur", locator: "052-at-tur")

#quran-verse(
  ("وَٱلطُّورِ", "١"),
  ("wal-ṭūri", "(1)"),
)

以山岳盟誓，

#quran-verse(
  ("وَكِتَـٰبٍۢ", "مَّسْطُورٍۢ", "٢"),
  ("wakitābin", "masṭūrin", "(2)"),
)

以天经之书

#quran-verse(
  ("فِى", "رَقٍّۢ", "مَّنشُورٍۢ", "٣"),
  ("fī", "raqqin", "manshūrin", "(3)"),
)

写于展开的皮纸者盟誓，

#quran-verse(
  ("وَٱلْبَيْتِ", "ٱلْمَعْمُورِ", "٤"),
  ("wal-bayti", "l-maʿmūri", "(4)"),
)

以众人朝觐的天房盟誓，

#quran-verse(
  ("وَٱلسَّقْفِ", "ٱلْمَرْفُوعِ", "٥"),
  ("wal-saqfi", "l-marfūʿi", "(5)"),
)

以被升起的苍穹盟誓，

#quran-verse(
  ("وَٱلْبَحْرِ", "ٱلْمَسْجُورِ", "٦"),
  ("wal-baḥri", "l-masjūri", "(6)"),
)

以汪洋的大海盟誓，

#quran-verse(
  ("إِنَّ", "عَذَابَ", "رَبِّكَ", "لَوَٰقِعٌۭ", "٧"),
  ("inna", "ʿadhāba", "rabbika", "lawāqiʿun", "(7)"),
)

你的主的刑罚，确是要实现的，

#quran-verse(
  ("مَّا", "لَهُۥ", "مِن", "دَافِعٍۢ", "٨"),
  ("mā", "lahu", "min", "dāfiʿin", "(8)"),
)

是任何人不能抵抗的。

#quran-verse(
  ("يَوْمَ", "تَمُورُ", "ٱلسَّمَآءُ", "مَوْرًۭا", "٩"),
  ("yawma", "tamūru", "l-samāu", "mawran", "(9)"),
)

在天体震动，

#quran-verse(
  ("وَتَسِيرُ", "ٱلْجِبَالُ", "سَيْرًۭا", "١٠"),
  ("watasīru", "l-jibālu", "sayran", "(10)"),
)

山岳逝去之日，

#quran-verse(
  ("فَوَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "١١"),
  ("fawaylun", "yawma-idhin", "lil'mukadhibīna", "(11)"),
)

在那日，伤哉否认真理的人们，

#quran-verse(
  ("ٱلَّذِينَ", "هُمْ", "فِى", "خَوْضٍۢ", "يَلْعَبُونَ", "١٢"),
  ("alladhīna", "hum", "fī", "khawḍin", "yalʿabūna", "(12)"),
)

即以妄言消遣的人们！

#quran-verse(
  ("يَوْمَ", "يُدَعُّونَ", "إِلَىٰ", "نَارِ", "جَهَنَّمَ", "دَعًّا", "١٣"),
  ("yawma", "yudaʿʿūna", "ilā", "nāri", "jahannama", "daʿʿan", "(13)"),
)

他们将被投入火狱。

#quran-verse(
  ("هَـٰذِهِ", "ٱلنَّارُ", "ٱلَّتِى", "كُنتُم", "بِهَا", "تُكَذِّبُونَ", "١٤"),
  ("hādhihi", "l-nāru", "allatī", "kuntum", "bihā", "tukadhibūna", "(14)"),
)

这就是你们生前所否认的火刑。

#quran-verse(
  ("أَفَسِحْرٌ", "هَـٰذَآ", "أَمْ", "أَنتُمْ", "لَا", "تُبْصِرُونَ", "١٥"),
  ("afasiḥ'run", "hādhā", "am", "antum", "lā", "tub'ṣirūna", "(15)"),
)

这是魔术呢？还是你们看不见呢？

#quran-verse(
  ("ٱصْلَوْهَا", "فَٱصْبِرُوٓا۟", "أَوْ", "لَا", "تَصْبِرُوا۟", "سَوَآءٌ", "عَلَيْكُمْ ۖ", "إِنَّمَا", "تُجْزَوْنَ", "مَا", "كُنتُمْ", "تَعْمَلُونَ", "١٦"),
  ("iṣ'lawhā", "fa-iṣ'birū", "aw", "lā", "taṣbirū", "sawāon", "ʿalaykum", "innamā", "tuj'zawna", "mā", "kuntum", "taʿmalūna", "(16)"),
)

你们进火狱去吧！你们忍受其中的刑罚与否，随你们的方便，那对于你们是一样的。你们只受自己行为的报酬。

#quran-verse(
  ("إِنَّ", "ٱلْمُتَّقِينَ", "فِى", "جَنَّـٰتٍۢ", "وَنَعِيمٍۢ", "١٧"),
  ("inna", "l-mutaqīna", "fī", "jannātin", "wanaʿīmin", "(17)"),
)

敬畏的人们，必定在乐园和恩泽中，

#quran-verse(
  ("فَـٰكِهِينَ", "بِمَآ", "ءَاتَىٰهُمْ", "رَبُّهُمْ", "وَوَقَىٰهُمْ", "رَبُّهُمْ", "عَذَابَ", "ٱلْجَحِيمِ", "١٨"),
  ("fākihīna", "bimā", "ātāhum", "rabbuhum", "wawaqāhum", "rabbuhum", "ʿadhāba", "l-jaḥīmi", "(18)"),
)

他们因主的赏赐而快乐，他们的主使他们得免于烈火的刑罚。

#quran-verse(
  ("كُلُوا۟", "وَٱشْرَبُوا۟", "هَنِيٓـًٔۢا", "بِمَا", "كُنتُمْ", "تَعْمَلُونَ", "١٩"),
  ("kulū", "wa-ish'rabū", "hanīan", "bimā", "kuntum", "taʿmalūna", "(19)"),
)

你们因自己的行为而愉快地吃喝吧！

#quran-verse(
  ("مُتَّكِـِٔينَ", "عَلَىٰ", "سُرُرٍۢ", "مَّصْفُوفَةٍۢ ۖ", "وَزَوَّجْنَـٰهُم", "بِحُورٍ", "عِينٍۢ", "٢٠"),
  ("muttakiīna", "ʿalā", "sururin", "maṣfūfatin", "wazawwajnāhum", "biḥūrin", "ʿīnin", "(20)"),
)

他们靠在分列成行的床上，我将以白皙的、美目的女子做他们的伴侣。

#quran-verse(
  ("وَٱلَّذِينَ", "ءَامَنُوا۟", "وَٱتَّبَعَتْهُمْ", "ذُرِّيَّتُهُم", "بِإِيمَـٰنٍ", "أَلْحَقْنَا", "بِهِمْ", "ذُرِّيَّتَهُمْ", "وَمَآ", "أَلَتْنَـٰهُم", "مِّنْ", "عَمَلِهِم", "مِّن", "شَىْءٍۢ ۚ", "كُلُّ", "ٱمْرِئٍۭ", "بِمَا", "كَسَبَ", "رَهِينٌۭ", "٢١"),
  ("wa-alladhīna", "āmanū", "wa-ittabaʿathum", "dhurriyyatuhum", "biīmānin", "alḥaqnā", "bihim", "dhurriyyatahum", "wamā", "alatnāhum", "min", "ʿamalihim", "min", "shayin", "kullu", "im'ri-in", "bimā", "kasaba", "rahīnun", "(21)"),
)

自己信道，子孙也跟著信道者，我将使他们的子孙与他们同级，我不减少他们的善功一丝毫。每人应对自己的行为负责。

#quran-verse(
  ("وَأَمْدَدْنَـٰهُم", "بِفَـٰكِهَةٍۢ", "وَلَحْمٍۢ", "مِّمَّا", "يَشْتَهُونَ", "٢٢"),
  ("wa-amdadnāhum", "bifākihatin", "walaḥmin", "mimmā", "yashtahūna", "(22)"),
)

我将以他们所嗜好的水果和肉食供给他们，

#quran-verse(
  ("يَتَنَـٰزَعُونَ", "فِيهَا", "كَأْسًۭا", "لَّا", "لَغْوٌۭ", "فِيهَا", "وَلَا", "تَأْثِيمٌۭ", "٢٣"),
  ("yatanāzaʿūna", "fīhā", "kasan", "lā", "laghwun", "fīhā", "walā", "tathīmun", "(23)"),
)

他们在乐园中互递（酒）杯，他们不因而出恶言，也不因而犯罪恶。

#quran-verse(
  ("۞ وَيَطُوفُ", "عَلَيْهِمْ", "غِلْمَانٌۭ", "لَّهُمْ", "كَأَنَّهُمْ", "لُؤْلُؤٌۭ", "مَّكْنُونٌۭ", "٢٤"),
  ("wayaṭūfu", "ʿalayhim", "ghil'mānun", "lahum", "ka-annahum", "lu'lu-on", "maknūnun", "(24)"),
)

他们的僮仆轮流著服侍他们，那些僮仆，好象藏在蚌壳里的珍珠一样。

#quran-verse(
  ("وَأَقْبَلَ", "بَعْضُهُمْ", "عَلَىٰ", "بَعْضٍۢ", "يَتَسَآءَلُونَ", "٢٥"),
  ("wa-aqbala", "baʿḍuhum", "ʿalā", "baʿḍin", "yatasāalūna", "(25)"),
)

于是他们大家走向前来互相谈论。

#quran-verse(
  ("قَالُوٓا۟", "إِنَّا", "كُنَّا", "قَبْلُ", "فِىٓ", "أَهْلِنَا", "مُشْفِقِينَ", "٢٦"),
  ("qālū", "innā", "kunnā", "qablu", "fī", "ahlinā", "mush'fiqīna", "(26)"),
)

他们将说：以前我们为自己的家属确是战战兢兢的，

#quran-verse(
  ("فَمَنَّ", "ٱللَّهُ", "عَلَيْنَا", "وَوَقَىٰنَا", "عَذَابَ", "ٱلسَّمُومِ", "٢٧"),
  ("famanna", "l-lahu", "ʿalaynā", "wawaqānā", "ʿadhāba", "l-samūmi", "(27)"),
)

但真主已施恩于我们，并使我们得免于毒风的刑罚。

#quran-verse(
  ("إِنَّا", "كُنَّا", "مِن", "قَبْلُ", "نَدْعُوهُ ۖ", "إِنَّهُۥ", "هُوَ", "ٱلْبَرُّ", "ٱلرَّحِيمُ", "٢٨"),
  ("innā", "kunnā", "min", "qablu", "nadʿūhu", "innahu", "huwa", "l-baru", "l-raḥīmu", "(28)"),
)

以前我们的确常常祈祷他，他确是仁爱的，确是至慈的。

#quran-verse(
  ("فَذَكِّرْ", "فَمَآ", "أَنتَ", "بِنِعْمَتِ", "رَبِّكَ", "بِكَاهِنٍۢ", "وَلَا", "مَجْنُونٍ", "٢٩"),
  ("fadhakkir", "famā", "anta", "biniʿ'mati", "rabbika", "bikāhinin", "walā", "majnūnin", "(29)"),
)

你应当教诲众人，因为借你的主的恩典，你不是一个占卜者，也不是一个疯人。

#quran-verse(
  ("أَمْ", "يَقُولُونَ", "شَاعِرٌۭ", "نَّتَرَبَّصُ", "بِهِۦ", "رَيْبَ", "ٱلْمَنُونِ", "٣٠"),
  ("am", "yaqūlūna", "shāʿirun", "natarabbaṣu", "bihi", "rayba", "l-manūni", "(30)"),
)

不然，他们说：他是一个诗人，我们等待他遭逢厄运。

#quran-verse(
  ("قُلْ", "تَرَبَّصُوا۟", "فَإِنِّى", "مَعَكُم", "مِّنَ", "ٱلْمُتَرَبِّصِينَ", "٣١"),
  ("qul", "tarabbaṣū", "fa-innī", "maʿakum", "mina", "l-mutarabiṣīna", "(31)"),
)

你说：你们等待吧！我确是与你们一同等待的。

#quran-verse(
  ("أَمْ", "تَأْمُرُهُمْ", "أَحْلَـٰمُهُم", "بِهَـٰذَآ ۚ", "أَمْ", "هُمْ", "قَوْمٌۭ", "طَاغُونَ", "٣٢"),
  ("am", "tamuruhum", "aḥlāmuhum", "bihādhā", "am", "hum", "qawmun", "ṭāghūna", "(32)"),
)

难道他们的理智命令他们说这句话吗？不然，他们是放荡的民众。

#quran-verse(
  ("أَمْ", "يَقُولُونَ", "تَقَوَّلَهُۥ ۚ", "بَل", "لَّا", "يُؤْمِنُونَ", "٣٣"),
  ("am", "yaqūlūna", "taqawwalahu", "bal", "lā", "yu'minūna", "(33)"),
)

难道他们说他曾捏造他吗？不然，其实是他们不归信。

#quran-verse(
  ("فَلْيَأْتُوا۟", "بِحَدِيثٍۢ", "مِّثْلِهِۦٓ", "إِن", "كَانُوا۟", "صَـٰدِقِينَ", "٣٤"),
  ("falyatū", "biḥadīthin", "mith'lihi", "in", "kānū", "ṣādiqīna", "(34)"),
)

叫他们作出象这样的文辞来，如果他们是说实话的！

#quran-verse(
  ("أَمْ", "خُلِقُوا۟", "مِنْ", "غَيْرِ", "شَىْءٍ", "أَمْ", "هُمُ", "ٱلْخَـٰلِقُونَ", "٣٥"),
  ("am", "khuliqū", "min", "ghayri", "shayin", "am", "humu", "l-khāliqūna", "(35)"),
)

是他们从无到有被创造出来呢？还是他们自己就是创造者呢？

#quran-verse(
  ("أَمْ", "خَلَقُوا۟", "ٱلسَّمَـٰوَٰتِ", "وَٱلْأَرْضَ ۚ", "بَل", "لَّا", "يُوقِنُونَ", "٣٦"),
  ("am", "khalaqū", "l-samāwāti", "wal-arḍa", "bal", "lā", "yūqinūna", "(36)"),
)

难道他们曾创造天地吗？不然，是他们不确信真主。

#quran-verse(
  ("أَمْ", "عِندَهُمْ", "خَزَآئِنُ", "رَبِّكَ", "أَمْ", "هُمُ", "ٱلْمُصَۣيْطِرُونَ", "٣٧"),
  ("am", "ʿindahum", "khazāinu", "rabbika", "am", "humu", "l-muṣayṭirūna", "(37)"),
)

是你的主的库藏归他们掌管呢？还是他们是那些库藏的监督呢？

#quran-verse(
  ("أَمْ", "لَهُمْ", "سُلَّمٌۭ", "يَسْتَمِعُونَ", "فِيهِ ۖ", "فَلْيَأْتِ", "مُسْتَمِعُهُم", "بِسُلْطَـٰنٍۢ", "مُّبِينٍ", "٣٨"),
  ("am", "lahum", "sullamun", "yastamiʿūna", "fīhi", "falyati", "mus'tamiʿuhum", "bisul'ṭānin", "mubīnin", "(38)"),
)

难道他们有一架天梯，可以登上去倾听吗？叫他们中的倾听者拿一个明证来吧！

#quran-verse(
  ("أَمْ", "لَهُ", "ٱلْبَنَـٰتُ", "وَلَكُمُ", "ٱلْبَنُونَ", "٣٩"),
  ("am", "lahu", "l-banātu", "walakumu", "l-banūna", "(39)"),
)

难道真主有女儿，你们有儿子吗？

#quran-verse(
  ("أَمْ", "تَسْـَٔلُهُمْ", "أَجْرًۭا", "فَهُم", "مِّن", "مَّغْرَمٍۢ", "مُّثْقَلُونَ", "٤٠"),
  ("am", "tasaluhum", "ajran", "fahum", "min", "maghramin", "muth'qalūna", "(40)"),
)

难道你向他们索取报酬，故他们为纳税而担负太重？

#quran-verse(
  ("أَمْ", "عِندَهُمُ", "ٱلْغَيْبُ", "فَهُمْ", "يَكْتُبُونَ", "٤١"),
  ("am", "ʿindahumu", "l-ghaybu", "fahum", "yaktubūna", "(41)"),
)

难道他们能知幽玄，故能将它记录下来？

#quran-verse(
  ("أَمْ", "يُرِيدُونَ", "كَيْدًۭا ۖ", "فَٱلَّذِينَ", "كَفَرُوا۟", "هُمُ", "ٱلْمَكِيدُونَ", "٤٢"),
  ("am", "yurīdūna", "kaydan", "fa-alladhīna", "kafarū", "humu", "l-makīdūna", "(42)"),
)

难道他们欲用计谋吗？不信道者，将自中其计。

#quran-verse(
  ("أَمْ", "لَهُمْ", "إِلَـٰهٌ", "غَيْرُ", "ٱللَّهِ ۚ", "سُبْحَـٰنَ", "ٱللَّهِ", "عَمَّا", "يُشْرِكُونَ", "٤٣"),
  ("am", "lahum", "ilāhun", "ghayru", "l-lahi", "sub'ḥāna", "l-lahi", "ʿammā", "yush'rikūna", "(43)"),
)

难道除真主外，他们还有别的神灵吗？真主是超乎他们所用以配他的。

#quran-verse(
  ("وَإِن", "يَرَوْا۟", "كِسْفًۭا", "مِّنَ", "ٱلسَّمَآءِ", "سَاقِطًۭا", "يَقُولُوا۟", "سَحَابٌۭ", "مَّرْكُومٌۭ", "٤٤"),
  ("wa-in", "yaraw", "kis'fan", "mina", "l-samāi", "sāqiṭan", "yaqūlū", "saḥābun", "markūmun", "(44)"),
)

如果他们看见天掉下来一块，他们将说：这是成堆的云彩。

#quran-verse(
  ("فَذَرْهُمْ", "حَتَّىٰ", "يُلَـٰقُوا۟", "يَوْمَهُمُ", "ٱلَّذِى", "فِيهِ", "يُصْعَقُونَ", "٤٥"),
  ("fadharhum", "ḥattā", "yulāqū", "yawmahumu", "alladhī", "fīhi", "yuṣ'ʿaqūna", "(45)"),
)

你任随他们吧！直到他们遭遇自己被震死的日子。

#quran-verse(
  ("يَوْمَ", "لَا", "يُغْنِى", "عَنْهُمْ", "كَيْدُهُمْ", "شَيْـًۭٔا", "وَلَا", "هُمْ", "يُنصَرُونَ", "٤٦"),
  ("yawma", "lā", "yugh'nī", "ʿanhum", "kayduhum", "shayan", "walā", "hum", "yunṣarūna", "(46)"),
)

在那日，他们的计谋，对于他们毫无裨益，他们也不受援助。

#quran-verse(

#import "../libquran.typ": quran-verse

= Al-Infitar (الإنفطار)

#quran-verse(
  ("إِذَا", "ٱلسَّمَآءُ", "ٱنفَطَرَتْ", "١"),
  ("idhā", "l-samāu", "infaṭarat", "(1)"),
  ("当", "穹苍", "它破裂", ""),
)

当穷苍破裂的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْكَوَاكِبُ", "ٱنتَثَرَتْ", "٢"),
  ("wa-idhā", "l-kawākibu", "intatharat", "(2)"),
  ("当|和", "众星", "它飘坠", ""),
)

当众星飘堕的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْبِحَارُ", "فُجِّرَتْ", "٣"),
  ("wa-idhā", "l-biḥāru", "fujjirat", "(3)"),
  ("当|和", "众海洋", "它被混合", ""),
)

当海洋混合的时候，

#quran-verse(
  ("وَإِذَا", "ٱلْقُبُورُ", "بُعْثِرَتْ", "٤"),
  ("wa-idhā", "l-qubūru", "buʿ'thirat", "(4)"),
  ("当|和", "众坟墓", "它被揭开", ""),
)

当坟墓被揭开的时候，

#quran-verse(
  ("عَلِمَتْ", "نَفْسٌۭ", "مَّا", "قَدَّمَتْ", "وَأَخَّرَتْ", "٥"),
  ("ʿalimat", "nafsun", "mā", "qaddamat", "wa-akharat", "(5)"),
  ("她知道", "(每一个)灵魂", "什么", "她前面", "她后面|和", ""),
)

每个人都知道自己前前后后所做的一切事情。

#quran-verse(
  ("يَـٰٓأَيُّهَا", "ٱلْإِنسَـٰنُ", "مَا", "غَرَّكَ", "بِرَبِّكَ", "ٱلْكَرِيمِ", "٦"),
  ("yāayyuhā", "l-insānu", "mā", "gharraka", "birabbika", "l-karīmi", "(6)"),
  ("啊", "世人", "什么?", "你|他背离", "你的|养主|以", "最仁慈的", ""),
)

人啊！什么东西引诱你背离了你的仁慈的主呢？

#quran-verse(
  ("ٱلَّذِى", "خَلَقَكَ", "فَسَوَّىٰكَ", "فَعَدَلَكَ", "٧"),
  ("alladhī", "khalaqaka", "fasawwāka", "faʿadalaka", "(7)"),
  ("那个", "你|我曾创造", "你|他使健全|然后", "你|他使匀称|然后", ""),
)

他曾创造了你，然后，使你健全，然后，使你均称。

#quran-verse(
  ("فِىٓ", "أَىِّ", "صُورَةٍۢ", "مَّا", "شَآءَ", "رَكَّبَكَ", "٨"),
  ("fī", "ayyi", "ṣūratin", "mā", "shāa", "rakkabaka", "(8)"),
  ("在", "什么", "形式", "那个", "他意欲", "你|他构造", ""),
)

他意欲什么型式，就依什么型式而构造你。

#quran-verse(
  ("كَلَّا", "بَلْ", "تُكَذِّبُونَ", "بِٱلدِّينِ", "٩"),
  ("kallā", "bal", "tukadhibūna", "bil-dīni", "(9)"),
  ("绝不然", "但", "你们否认", "报应|在", ""),
)

绝不然，但你们否认报应！

#quran-verse(
  ("وَإِنَّ", "عَلَيْكُمْ", "لَحَـٰفِظِينَ", "١٠"),
  ("wa-inna", "ʿalaykum", "laḥāfiẓīna", "(10)"),
  ("确实|和", "你们|在", "众监视者|必定", ""),
)

你们的上面，确有许多监视者，

#quran-verse(
  ("كِرَامًۭا", "كَـٰتِبِينَ", "١١"),
  ("kirāman", "kātibīna", "(11)"),
  ("尊贵的", "纪录的", ""),
)

他们是尊贵的，是记录的，

#quran-verse(
  ("يَعْلَمُونَ", "مَا", "تَفْعَلُونَ", "١٢"),
  ("yaʿlamūna", "mā", "tafʿalūna", "(12)"),
  ("他们知道", "什么", "你们做", ""),
)

他们知道你们的一切行为。

#quran-verse(
  ("إِنَّ", "ٱلْأَبْرَارَ", "لَفِى", "نَعِيمٍۢ", "١٣"),
  ("inna", "l-abrāra", "lafī", "naʿīmin", "(13)"),
  ("确实", "善人们", "在|必定", "恩泽", ""),
)

善人们，必在恩泽中；

#quran-verse(
  ("وَإِنَّ", "ٱلْفُجَّارَ", "لَفِى", "جَحِيمٍۢ", "١٤"),
  ("wa-inna", "l-fujāra", "lafī", "jaḥīmin", "(14)"),
  ("确实|和", "众人们", "在|必定", "烈火", ""),
)

恶人们，必在烈火中。

#quran-verse(
  ("يَصْلَوْنَهَا", "يَوْمَ", "ٱلدِّينِ", "١٥"),
  ("yaṣlawnahā", "yawma", "l-dīni", "(15)"),
  ("她(烈火)|他们将焚烧", "日子", "报应的", ""),
)

他们将在报应日堕入烈火，

#quran-verse(
  ("وَمَا", "هُمْ", "عَنْهَا", "بِغَآئِبِينَ", "١٦"),
  ("wamā", "hum", "ʿanhā", "bighāibīna", "(16)"),
  ("不|和", "他们", "她(烈火)|从", "离开|在", ""),
)

他们绝不得离开它。

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "يَوْمُ", "ٱلدِّينِ", "١٧"),
  ("wamā", "adrāka", "mā", "yawmu", "l-dīni", "(17)"),
  ("什么?|和", "你|它使知道", "什么?", "日子", "报应的", ""),
)

你怎能知道报应日是什么？

#quran-verse(
  ("ثُمَّ", "مَآ", "أَدْرَىٰكَ", "مَا", "يَوْمُ", "ٱلدِّينِ", "١٨"),
  ("thumma", "mā", "adrāka", "mā", "yawmu", "l-dīni", "(18)"),
  ("然后", "什么?", "你|它使知道", "什么?", "日子", "报应的", ""),
)

你怎能知道报应日是什么？

#quran-verse(
  ("يَوْمَ", "لَا", "تَمْلِكُ", "نَفْسٌۭ", "لِّنَفْسٍۢ", "شَيْـًۭٔا ۖ", "وَٱلْأَمْرُ", "يَوْمَئِذٍۢ", "لِّلَّهِ", "١٩"),
  ("yawma", "lā", "tamliku", "nafsun", "linafsin", "shayan", "wal-amru", "yawma-idhin", "lillahi", "(19)"),
  ("日子", "不", "她将有力量", "一个灵魂", "任何灵魂|对", "任何事", "命令|和", "那日的", "真主|归", ""),
)

在那日，任何人对任何人不能有什么裨益；命令全归真主。

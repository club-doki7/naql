#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Inshiqaq", title-ar: "الإنشقاق", title-tl: "Al-Inshiqaq", locator: "084-al-inshiqaq")

#quran-verse(
  ("إِذَا", "ٱلسَّمَآءُ", "ٱنشَقَّتْ", "١"),
  ("idhā", "l-samāu", "inshaqqat", "(1)"),
  ("当", "天", "它破绽", ""),
)

当天绽裂，

#quran-verse(
  ("وَأَذِنَتْ", "لِرَبِّهَا", "وَحُقَّتْ", "٢"),
  ("wa-adhinat", "lirabbihā", "waḥuqqat", "(2)"),
  ("它听|和", "它的|养主|对", "听从它宜于|和", ""),
)

听从主命，而且宜於听从的时候；

#quran-verse(
  ("وَإِذَا", "ٱلْأَرْضُ", "مُدَّتْ", "٣"),
  ("wa-idhā", "l-arḍu", "muddat", "(3)"),
  ("当|和", "大地", "它被展开", ""),
)

当地展开，

#quran-verse(
  ("وَأَلْقَتْ", "مَا", "فِيهَا", "وَتَخَلَّتْ", "٤"),
  ("wa-alqat", "mā", "fīhā", "watakhallat", "(4)"),
  ("它抛|和", "那个", "它|在", "空虚它变为|和", ""),
)

并抛其所怀，而且变为空虚，

#quran-verse(
  ("وَأَذِنَتْ", "لِرَبِّهَا", "وَحُقَّتْ", "٥"),
  ("wa-adhinat", "lirabbihā", "waḥuqqat", "(5)"),
  ("它听|和", "它的|养主|对", "它宜于听从|和", ""),
)

听从主命，而且宜於听从的时候；

#quran-verse(
  ("يَـٰٓأَيُّهَا", "ٱلْإِنسَـٰنُ", "إِنَّكَ", "كَادِحٌ", "إِلَىٰ", "رَبِّكَ", "كَدْحًۭا", "فَمُلَـٰقِيهِ", "٦"),
  ("yāayyuhā", "l-insānu", "innaka", "kādiḥun", "ilā", "rabbika", "kadḥan", "famulāqīhi", "(6)"),
  ("啊", "世人", "你|确实", "勉力", "至", "你的|养主", "非常努力", "他(真主)的|遇见|然后", ""),
)

人啊！你必定勉力工作，直到会见你的主，你将看到自己的劳绩。

#quran-verse(
  ("فَأَمَّا", "مَنْ", "أُوتِىَ", "كِتَـٰبَهُۥ", "بِيَمِينِهِۦ", "٧"),
  ("fa-ammā", "man", "ūtiya", "kitābahu", "biyamīnihi", "(7)"),
  ("至于|然后", "谁", "他被给", "他的|功过簿", "他的|右手|以", ""),
)

至於用右手接过功过簿者，

#quran-verse(
  ("فَسَوْفَ", "يُحَاسَبُ", "حِسَابًۭا", "يَسِيرًۭا", "٨"),
  ("fasawfa", "yuḥāsabu", "ḥisāban", "yasīran", "(8)"),
  ("将|然后", "他被稽核", "稽核", "简易的", ""),
)

将受简易的稽核，

#quran-verse(
  ("وَيَنقَلِبُ", "إِلَىٰٓ", "أَهْلِهِۦ", "مَسْرُورًۭا", "٩"),
  ("wayanqalibu", "ilā", "ahlihi", "masrūran", "(9)"),
  ("他返回|和", "到", "他的|家属", "高兴地", ""),
)

而兴高采烈地返於他的家属；

#quran-verse(
  ("وَأَمَّا", "مَنْ", "أُوتِىَ", "كِتَـٰبَهُۥ", "وَرَآءَ", "ظَهْرِهِۦ", "١٠"),
  ("wa-ammā", "man", "ūtiya", "kitābahu", "warāa", "ẓahrihi", "(10)"),
  ("至于|和", "谁", "他被给", "他的|功过簿", "后面", "他的|背的", ""),
)

至於从背後接受功过簿者，

#quran-verse(
  ("فَسَوْفَ", "يَدْعُوا۟", "ثُبُورًۭا", "١١"),
  ("fasawfa", "yadʿū", "thubūran", "(11)"),
  ("将|然后", "他祈求(呼喊)", "毁灭(遭祸)", ""),
)

将叫苦连天，

#quran-verse(
  ("وَيَصْلَىٰ", "سَعِيرًا", "١٢"),
  ("wayaṣlā", "saʿīran", "(12)"),
  ("他焚烧|和", "烈火", ""),
)

入於烈火之中，

#quran-verse(
  ("إِنَّهُۥ", "كَانَ", "فِىٓ", "أَهْلِهِۦ", "مَسْرُورًا", "١٣"),
  ("innahu", "kāna", "fī", "ahlihi", "masrūran", "(13)"),
  ("他|确实", "他是", "在", "他的|家属", "快乐的", ""),
)

从前他在家属间原是快乐的，

#quran-verse(
  ("إِنَّهُۥ", "ظَنَّ", "أَن", "لَّن", "يَحُورَ", "١٤"),
  ("innahu", "ẓanna", "an", "lan", "yaḥūra", "(14)"),
  ("他|确实", "他猜想", "那个", "绝不", "他将返回", ""),
)

他已猜想他绝不会归於主。

#quran-verse(
  ("بَلَىٰٓ", "إِنَّ", "رَبَّهُۥ", "كَانَ", "بِهِۦ", "بَصِيرًۭا", "١٥"),
  ("balā", "inna", "rabbahu", "kāna", "bihi", "baṣīran", "(15)"),
  ("不然", "确实", "他的|养主", "他是", "他|在", "监察", ""),
)

不然，他的主，原是鉴察他的。

#quran-verse(
  ("فَلَآ", "أُقْسِمُ", "بِٱلشَّفَقِ", "١٦"),
  ("falā", "uq'simu", "bil-shafaqi", "(16)"),
  ("因此", "我盟誓", "晚霞|以", ""),
)

我以晚霞盟誓，

#quran-verse(
  ("وَٱلَّيْلِ", "وَمَا", "وَسَقَ", "١٧"),
  ("wa-al-layli", "wamā", "wasaqa", "(17)"),
  ("黑夜|和", "什么|和", "它包罗", ""),
)

以黑夜及其包罗万象的盟誓，

#quran-verse(
  ("وَٱلْقَمَرِ", "إِذَا", "ٱتَّسَقَ", "١٨"),
  ("wal-qamari", "idhā", "ittasaqa", "(18)"),
  ("月亮|和", "当", "它圆满", ""),
)

以圆满时的月亮盟誓，

#quran-verse(
  ("لَتَرْكَبُنَّ", "طَبَقًا", "عَن", "طَبَقٍۢ", "١٩"),
  ("latarkabunna", "ṭabaqan", "ʿan", "ṭabaqin", "(19)"),
  ("你们经历|必定", "阶段", "从", "阶段", ""),
)

你们必定遭遇重重的灾难。

#quran-verse(
  ("فَمَا", "لَهُمْ", "لَا", "يُؤْمِنُونَ", "٢٠"),
  ("famā", "lahum", "lā", "yu'minūna", "(20)"),
  ("什么?|因此", "他们|对", "不", "他们信道", ""),
)

他们怎能不信道呢？

#quran-verse(
  ("وَإِذَا", "قُرِئَ", "عَلَيْهِمُ", "ٱلْقُرْءَانُ", "لَا", "يَسْجُدُونَ ۩", "٢١"),
  ("wa-idhā", "quri-a", "ʿalayhimu", "l-qur'ānu", "lā", "yasjudūna", "(21)"),
  ("当|和", "它被宣读", "他们|对", "古兰经", "不", "他们叩头", ""),
)

当别人对他们宣读《古兰经》的时候，他们怎么不叩头呢？※（此处叩头！）

#quran-verse(
  ("بَلِ", "ٱلَّذِينَ", "كَفَرُوا۟", "يُكَذِّبُونَ", "٢٢"),
  ("bali", "alladhīna", "kafarū", "yukadhibūna", "(22)"),
  ("不然", "那些人", "他们不信", "他们否认", ""),
)

不然，不信道的人们，是否认真理的，

#quran-verse(
  ("وَٱللَّهُ", "أَعْلَمُ", "بِمَا", "يُوعُونَ", "٢٣"),
  ("wal-lahu", "aʿlamu", "bimā", "yūʿūna", "(23)"),
  ("真主|和", "最知道", "什么|在", "他们隐藏", ""),
)

真主全知道他们心中隐藏的东西，

#quran-verse(
  ("فَبَشِّرْهُم", "بِعَذَابٍ", "أَلِيمٍ", "٢٤"),
  ("fabashir'hum", "biʿadhābin", "alīmin", "(24)"),
  ("他们|你应宣告|因此", "刑罚|以", "痛苦的", ""),
)

故你当以一种痛苦的刑罚向他们报喜，

#quran-verse(
  ("إِلَّا", "ٱلَّذِينَ", "ءَامَنُوا۟", "وَعَمِلُوا۟", "ٱلصَّـٰلِحَـٰتِ", "لَهُمْ", "أَجْرٌ", "غَيْرُ", "مَمْنُونٍۭ", "٢٥"),
  ("illā", "alladhīna", "āmanū", "waʿamilū", "l-ṣāliḥāti", "lahum", "ajrun", "ghayru", "mamnūnin", "(25)"),
  ("除了", "那些人", "他们信道", "他们做|和", "众善功", "他们|对", "报酬", "不", "终止的", ""),
)

惟信道而且行善的人们，将受不断的报酬。

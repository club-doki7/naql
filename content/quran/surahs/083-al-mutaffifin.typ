#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Mutaffifin", title-ar: "المطففين", title-tl: "Al-Mutaffifin", locator: "083-al-mutaffifin")

#quran-verse(
  ("وَيْلٌۭ", "لِّلْمُطَفِّفِينَ", "١"),
  ("waylun", "lil'muṭaffifīna", "(1)"),
  ([伤哉！称量不公的人们。]),
)

#quran-verse(
  ("ٱلَّذِينَ", "إِذَا", "ٱكْتَالُوا۟", "عَلَى", "ٱلنَّاسِ", "يَسْتَوْفُونَ", "٢"),
  ("alladhīna", "idhā", "ik'tālū", "ʿalā", "l-nāsi", "yastawfūna", "(2)"),
  ([当他们从别人称量进来的时候，他们称量得很充足；]),
)

#quran-verse(
  ("وَإِذَا", "كَالُوهُمْ", "أَو", "وَّزَنُوهُمْ", "يُخْسِرُونَ", "٣"),
  ("wa-idhā", "kālūhum", "aw", "wazanūhum", "yukh'sirūna", "(3)"),
  ([当他们量给别人或称给别人的时候，他们不称足不量足。]),
)

#quran-verse(
  ("أَلَا", "يَظُنُّ", "أُو۟لَـٰٓئِكَ", "أَنَّهُم", "مَّبْعُوثُونَ", "٤"),
  ("alā", "yaẓunnu", "ulāika", "annahum", "mabʿūthūna", "(4)"),
  ([难道他们不信自己将复活，]),
)

#quran-verse(
  ("لِيَوْمٍ", "عَظِيمٍۢ", "٥"),
  ("liyawmin", "ʿaẓīmin", "(5)"),
  ([在一个重大的日子吗？]),
)

#quran-verse(
  ("يَوْمَ", "يَقُومُ", "ٱلنَّاسُ", "لِرَبِّ", "ٱلْعَـٰلَمِينَ", "٦"),
  ("yawma", "yaqūmu", "l-nāsu", "lirabbi", "l-ʿālamīna", "(6)"),
  ([在那日，人们将为全世界的主而起立。]),
)

#quran-verse(
  ("كَلَّآ", "إِنَّ", "كِتَـٰبَ", "ٱلْفُجَّارِ", "لَفِى", "سِجِّينٍۢ", "٧"),
  ("kallā", "inna", "kitāba", "l-fujāri", "lafī", "sijjīnin", "(7)"),
  ([绝不然，恶人们的纪录，将在一本恶行簿中。]),
)

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "سِجِّينٌۭ", "٨"),
  ("wamā", "adrāka", "mā", "sijjīnun", "(8)"),
  ([你怎能知道恶行簿是什麽？]),
)

#quran-verse(
  ("كِتَـٰبٌۭ", "مَّرْقُومٌۭ", "٩"),
  ("kitābun", "marqūmun", "(9)"),
  ([是一本封存的簿子。]),
)

#quran-verse(
  ("وَيْلٌۭ", "يَوْمَئِذٍۢ", "لِّلْمُكَذِّبِينَ", "١٠"),
  ("waylun", "yawma-idhin", "lil'mukadhibīna", "(10)"),
  ([在那日，伤哉否认的人们　　]),
)

#quran-verse(
  ("ٱلَّذِينَ", "يُكَذِّبُونَ", "بِيَوْمِ", "ٱلدِّينِ", "١١"),
  ("alladhīna", "yukadhibūna", "biyawmi", "l-dīni", "(11)"),
  ([否认报应日的人们！]),
)

#quran-verse(
  ("وَمَا", "يُكَذِّبُ", "بِهِۦٓ", "إِلَّا", "كُلُّ", "مُعْتَدٍ", "أَثِيمٍ", "١٢"),
  ("wamā", "yukadhibu", "bihi", "illā", "kullu", "muʿ'tadin", "athīmin", "(12)"),
  ([只有每个过分的犯罪的人，否认它。]),
)

#quran-verse(
  ("إِذَا", "تُتْلَىٰ", "عَلَيْهِ", "ءَايَـٰتُنَا", "قَالَ", "أَسَـٰطِيرُ", "ٱلْأَوَّلِينَ", "١٣"),
  ("idhā", "tut'lā", "ʿalayhi", "āyātunā", "qāla", "asāṭīru", "l-awalīna", "(13)"),
  ([当别人对他宣读我的迹象的时候，他说：这是古人的故事。]),
)

#quran-verse(
  ("كَلَّا ۖ", "بَلْ ۜ", "رَانَ", "عَلَىٰ", "قُلُوبِهِم", "مَّا", "كَانُوا۟", "يَكْسِبُونَ", "١٤"),
  ("kallā", "bal", "rāna", "ʿalā", "qulūbihim", "mā", "kānū", "yaksibūna", "(14)"),
  ([绝不然，但他们所犯的罪恶，已像锈样蒙敝他们的心。]),
)

#quran-verse(
  ("كَلَّآ", "إِنَّهُمْ", "عَن", "رَّبِّهِمْ", "يَوْمَئِذٍۢ", "لَّمَحْجُوبُونَ", "١٥"),
  ("kallā", "innahum", "ʿan", "rabbihim", "yawma-idhin", "lamaḥjūbūna", "(15)"),
  ([真的，在那日，他们必受阻拦，不得觐见他们的主。]),
)

#quran-verse(
  ("ثُمَّ", "إِنَّهُمْ", "لَصَالُوا۟", "ٱلْجَحِيمِ", "١٦"),
  ("thumma", "innahum", "laṣālū", "l-jaḥīmi", "(16)"),
  ([然後，他们必堕入烈火之中。]),
)

#quran-verse(
  ("ثُمَّ", "يُقَالُ", "هَـٰذَا", "ٱلَّذِى", "كُنتُم", "بِهِۦ", "تُكَذِّبُونَ", "١٧"),
  ("thumma", "yuqālu", "hādhā", "alladhī", "kuntum", "bihi", "tukadhibūna", "(17)"),
  ([然後，或者将对他们说：这就是你们所否认的。]),
)

#quran-verse(
  ("كَلَّآ", "إِنَّ", "كِتَـٰبَ", "ٱلْأَبْرَارِ", "لَفِى", "عِلِّيِّينَ", "١٨"),
  ("kallā", "inna", "kitāba", "l-abrāri", "lafī", "ʿilliyyīna", "(18)"),
  ([真的，善人们的记录，确在善行簿中。]),
)

#quran-verse(
  ("وَمَآ", "أَدْرَىٰكَ", "مَا", "عِلِّيُّونَ", "١٩"),
  ("wamā", "adrāka", "mā", "ʿilliyyūna", "(19)"),
  ([你怎能知道善行簿是什麽？]),
)

#quran-verse(
  ("كِتَـٰبٌۭ", "مَّرْقُومٌۭ", "٢٠"),
  ("kitābun", "marqūmun", "(20)"),
  ([是一本封存的簿子，]),
)

#quran-verse(
  ("يَشْهَدُهُ", "ٱلْمُقَرَّبُونَ", "٢١"),
  ("yashhaduhu", "l-muqarabūna", "(21)"),
  ([真主所亲近的天神们将作证它。]),
)

#quran-verse(
  ("إِنَّ", "ٱلْأَبْرَارَ", "لَفِى", "نَعِيمٍ", "٢٢"),
  ("inna", "l-abrāra", "lafī", "naʿīmin", "(22)"),
  ([善人们必在恩泽中，]),
)

#quran-verse(
  ("عَلَى", "ٱلْأَرَآئِكِ", "يَنظُرُونَ", "٢٣"),
  ("ʿalā", "l-arāiki", "yanẓurūna", "(23)"),
  ([靠在床上注视著，]),
)

#quran-verse(
  ("تَعْرِفُ", "فِى", "وُجُوهِهِمْ", "نَضْرَةَ", "ٱلنَّعِيمِ", "٢٤"),
  ("taʿrifu", "fī", "wujūhihim", "naḍrata", "l-naʿīmi", "(24)"),
  ([你能在他们的面目上认识恩泽的光华。]),
)

#quran-verse(
  ("يُسْقَوْنَ", "مِن", "رَّحِيقٍۢ", "مَّخْتُومٍ", "٢٥"),
  ("yus'qawna", "min", "raḥīqin", "makhtūmin", "(25)"),
  ([他们将饮封存的天醇，]),
)

#quran-verse(
  ("خِتَـٰمُهُۥ", "مِسْكٌۭ ۚ", "وَفِى", "ذَٰلِكَ", "فَلْيَتَنَافَسِ", "ٱلْمُتَنَـٰفِسُونَ", "٢٦"),
  ("khitāmuhu", "mis'kun", "wafī", "dhālika", "falyatanāfasi", "l-mutanāfisūna", "(26)"),
  ([封瓶口的，是麝香。教贪爱这种幸福的人们，争先为善吧！]),
)

#quran-verse(
  ("وَمِزَاجُهُۥ", "مِن", "تَسْنِيمٍ", "٢٧"),
  ("wamizājuhu", "min", "tasnīmin", "(27)"),
  ([天醇的混合物，是由太斯尼姆来的，]),
)

#quran-verse(
  ("عَيْنًۭا", "يَشْرَبُ", "بِهَا", "ٱلْمُقَرَّبُونَ", "٢٨"),
  ("ʿaynan", "yashrabu", "bihā", "l-muqarabūna", "(28)"),
  ([那是一洞泉水，真主所亲近的人将饮它。]),
)

#quran-verse(
  ("إِنَّ", "ٱلَّذِينَ", "أَجْرَمُوا۟", "كَانُوا۟", "مِنَ", "ٱلَّذِينَ", "ءَامَنُوا۟", "يَضْحَكُونَ", "٢٩"),
  ("inna", "alladhīna", "ajramū", "kānū", "mina", "alladhīna", "āmanū", "yaḍḥakūna", "(29)"),
  ([犯罪的人们常常嘲笑信士们，]),
)

#quran-verse(
  ("وَإِذَا", "مَرُّوا۟", "بِهِمْ", "يَتَغَامَزُونَ", "٣٠"),
  ("wa-idhā", "marrū", "bihim", "yataghāmazūna", "(30)"),
  ([当信士们从他们的面前走过的时候，他们以目互相示意；]),
)

#quran-verse(
  ("وَإِذَا", "ٱنقَلَبُوٓا۟", "إِلَىٰٓ", "أَهْلِهِمُ", "ٱنقَلَبُوا۟", "فَكِهِينَ", "٣١"),
  ("wa-idhā", "inqalabū", "ilā", "ahlihimu", "inqalabū", "fakihīna", "(31)"),
  ([当他们回家的时候，洋洋得意地回去；]),
)

#quran-verse(
  ("وَإِذَا", "رَأَوْهُمْ", "قَالُوٓا۟", "إِنَّ", "هَـٰٓؤُلَآءِ", "لَضَآلُّونَ", "٣٢"),
  ("wa-idhā", "ra-awhum", "qālū", "inna", "hāulāi", "laḍāllūna", "(32)"),
  ([当他们遇见信士们的时候，他们说：这等人确是迷误的。]),
)

#quran-verse(
  ("وَمَآ", "أُرْسِلُوا۟", "عَلَيْهِمْ", "حَـٰفِظِينَ", "٣٣"),
  ("wamā", "ur'silū", "ʿalayhim", "ḥāfiẓīna", "(33)"),
  ([他们没有被派去监视信士们。]),
)

#quran-verse(
  ("فَٱلْيَوْمَ", "ٱلَّذِينَ", "ءَامَنُوا۟", "مِنَ", "ٱلْكُفَّارِ", "يَضْحَكُونَ", "٣٤"),
  ("fal-yawma", "alladhīna", "āmanū", "mina", "l-kufāri", "yaḍḥakūna", "(34)"),
  ([故今日信士们，嘲笑不信道的人们，]),
)

#quran-verse(
  ("عَلَى", "ٱلْأَرَآئِكِ", "يَنظُرُونَ", "٣٥"),
  ("ʿalā", "l-arāiki", "yanẓurūna", "(35)"),
  ([他们靠在床上注视著，]),
)

#quran-verse(
  ("هَلْ", "ثُوِّبَ", "ٱلْكُفَّارُ", "مَا", "كَانُوا۟", "يَفْعَلُونَ", "٣٦"),
  ("hal", "thuwwiba", "l-kufāru", "mā", "kānū", "yafʿalūna", "(36)"),
  ([不信道的人们已获得他们的行为的报酬了吗？]),
)

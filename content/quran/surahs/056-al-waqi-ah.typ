#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Waqi'ah", title-ar: "الواقعة", title-tl: "Al-Waqi'ah", locator: "056-al-waqi-ah")

#quran-verse(
  ("إِذَا", "وَقَعَتِ", "ٱلْوَاقِعَةُ", "١"),
  ("idhā", "waqaʿati", "l-wāqiʿatu", "(1)"),
)

当那件大事发生的时候，

#quran-verse(
  ("لَيْسَ", "لِوَقْعَتِهَا", "كَاذِبَةٌ", "٢"),
  ("laysa", "liwaqʿatihā", "kādhibatun", "(2)"),
)

没有任何人否认其发生。

#quran-verse(
  ("خَافِضَةٌۭ", "رَّافِعَةٌ", "٣"),
  ("khāfiḍatun", "rāfiʿatun", "(3)"),
)

那件大事将是能使人降级，能使人升级的；

#quran-verse(
  ("إِذَا", "رُجَّتِ", "ٱلْأَرْضُ", "رَجًّۭا", "٤"),
  ("idhā", "rujjati", "l-arḍu", "rajjan", "(4)"),
)

当大地震荡，

#quran-verse(
  ("وَبُسَّتِ", "ٱلْجِبَالُ", "بَسًّۭا", "٥"),
  ("wabussati", "l-jibālu", "bassan", "(5)"),
)

山峦粉碎，

#quran-verse(
  ("فَكَانَتْ", "هَبَآءًۭ", "مُّنۢبَثًّۭا", "٦"),
  ("fakānat", "habāan", "munbathan", "(6)"),
)

化为散漫的尘埃，

#quran-verse(
  ("وَكُنتُمْ", "أَزْوَٰجًۭا", "ثَلَـٰثَةًۭ", "٧"),
  ("wakuntum", "azwājan", "thalāthatan", "(7)"),
)

而你们分为三等的时候。

#quran-verse(
  ("فَأَصْحَـٰبُ", "ٱلْمَيْمَنَةِ", "مَآ", "أَصْحَـٰبُ", "ٱلْمَيْمَنَةِ", "٨"),
  ("fa-aṣḥābu", "l-maymanati", "mā", "aṣḥābu", "l-maymanati", "(8)"),
)

幸福者，幸福者是何等的人？

#quran-verse(
  ("وَأَصْحَـٰبُ", "ٱلْمَشْـَٔمَةِ", "مَآ", "أَصْحَـٰبُ", "ٱلْمَشْـَٔمَةِ", "٩"),
  ("wa-aṣḥābu", "l-mashamati", "mā", "aṣḥābu", "l-mashamati", "(9)"),
)

薄命者，薄命者是何等的人？

#quran-verse(
  ("وَٱلسَّـٰبِقُونَ", "ٱلسَّـٰبِقُونَ", "١٠"),
  ("wal-sābiqūna", "l-sābiqūna", "(10)"),
)

最先行善者，是最先入乐园的人，

#quran-verse(
  ("أُو۟لَـٰٓئِكَ", "ٱلْمُقَرَّبُونَ", "١١"),
  ("ulāika", "l-muqarabūna", "(11)"),
)

这等人，确是蒙主眷顾的。

#quran-verse(
  ("فِى", "جَنَّـٰتِ", "ٱلنَّعِيمِ", "١٢"),
  ("fī", "jannāti", "l-naʿīmi", "(12)"),
)

他们将在恩泽的乐园中。

#quran-verse(
  ("ثُلَّةٌۭ", "مِّنَ", "ٱلْأَوَّلِينَ", "١٣"),
  ("thullatun", "mina", "l-awalīna", "(13)"),
)

许多前人

#quran-verse(
  ("وَقَلِيلٌۭ", "مِّنَ", "ٱلْـَٔاخِرِينَ", "١٤"),
  ("waqalīlun", "mina", "l-ākhirīna", "(14)"),
)

和少数后人，

#quran-verse(
  ("عَلَىٰ", "سُرُرٍۢ", "مَّوْضُونَةٍۢ", "١٥"),
  ("ʿalā", "sururin", "mawḍūnatin", "(15)"),
)

在珠宝镶成的床榻上，

#quran-verse(
  ("مُّتَّكِـِٔينَ", "عَلَيْهَا", "مُتَقَـٰبِلِينَ", "١٦"),
  ("muttakiīna", "ʿalayhā", "mutaqābilīna", "(16)"),
)

彼此相对地靠在上面。

#quran-verse(
  ("يَطُوفُ", "عَلَيْهِمْ", "وِلْدَٰنٌۭ", "مُّخَلَّدُونَ", "١٧"),
  ("yaṭūfu", "ʿalayhim", "wil'dānun", "mukhalladūna", "(17)"),
)

长生不老的僮仆，轮流着服待他们，

#quran-verse(
  ("بِأَكْوَابٍۢ", "وَأَبَارِيقَ", "وَكَأْسٍۢ", "مِّن", "مَّعِينٍۢ", "١٨"),
  ("bi-akwābin", "wa-abārīqa", "wakasin", "min", "maʿīnin", "(18)"),
)

捧着盏和壶，与满杯的醴泉；

#quran-verse(
  ("لَّا", "يُصَدَّعُونَ", "عَنْهَا", "وَلَا", "يُنزِفُونَ", "١٩"),
  ("lā", "yuṣaddaʿūna", "ʿanhā", "walā", "yunzifūna", "(19)"),
)

他们不因那醴泉而头痛，也不酩酊。

#quran-verse(
  ("وَفَـٰكِهَةٍۢ", "مِّمَّا", "يَتَخَيَّرُونَ", "٢٠"),
  ("wafākihatin", "mimmā", "yatakhayyarūna", "(20)"),
)

他们有自己所选择的水果，

#quran-verse(
  ("وَلَحْمِ", "طَيْرٍۢ", "مِّمَّا", "يَشْتَهُونَ", "٢١"),
  ("walaḥmi", "ṭayrin", "mimmā", "yashtahūna", "(21)"),
)

和自己所爱好的鸟肉。

#quran-verse(
  ("وَحُورٌ", "عِينٌۭ", "٢٢"),
  ("waḥūrun", "ʿīnun", "(22)"),
)

还有白皙的、美目的妻子，

#quran-verse(
  ("كَأَمْثَـٰلِ", "ٱللُّؤْلُؤِ", "ٱلْمَكْنُونِ", "٢٣"),
  ("ka-amthāli", "l-lu'lu-i", "l-maknūni", "(23)"),
)

好象藏在蚌壳里的珍珠一样。

#quran-verse(
  ("جَزَآءًۢ", "بِمَا", "كَانُوا۟", "يَعْمَلُونَ", "٢٤"),
  ("jazāan", "bimā", "kānū", "yaʿmalūna", "(24)"),
)

那是为了报酬他们的善行。

#quran-verse(
  ("لَا", "يَسْمَعُونَ", "فِيهَا", "لَغْوًۭا", "وَلَا", "تَأْثِيمًا", "٢٥"),
  ("lā", "yasmaʿūna", "fīhā", "laghwan", "walā", "tathīman", "(25)"),
)

他们在乐园里，听不到恶言和谎话，

#quran-verse(
  ("إِلَّا", "قِيلًۭا", "سَلَـٰمًۭا", "سَلَـٰمًۭا", "٢٦"),
  ("illā", "qīlan", "salāman", "salāman", "(26)"),
)

但听到说：祝你们平安！祝你们平安！

#quran-verse(
  ("وَأَصْحَـٰبُ", "ٱلْيَمِينِ", "مَآ", "أَصْحَـٰبُ", "ٱلْيَمِينِ", "٢٧"),
  ("wa-aṣḥābu", "l-yamīni", "mā", "aṣḥābu", "l-yamīni", "(27)"),
)

幸福者，幸福者是何等的人？

#quran-verse(
  ("فِى", "سِدْرٍۢ", "مَّخْضُودٍۢ", "٢٨"),
  ("fī", "sid'rin", "makhḍūdin", "(28)"),
)

他们享受无刺的酸枣树，

#quran-verse(
  ("وَطَلْحٍۢ", "مَّنضُودٍۢ", "٢٩"),
  ("waṭalḥin", "manḍūdin", "(29)"),
)

结实累累的（香蕉）树；

#quran-verse(
  ("وَظِلٍّۢ", "مَّمْدُودٍۢ", "٣٠"),
  ("waẓillin", "mamdūdin", "(30)"),
)

漫漫的树荫；

#quran-verse(
  ("وَمَآءٍۢ", "مَّسْكُوبٍۢ", "٣١"),
  ("wamāin", "maskūbin", "(31)"),
)

泛泛的流水；

#quran-verse(
  ("وَفَـٰكِهَةٍۢ", "كَثِيرَةٍۢ", "٣٢"),
  ("wafākihatin", "kathīratin", "(32)"),
)

丰富的水果，

#quran-verse(
  ("لَّا", "مَقْطُوعَةٍۢ", "وَلَا", "مَمْنُوعَةٍۢ", "٣٣"),
  ("lā", "maqṭūʿatin", "walā", "mamnūʿatin", "(33)"),
)

四时不绝，可以随意摘食；

#quran-verse(
  ("وَفُرُشٍۢ", "مَّرْفُوعَةٍ", "٣٤"),
  ("wafurushin", "marfūʿatin", "(34)"),
)

与被升起的床榻。

#quran-verse(
  ("إِنَّآ", "أَنشَأْنَـٰهُنَّ", "إِنشَآءًۭ", "٣٥"),
  ("innā", "anshanāhunna", "inshāan", "(35)"),
)

我使她们重新生长，

#quran-verse(
  ("فَجَعَلْنَـٰهُنَّ", "أَبْكَارًا", "٣٦"),
  ("fajaʿalnāhunna", "abkāran", "(36)"),
)

我使她们常为处女，

#quran-verse(
  ("عُرُبًا", "أَتْرَابًۭا", "٣٧"),
  ("ʿuruban", "atrāban", "(37)"),
)

依恋丈夫，彼此同岁；

#quran-verse(
  ("لِّأَصْحَـٰبِ", "ٱلْيَمِينِ", "٣٨"),
  ("li-aṣḥābi", "l-yamīni", "(38)"),
)

这些都是幸福者所享受的。

#quran-verse(
  ("ثُلَّةٌۭ", "مِّنَ", "ٱلْأَوَّلِينَ", "٣٩"),
  ("thullatun", "mina", "l-awalīna", "(39)"),
)

他们是许多前人

#quran-verse(
  ("وَثُلَّةٌۭ", "مِّنَ", "ٱلْـَٔاخِرِينَ", "٤٠"),
  ("wathullatun", "mina", "l-ākhirīna", "(40)"),
)

和许多后人。

#quran-verse(
  ("وَأَصْحَـٰبُ", "ٱلشِّمَالِ", "مَآ", "أَصْحَـٰبُ", "ٱلشِّمَالِ", "٤١"),
  ("wa-aṣḥābu", "l-shimāli", "mā", "aṣḥābu", "l-shimāli", "(41)"),
)

薄命者，薄命者是何等的人？

#quran-verse(
  ("فِى", "سَمُومٍۢ", "وَحَمِيمٍۢ", "٤٢"),
  ("fī", "samūmin", "waḥamīmin", "(42)"),
)

他们在毒风和沸水中，

#quran-verse(
  ("وَظِلٍّۢ", "مِّن", "يَحْمُومٍۢ", "٤٣"),
  ("waẓillin", "min", "yaḥmūmin", "(43)"),
)

在黑烟的阴影下，

#quran-verse(
  ("لَّا", "بَارِدٍۢ", "وَلَا", "كَرِيمٍ", "٤٤"),
  ("lā", "bāridin", "walā", "karīmin", "(44)"),
)

既不凉爽，又不美观。

#quran-verse(
  ("إِنَّهُمْ", "كَانُوا۟", "قَبْلَ", "ذَٰلِكَ", "مُتْرَفِينَ", "٤٥"),
  ("innahum", "kānū", "qabla", "dhālika", "mut'rafīna", "(45)"),
)

以前他们确是豪华的，

#quran-verse(
  ("وَكَانُوا۟", "يُصِرُّونَ", "عَلَى", "ٱلْحِنثِ", "ٱلْعَظِيمِ", "٤٦"),
  ("wakānū", "yuṣirrūna", "ʿalā", "l-ḥinthi", "l-ʿaẓīmi", "(46)"),
)

确是固执大罪的，

#quran-verse(
  ("وَكَانُوا۟", "يَقُولُونَ", "أَئِذَا", "مِتْنَا", "وَكُنَّا", "تُرَابًۭا", "وَعِظَـٰمًا", "أَءِنَّا", "لَمَبْعُوثُونَ", "٤٧"),
  ("wakānū", "yaqūlūna", "a-idhā", "mit'nā", "wakunnā", "turāban", "waʿiẓāman", "a-innā", "lamabʿūthūna", "(47)"),
)

他们常说：难道我们死后，已变成尘土和枯骨的时候，我们必定要复活吗？

#quran-verse(
  ("أَوَءَابَآؤُنَا", "ٱلْأَوَّلُونَ", "٤٨"),
  ("awaābāunā", "l-awalūna", "(48)"),
)

连我们的祖先也要复活吗？

#quran-verse(
  ("قُلْ", "إِنَّ", "ٱلْأَوَّلِينَ", "وَٱلْـَٔاخِرِينَ", "٤٩"),
  ("qul", "inna", "l-awalīna", "wal-ākhirīna", "(49)"),
)

你说：前人和后人，

#quran-verse(
  ("لَمَجْمُوعُونَ", "إِلَىٰ", "مِيقَـٰتِ", "يَوْمٍۢ", "مَّعْلُومٍۢ", "٥٠"),
  ("lamajmūʿūna", "ilā", "mīqāti", "yawmin", "maʿlūmin", "(50)"),
)

在一个著名的日期和特定时间必定要被集合。

#quran-verse(
  ("ثُمَّ", "إِنَّكُمْ", "أَيُّهَا", "ٱلضَّآلُّونَ", "ٱلْمُكَذِّبُونَ", "٥١"),
  ("thumma", "innakum", "ayyuhā", "l-ḍālūna", "l-mukadhibūna", "(51)"),
)

然后迷误的、否认复活的人们啊！

#quran-verse(
  ("لَـَٔاكِلُونَ", "مِن", "شَجَرٍۢ", "مِّن", "زَقُّومٍۢ", "٥٢"),
  ("laākilūna", "min", "shajarin", "min", "zaqqūmin", "(52)"),
)

你们必定食攒（木+苦）木的果实，

#quran-verse(
  ("فَمَالِـُٔونَ", "مِنْهَا", "ٱلْبُطُونَ", "٥٣"),
  ("famāliūna", "min'hā", "l-buṭūna", "(53)"),
)

而以它充饥，

#quran-verse(
  ("فَشَـٰرِبُونَ", "عَلَيْهِ", "مِنَ", "ٱلْحَمِيمِ", "٥٤"),
  ("fashāribūna", "ʿalayhi", "mina", "l-ḥamīmi", "(54)"),
)

然后痛饮沸水，

#quran-verse(
  ("فَشَـٰرِبُونَ", "شُرْبَ", "ٱلْهِيمِ", "٥٥"),
  ("fashāribūna", "shur'ba", "l-hīmi", "(55)"),
)

象害消渴病的骆驼饮凉水一样。

#quran-verse(
  ("هَـٰذَا", "نُزُلُهُمْ", "يَوْمَ", "ٱلدِّينِ", "٥٦"),
  ("hādhā", "nuzuluhum", "yawma", "l-dīni", "(56)"),
)

这是他们在报应之日所受的款待。

#quran-verse(
  ("نَحْنُ", "خَلَقْنَـٰكُمْ", "فَلَوْلَا", "تُصَدِّقُونَ", "٥٧"),
  ("naḥnu", "khalaqnākum", "falawlā", "tuṣaddiqūna", "(57)"),
)

我曾创造你们，你们怎么不信复活呢？

#quran-verse(
  ("أَفَرَءَيْتُم", "مَّا", "تُمْنُونَ", "٥٨"),
  ("afara-aytum", "mā", "tum'nūna", "(58)"),
)

你们告诉我吧！你们所射的精液，

#quran-verse(
  ("ءَأَنتُمْ", "تَخْلُقُونَهُۥٓ", "أَمْ", "نَحْنُ", "ٱلْخَـٰلِقُونَ", "٥٩"),
  ("a-antum", "takhluqūnahu", "am", "naḥnu", "l-khāliqūna", "(59)"),
)

究竟是你们把它造成人呢？还是我把它造成人呢？

#quran-verse(
  ("نَحْنُ", "قَدَّرْنَا", "بَيْنَكُمُ", "ٱلْمَوْتَ", "وَمَا", "نَحْنُ", "بِمَسْبُوقِينَ", "٦٠"),
  ("naḥnu", "qaddarnā", "baynakumu", "l-mawta", "wamā", "naḥnu", "bimasbūqīna", "(60)"),
)

我曾将死亡分配给你们，任何人不能阻挠我，

#quran-verse(
  ("عَلَىٰٓ", "أَن", "نُّبَدِّلَ", "أَمْثَـٰلَكُمْ", "وَنُنشِئَكُمْ", "فِى", "مَا", "لَا", "تَعْلَمُونَ", "٦١"),
  ("ʿalā", "an", "nubaddila", "amthālakum", "wanunshi-akum", "fī", "mā", "lā", "taʿlamūna", "(61)"),
)

不让我改变你们的品性，而使你们生长在你们所不知的状态中。

#quran-verse(
  ("وَلَقَدْ", "عَلِمْتُمُ", "ٱلنَّشْأَةَ", "ٱلْأُولَىٰ", "فَلَوْلَا", "تَذَكَّرُونَ", "٦٢"),
  ("walaqad", "ʿalim'tumu", "l-nashata", "l-ūlā", "falawlā", "tadhakkarūna", "(62)"),
)

你们确已知道初次的生长，你们怎不觉悟呢？

#quran-verse(
  ("أَفَرَءَيْتُم", "مَّا", "تَحْرُثُونَ", "٦٣"),
  ("afara-aytum", "mā", "taḥruthūna", "(63)"),
)

你们告诉我吧！你们所耕种的庄稼，

#quran-verse(
  ("ءَأَنتُمْ", "تَزْرَعُونَهُۥٓ", "أَمْ", "نَحْنُ", "ٱلزَّٰرِعُونَ", "٦٤"),
  ("a-antum", "tazraʿūnahu", "am", "naḥnu", "l-zāriʿūna", "(64)"),
)

究竟是你们使它发荣呢？还是我使它发荣呢？

#quran-verse(
  ("لَوْ", "نَشَآءُ", "لَجَعَلْنَـٰهُ", "حُطَـٰمًۭا", "فَظَلْتُمْ", "تَفَكَّهُونَ", "٦٥"),
  ("law", "nashāu", "lajaʿalnāhu", "ḥuṭāman", "faẓaltum", "tafakkahūna", "(65)"),
)

假若我意欲，我必使它凋零，而你们变成诧异者，

#quran-verse(
  ("إِنَّا", "لَمُغْرَمُونَ", "٦٦"),
  ("innā", "lamugh'ramūna", "(66)"),
)

你们将说：我们是遭损失的。

#quran-verse(
  ("بَلْ", "نَحْنُ", "مَحْرُومُونَ", "٦٧"),
  ("bal", "naḥnu", "maḥrūmūna", "(67)"),
)

不然！我们是被剥夺的。

#quran-verse(
  ("أَفَرَءَيْتُمُ", "ٱلْمَآءَ", "ٱلَّذِى", "تَشْرَبُونَ", "٦٨"),
  ("afara-aytumu", "l-māa", "alladhī", "tashrabūna", "(68)"),
)

你们告诉吧！你们所饮的水，

#quran-verse(
  ("ءَأَنتُمْ", "أَنزَلْتُمُوهُ", "مِنَ", "ٱلْمُزْنِ", "أَمْ", "نَحْنُ", "ٱلْمُنزِلُونَ", "٦٩"),
  ("a-antum", "anzaltumūhu", "mina", "l-muz'ni", "am", "naḥnu", "l-munzilūna", "(69)"),
)

究竟是你们使它从云中降下的呢？还是我使它降下的呢？

#quran-verse(
  ("لَوْ", "نَشَآءُ", "جَعَلْنَـٰهُ", "أُجَاجًۭا", "فَلَوْلَا", "تَشْكُرُونَ", "٧٠"),
  ("law", "nashāu", "jaʿalnāhu", "ujājan", "falawlā", "tashkurūna", "(70)"),
)

假若我意欲，我必使它变成苦的，你们怎么不感谢呢？

#quran-verse(
  ("أَفَرَءَيْتُمُ", "ٱلنَّارَ", "ٱلَّتِى", "تُورُونَ", "٧١"),
  ("afara-aytumu", "l-nāra", "allatī", "tūrūna", "(71)"),
)

你们告诉吧！你们所钻取的火；

#quran-verse(
  ("ءَأَنتُمْ", "أَنشَأْتُمْ", "شَجَرَتَهَآ", "أَمْ", "نَحْنُ", "ٱلْمُنشِـُٔونَ", "٧٢"),
  ("a-antum", "anshatum", "shajaratahā", "am", "naḥnu", "l-munshiūna", "(72)"),
)

究竟是你们使燧木生长的呢？还是我使它生长的呢？

#quran-verse(
  ("نَحْنُ", "جَعَلْنَـٰهَا", "تَذْكِرَةًۭ", "وَمَتَـٰعًۭا", "لِّلْمُقْوِينَ", "٧٣"),
  ("naḥnu", "jaʿalnāhā", "tadhkiratan", "wamatāʿan", "lil'muq'wīna", "(73)"),
)

我以它为教训，并且以它为荒野的居民的慰藉，

#quran-verse(
  ("فَسَبِّحْ", "بِٱسْمِ", "رَبِّكَ", "ٱلْعَظِيمِ", "٧٤"),
  ("fasabbiḥ", "bi-is'mi", "rabbika", "l-ʿaẓīmi", "(74)"),
)

故你们应当颂扬你的主的大名。

#quran-verse(
  ("۞ فَلَآ", "أُقْسِمُ", "بِمَوَٰقِعِ", "ٱلنُّجُومِ", "٧٥"),
  ("falā", "uq'simu", "bimawāqiʿi", "l-nujūmi", "(75)"),
)

我必以星宿的没落处盟誓，

#quran-verse(
  ("وَإِنَّهُۥ", "لَقَسَمٌۭ", "لَّوْ", "تَعْلَمُونَ", "عَظِيمٌ", "٧٦"),
  ("wa-innahu", "laqasamun", "law", "taʿlamūna", "ʿaẓīmun", "(76)"),
)

这确是一个重大的盟誓，假若你们知道。

#quran-verse(
  ("إِنَّهُۥ", "لَقُرْءَانٌۭ", "كَرِيمٌۭ", "٧٧"),
  ("innahu", "laqur'ānun", "karīmun", "(77)"),
)

这确是宝贵的《古兰经》，

#quran-verse(
  ("فِى", "كِتَـٰبٍۢ", "مَّكْنُونٍۢ", "٧٨"),
  ("fī", "kitābin", "maknūnin", "(78)"),
)

记录在珍藏的经本中，

#quran-verse(
  ("لَّا", "يَمَسُّهُۥٓ", "إِلَّا", "ٱلْمُطَهَّرُونَ", "٧٩"),
  ("lā", "yamassuhu", "illā", "l-muṭaharūna", "(79)"),
)

只有纯洁者才得抚摸那经本。

#quran-verse(
  ("تَنزِيلٌۭ", "مِّن", "رَّبِّ", "ٱلْعَـٰلَمِينَ", "٨٠"),
  ("tanzīlun", "min", "rabbi", "l-ʿālamīna", "(80)"),
)

《古兰经》是从全世界的主降示的。

#quran-verse(
  ("أَفَبِهَـٰذَا", "ٱلْحَدِيثِ", "أَنتُم", "مُّدْهِنُونَ", "٨١"),
  ("afabihādhā", "l-ḥadīthi", "antum", "mud'hinūna", "(81)"),
)

难道你们藐视这训辞，

#quran-verse(
  ("وَتَجْعَلُونَ", "رِزْقَكُمْ", "أَنَّكُمْ", "تُكَذِّبُونَ", "٨٢"),
  ("watajʿalūna", "riz'qakum", "annakum", "tukadhibūna", "(82)"),
)

而以否认代替感谢吗？

#quran-verse(
  ("فَلَوْلَآ", "إِذَا", "بَلَغَتِ", "ٱلْحُلْقُومَ", "٨٣"),
  ("falawlā", "idhā", "balaghati", "l-ḥul'qūma", "(83)"),
)

（你们）怎么不在灵魂到将死者的咽喉的时候--

#quran-verse(
  ("وَأَنتُمْ", "حِينَئِذٍۢ", "تَنظُرُونَ", "٨٤"),
  ("wa-antum", "ḥīna-idhin", "tanẓurūna", "(84)"),
)

那时候，你们大家看着他，

#quran-verse(
  ("وَنَحْنُ", "أَقْرَبُ", "إِلَيْهِ", "مِنكُمْ", "وَلَـٰكِن", "لَّا", "تُبْصِرُونَ", "٨٥"),
  ("wanaḥnu", "aqrabu", "ilayhi", "minkum", "walākin", "lā", "tub'ṣirūna", "(85)"),
)

我比你们更临近他，但你们不晓得，

#quran-verse(
  ("فَلَوْلَآ", "إِن", "كُنتُمْ", "غَيْرَ", "مَدِينِينَ", "٨٦"),
  ("falawlā", "in", "kuntum", "ghayra", "madīnīna", "(86)"),
)

如果你们不是受报应的，--

#quran-verse(
  ("تَرْجِعُونَهَآ", "إِن", "كُنتُمْ", "صَـٰدِقِينَ", "٨٧"),
  ("tarjiʿūnahā", "in", "kuntum", "ṣādiqīna", "(87)"),
)

你们怎不使灵魂复返于本位呢？如果你们是说实话的。

#quran-verse(
  ("فَأَمَّآ", "إِن", "كَانَ", "مِنَ", "ٱلْمُقَرَّبِينَ", "٨٨"),
  ("fa-ammā", "in", "kāna", "mina", "l-muqarabīna", "(88)"),
)

如果他是被眷顾的，

#quran-verse(
  ("فَرَوْحٌۭ", "وَرَيْحَانٌۭ", "وَجَنَّتُ", "نَعِيمٍۢ", "٨٩"),
  ("farawḥun", "warayḥānun", "wajannatu", "naʿīmin", "(89)"),
)

那末，他将享受舒适、给养与恩泽的乐园；

#quran-verse(
  ("وَأَمَّآ", "إِن", "كَانَ", "مِنْ", "أَصْحَـٰبِ", "ٱلْيَمِينِ", "٩٠"),
  ("wa-ammā", "in", "kāna", "min", "aṣḥābi", "l-yamīni", "(90)"),
)

如果他是幸福者，

#quran-verse(
  ("فَسَلَـٰمٌۭ", "لَّكَ", "مِنْ", "أَصْحَـٰبِ", "ٱلْيَمِينِ", "٩١"),
  ("fasalāmun", "laka", "min", "aṣḥābi", "l-yamīni", "(91)"),
)

那末，一般幸福的人将对他说：祝你平安！

#quran-verse(
  ("وَأَمَّآ", "إِن", "كَانَ", "مِنَ", "ٱلْمُكَذِّبِينَ", "ٱلضَّآلِّينَ", "٩٢"),
  ("wa-ammā", "in", "kāna", "mina", "l-mukadhibīna", "l-ḍālīna", "(92)"),
)

如果他是迷误的、否认复活者，

#quran-verse(
  ("فَنُزُلٌۭ", "مِّنْ", "حَمِيمٍۢ", "٩٣"),
  ("fanuzulun", "min", "ḥamīmin", "(93)"),
)

那末，他将享受沸水的款待，

#quran-verse(
  ("وَتَصْلِيَةُ", "جَحِيمٍ", "٩٤"),
  ("wataṣliyatu", "jaḥīmin", "(94)"),
)

和烈火的烧灼。

#quran-verse(
  ("إِنَّ", "هَـٰذَا", "لَهُوَ", "حَقُّ", "ٱلْيَقِينِ", "٩٥"),
  ("inna", "hādhā", "lahuwa", "ḥaqqu", "l-yaqīni", "(95)"),
)

这确是无可置疑的真理。

#quran-verse(
  ("فَسَبِّحْ", "بِٱسْمِ", "رَبِّكَ", "ٱلْعَظِيمِ", "٩٦"),
  ("fasabbiḥ", "bi-is'mi", "rabbika", "l-ʿaẓīmi", "(96)"),
)

故你应当颂扬你的主的大名。

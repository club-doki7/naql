  ("ﱁ", "ﱂ", "ﱃ", "ﱄ", "ﱅ", "ﱆ", "ﱇ", "ﱈﱉ", "ﱊ", "ﱋ", "ﱌ", "ﱍﱎ", "ﱏ", "ﱐ", "ﱑ", "ﱒ", "ﱓ", "ﱔ"),
  ("yusabbiḥu", "lillahi", "mā", "fī", "l-samāwāti", "wamā", "fī", "l-arḍi", "lahu", "l-mul'ku", "walahu", "l-ḥamdu", "wahuwa", "ʿalā", "kulli", "shayin", "qadīrun", "(1)"),
  ([凡在天地间的，都赞颂真主超绝万物。国权只归他所有，赞颂只归他享受，他对於万事是全能的。]),
)

#quran-verse(
  (556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556),
  ("ﱕ", "ﱖ", "ﱗ", "ﱘ", "ﱙ", "ﱚ", "ﱛﱜ", "ﱝ", "ﱞ", "ﱟ", "ﱠ", "ﱡ"),
  ("huwa", "alladhī", "khalaqakum", "faminkum", "kāfirun", "waminkum", "mu'minun", "wal-lahu", "bimā", "taʿmalūna", "baṣīrun", "(2)"),
  ([他曾创造你们，但你们中有不信道的，有信道的；真主是鉴察你们的行为的。]),
)

#quran-verse(
  (556, 556, 556, 556, 556, 556, 556, 556, 556, 556),
  ("ﱢ", "ﱣ", "ﱤ", "ﱥ", "ﱦ", "ﱧ", "ﱨﱩ", "ﱪ", "ﱫ", "ﱬ"),
  ("khalaqa", "l-samāwāti", "wal-arḍa", "bil-ḥaqi", "waṣawwarakum", "fa-aḥsana", "ṣuwarakum", "wa-ilayhi", "l-maṣīru", "(3)"),
  ([他曾本著真理创造天地，他曾以形像赋予你们，而使你们的 形像优美，他是唯一的归宿。]),
)

#quran-verse(
  (556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556, 556),

#quran-verse(
  ("يُسَبِّحُ", "لِلَّهِ", "مَا", "فِى", "ٱلسَّمَـٰوَٰتِ", "وَمَا", "فِى", "ٱلْأَرْضِ ۖ", "لَهُ", "ٱلْمُلْكُ", "وَلَهُ", "ٱلْحَمْدُ ۖ", "وَهُوَ", "عَلَىٰ", "كُلِّ", "شَىْءٍۢ", "قَدِيرٌ", "١"),

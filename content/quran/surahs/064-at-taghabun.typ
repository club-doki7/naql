  ([凡在天地间的，都赞颂真主超绝万物。国权只归他所有，赞颂只归他享受，他对於万事是全能的。]),
)

#quran-verse(
  ("هُوَ", "ٱلَّذِى", "خَلَقَكُمْ", "فَمِنكُمْ", "كَافِرٌۭ", "وَمِنكُم", "مُّؤْمِنٌۭ ۚ", "وَٱللَّهُ", "بِمَا", "تَعْمَلُونَ", "بَصِيرٌ", "٢"),

#import "../libquran.typ": *

#show: quran-page.with(title: "Al-Fajr", title-ar: "الفجر", title-tl: "Al-Fajr", locator: "089-al-fajr")

#quran-verse(
  ("وَٱلْفَجْرِ", "١"),
  ("wal-fajri", "(1)"),
)

誓以黎明，

#quran-verse(
  ("وَلَيَالٍ", "عَشْرٍۢ", "٢"),
  ("walayālin", "ʿashrin", "(2)"),
)

与十夜，

#quran-verse(
  ("وَٱلشَّفْعِ", "وَٱلْوَتْرِ", "٣"),
  ("wal-shafʿi", "wal-watri", "(3)"),
)

与偶数和奇数，

#quran-verse(
  ("وَٱلَّيْلِ", "إِذَا", "يَسْرِ", "٤"),
  ("wa-al-layli", "idhā", "yasri", "(4)"),
)

与离去的黑夜，

#quran-verse(
  ("هَلْ", "فِى", "ذَٰلِكَ", "قَسَمٌۭ", "لِّذِى", "حِجْرٍ", "٥"),
  ("hal", "fī", "dhālika", "qasamun", "lidhī", "ḥij'rin", "(5)"),
)

对於有理智者，此中有一种盟誓吗？

#quran-verse(
  ("أَلَمْ", "تَرَ", "كَيْفَ", "فَعَلَ", "رَبُّكَ", "بِعَادٍ", "٦"),
  ("alam", "tara", "kayfa", "faʿala", "rabbuka", "biʿādin", "(6)"),
)

难道你不知道你的主怎样惩治阿德人---

#quran-verse(
  ("إِرَمَ", "ذَاتِ", "ٱلْعِمَادِ", "٧"),
  ("irama", "dhāti", "l-ʿimādi", "(7)"),
)

有高柱的伊赖姆人吗？

#quran-verse(
  ("ٱلَّتِى", "لَمْ", "يُخْلَقْ", "مِثْلُهَا", "فِى", "ٱلْبِلَـٰدِ", "٨"),
  ("allatī", "lam", "yukh'laq", "mith'luhā", "fī", "l-bilādi", "(8)"),
)

像那样的人，在别的城市里还没有被创造过的---

#quran-verse(
  ("وَثَمُودَ", "ٱلَّذِينَ", "جَابُوا۟", "ٱلصَّخْرَ", "بِٱلْوَادِ", "٩"),
  ("wathamūda", "alladhīna", "jābū", "l-ṣakhra", "bil-wādi", "(9)"),
)

怎样惩治在山谷里凿石为家的赛莫德人，

#quran-verse(
  ("وَفِرْعَوْنَ", "ذِى", "ٱلْأَوْتَادِ", "١٠"),
  ("wafir'ʿawna", "dhī", "l-awtādi", "(10)"),
)

怎样惩治有武力的法老。

#quran-verse(
  ("ٱلَّذِينَ", "طَغَوْا۟", "فِى", "ٱلْبِلَـٰدِ", "١١"),
  ("alladhīna", "ṭaghaw", "fī", "l-bilādi", "(11)"),
)

这等人曾在国中放肆，

#quran-verse(
  ("فَأَكْثَرُوا۟", "فِيهَا", "ٱلْفَسَادَ", "١٢"),
  ("fa-aktharū", "fīhā", "l-fasāda", "(12)"),
)

乃多行不义，

#quran-verse(
  ("فَصَبَّ", "عَلَيْهِمْ", "رَبُّكَ", "سَوْطَ", "عَذَابٍ", "١٣"),
  ("faṣabba", "ʿalayhim", "rabbuka", "sawṭa", "ʿadhābin", "(13)"),
)

故你的主把一种刑罚，倾注在他们身上。

#quran-verse(
  ("إِنَّ", "رَبَّكَ", "لَبِٱلْمِرْصَادِ", "١٤"),
  ("inna", "rabbaka", "labil-mir'ṣādi", "(14)"),
)

你的主，确是监视的。

#quran-verse(
  ("فَأَمَّا", "ٱلْإِنسَـٰنُ", "إِذَا", "مَا", "ٱبْتَلَىٰهُ", "رَبُّهُۥ", "فَأَكْرَمَهُۥ", "وَنَعَّمَهُۥ", "فَيَقُولُ", "رَبِّىٓ", "أَكْرَمَنِ", "١٥"),
  ("fa-ammā", "l-insānu", "idhā", "mā", "ib'talāhu", "rabbuhu", "fa-akramahu", "wanaʿʿamahu", "fayaqūlu", "rabbī", "akramani", "(15)"),
)

至於人，当他的主考验他，故优待他，而且使他过安逸生活的时候，他说：我的主优待我了。

#quran-verse(
  ("وَأَمَّآ", "إِذَا", "مَا", "ٱبْتَلَىٰهُ", "فَقَدَرَ", "عَلَيْهِ", "رِزْقَهُۥ", "فَيَقُولُ", "رَبِّىٓ", "أَهَـٰنَنِ", "١٦"),
  ("wa-ammā", "idhā", "mā", "ib'talāhu", "faqadara", "ʿalayhi", "riz'qahu", "fayaqūlu", "rabbī", "ahānani", "(16)"),
)

当他考验他，故节约他的给养的时候，他说：我的主凌辱我了。

#quran-verse(
  ("كَلَّا ۖ", "بَل", "لَّا", "تُكْرِمُونَ", "ٱلْيَتِيمَ", "١٧"),
  ("kallā", "bal", "lā", "tuk'rimūna", "l-yatīma", "(17)"),
)

绝不然！但你们不优待孤儿，

#quran-verse(
  ("وَلَا", "تَحَـٰٓضُّونَ", "عَلَىٰ", "طَعَامِ", "ٱلْمِسْكِينِ", "١٨"),
  ("walā", "taḥāḍḍūna", "ʿalā", "ṭaʿāmi", "l-mis'kīni", "(18)"),
)

你们不以济贫相勉励，

#quran-verse(
  ("وَتَأْكُلُونَ", "ٱلتُّرَاثَ", "أَكْلًۭا", "لَّمًّۭا", "١٩"),
  ("watakulūna", "l-turātha", "aklan", "lamman", "(19)"),
)

你们侵吞遗产，

#quran-verse(
  ("وَتُحِبُّونَ", "ٱلْمَالَ", "حُبًّۭا", "جَمًّۭا", "٢٠"),
  ("watuḥibbūna", "l-māla", "ḥubban", "jamman", "(20)"),
)

你们酷爱钱财。

#quran-verse(
  ("كَلَّآ", "إِذَا", "دُكَّتِ", "ٱلْأَرْضُ", "دَكًّۭا", "دَكًّۭا", "٢١"),
  ("kallā", "idhā", "dukkati", "l-arḍu", "dakkan", "dakkan", "(21)"),
)

绝不然！当大地震动复震动，

#quran-verse(
  ("وَجَآءَ", "رَبُّكَ", "وَٱلْمَلَكُ", "صَفًّۭا", "صَفًّۭا", "٢٢"),
  ("wajāa", "rabbuka", "wal-malaku", "ṣaffan", "ṣaffan", "(22)"),
)

你的主的命令，和排班的天神，同齐来临的时候，

#quran-verse(
  ("وَجِا۟ىٓءَ", "يَوْمَئِذٍۭ", "بِجَهَنَّمَ ۚ", "يَوْمَئِذٍۢ", "يَتَذَكَّرُ", "ٱلْإِنسَـٰنُ", "وَأَنَّىٰ", "لَهُ", "ٱلذِّكْرَىٰ", "٢٣"),
  ("wajīa", "yawma-idhin", "bijahannama", "yawma-idhin", "yatadhakkaru", "l-insānu", "wa-annā", "lahu", "l-dhik'rā", "(23)"),
)

在那日，火狱将被拿来；在那日，人将觉悟，但觉悟於他有何裨益呢？

#quran-verse(
  ("يَقُولُ", "يَـٰلَيْتَنِى", "قَدَّمْتُ", "لِحَيَاتِى", "٢٤"),
  ("yaqūlu", "yālaytanī", "qaddamtu", "liḥayātī", "(24)"),
)

他将说：但愿我在世的时候曾行善事。

#quran-verse(
  ("فَيَوْمَئِذٍۢ", "لَّا", "يُعَذِّبُ", "عَذَابَهُۥٓ", "أَحَدٌۭ", "٢٥"),
  ("fayawma-idhin", "lā", "yuʿadhibu", "ʿadhābahu", "aḥadun", "(25)"),
)

在那日，任何人，不用他的那种刑罚惩治别人；

#quran-verse(
  ("وَلَا", "يُوثِقُ", "وَثَاقَهُۥٓ", "أَحَدٌۭ", "٢٦"),
  ("walā", "yūthiqu", "wathāqahu", "aḥadun", "(26)"),
)

任何人，不用他的那种束缚束缚别人。

#quran-verse(
  ("يَـٰٓأَيَّتُهَا", "ٱلنَّفْسُ", "ٱلْمُطْمَئِنَّةُ", "٢٧"),
  ("yāayyatuhā", "l-nafsu", "l-muṭ'ma-inatu", "(27)"),
)

安定的灵魂啊！

#quran-verse(
  ("ٱرْجِعِىٓ", "إِلَىٰ", "رَبِّكِ", "رَاضِيَةًۭ", "مَّرْضِيَّةًۭ", "٢٨"),
  ("ir'jiʿī", "ilā", "rabbiki", "rāḍiyatan", "marḍiyyatan", "(28)"),
)

你应当喜悦地，被喜悦地归於你的主。

#quran-verse(
  ("فَٱدْخُلِى", "فِى", "عِبَـٰدِى", "٢٩"),
  ("fa-ud'khulī", "fī", "ʿibādī", "(29)"),
)

你应当入在我的众仆里；

#quran-verse(
  ("وَٱدْخُلِى", "جَنَّتِى", "٣٠"),
  ("wa-ud'khulī", "jannatī", "(30)"),
)

你应当入在我的乐园里。

#import "../libquran.typ": quran-verse

= 'Abasa (عبس)

#quran-verse(
  ("عَبَسَ", "وَتَوَلَّىٰٓ", "١"),
  ("ʿabasa", "watawallā", "(1)"),
  ("他皱眉", "他转身离去|和", ""),
)

他曾皱眉，而且转身离去，

#quran-verse(
  ("أَن", "جَآءَهُ", "ٱلْأَعْمَىٰ", "٢"),
  ("an", "jāahu", "l-aʿmā", "(2)"),
  ("因为", "他(穆圣)|他来到", "盲人", ""),
)

因为那个盲人来到他的面前。

#quran-verse(
  ("وَمَا", "يُدْرِيكَ", "لَعَلَّهُۥ", "يَزَّكَّىٰٓ", "٣"),
  ("wamā", "yud'rīka", "laʿallahu", "yazzakkā", "(3)"),
  ("什么?|和", "你|它使知道", "他(盲人)|也许", "他将受薰陶", ""),
)

你怎能知道呢？他也许能受薰陶，

#quran-verse(
  ("أَوْ", "يَذَّكَّرُ", "فَتَنفَعَهُ", "ٱلذِّكْرَىٰٓ", "٤"),
  ("aw", "yadhakkaru", "fatanfaʿahu", "l-dhik'rā", "(4)"),
  ("或", "他接受忠告", "他|它有益|然后", "忠告", ""),
)

或听忠告，而蒙教益。

#quran-verse(
  ("أَمَّا", "مَنِ", "ٱسْتَغْنَىٰ", "٥"),
  ("ammā", "mani", "is'taghnā", "(5)"),
  ("至于", "谁", "他自满", ""),
)

至於自满者，

#quran-verse(
  ("فَأَنتَ", "لَهُۥ", "تَصَدَّىٰ", "٦"),
  ("fa-anta", "lahu", "taṣaddā", "(6)"),
  ("你|因此", "他|对", "你逢迎", ""),
)

你都逢迎他，

#quran-verse(
  ("وَمَا", "عَلَيْكَ", "أَلَّا", "يَزَّكَّىٰ", "٧"),
  ("wamā", "ʿalayka", "allā", "yazzakkā", "(7)"),
  ("不|和", "你|在", "不|那个", "他受薰陶", ""),
)

他不受薰陶，於你何干？

#quran-verse(
  ("وَأَمَّا", "مَن", "جَآءَكَ", "يَسْعَىٰ", "٨"),
  ("wa-ammā", "man", "jāaka", "yasʿā", "(8)"),
  ("至于|和", "谁", "你|他来至", "他跑来", ""),
)

至於殷切地来请教你，

#quran-verse(
  ("وَهُوَ", "يَخْشَىٰ", "٩"),
  ("wahuwa", "yakhshā", "(9)"),
  ("他|和", "他畏惧", ""),
)

而且心怀敬畏者，

#quran-verse(
  ("فَأَنتَ", "عَنْهُ", "تَلَهَّىٰ", "١٠"),
  ("fa-anta", "ʿanhu", "talahhā", "(10)"),
  ("你|因此", "他|从", "你怠慢", ""),
)

你却怠慢他。

#quran-verse(
  ("كَلَّآ", "إِنَّهَا", "تَذْكِرَةٌۭ", "١١"),
  ("kallā", "innahā", "tadhkiratun", "(11)"),
  ("绝不然", "它|确实", "一种教训", ""),
)

绝不然！这确是一种教训。

#quran-verse(
  ("فَمَن", "شَآءَ", "ذَكَرَهُۥ", "١٢"),
  ("faman", "shāa", "dhakarahu", "(12)"),
  ("谁|因此", "他记诵|他意欲", "它", ""),
)

谁欲记诵它，就叫谁记诵它吧。

#quran-verse(
  ("فِى", "صُحُفٍۢ", "مُّكَرَّمَةٍۢ", "١٣"),
  ("fī", "ṣuḥufin", "mukarramatin", "(13)"),
  ("在", "众册页", "珍贵的", ""),
)

它在珍贵的册业里；

#quran-verse(
  ("مَّرْفُوعَةٍۢ", "مُّطَهَّرَةٍۭ", "١٤"),
  ("marfūʿatin", "muṭahharatin", "(14)"),
  ("被称扬的", "被涤净的", ""),
)

那些册业，是被称扬的，是被涤净的，

#quran-verse(
  ("بِأَيْدِى", "سَفَرَةٍۢ", "١٥"),
  ("bi-aydī", "safaratin", "(15)"),
  ("众手|在", "众书记的", ""),
)

是在许多书记的手里的；

#quran-verse(
  ("كِرَامٍۭ", "بَرَرَةٍۢ", "١٦"),
  ("kirāmin", "bararatin", "(16)"),
  ("尊贵的", "良善的", ""),
)

那些书记，是尊贵的，是善良的。

#quran-verse(
  ("قُتِلَ", "ٱلْإِنسَـٰنُ", "مَآ", "أَكْفَرَهُۥ", "١٧"),
  ("qutila", "l-insānu", "mā", "akfarahu", "(17)"),
  ("他该死", "世人", "什么？", "他|它使忘恩", ""),
)

该死的人！他是何等的忘恩！

#quran-verse(
  ("مِنْ", "أَىِّ", "شَىْءٍ", "خَلَقَهُۥ", "١٨"),
  ("min", "ayyi", "shayin", "khalaqahu", "(18)"),
  ("从", "什么？", "事物", "他|他创造", ""),
)

真主曾用什么创造他的呢？

#quran-verse(
  ("مِن", "نُّطْفَةٍ", "خَلَقَهُۥ", "فَقَدَّرَهُۥ", "١٩"),
  ("min", "nuṭ'fatin", "khalaqahu", "faqaddarahu", "(19)"),
  ("从", "精液", "他|他创造", "他|他预定发育程序|然后", ""),
)

是用精液。他曾创造他，并预定他发育的程序。

#quran-verse(
  ("ثُمَّ", "ٱلسَّبِيلَ", "يَسَّرَهُۥ", "٢٠"),
  ("thumma", "l-sabīla", "yassarahu", "(20)"),
  ("然后", "道路", "它(他)|他使容易", ""),
)

然后，他使他的道路平易。

#quran-verse(
  ("ثُمَّ", "أَمَاتَهُۥ", "فَأَقْبَرَهُۥ", "٢١"),
  ("thumma", "amātahu", "fa-aqbarahu", "(21)"),
  ("然后", "他|他使死", "他|他安葬|然后", ""),
)

然后，他使他死，并安葬他。

#quran-verse(
  ("ثُمَّ", "إِذَا", "شَآءَ", "أَنشَرَهُۥ", "٢٢"),
  ("thumma", "idhā", "shāa", "ansharahu", "(22)"),
  ("然后", "当", "他意欲", "他|他复活", ""),
)

然后，当他意欲的时候，他使他复活。

#quran-verse(
  ("كَلَّا", "لَمَّا", "يَقْضِ", "مَآ", "أَمَرَهُۥ", "٢٣"),
  ("kallā", "lammā", "yaqḍi", "mā", "amarahu", "(23)"),
  ("绝不然", "不", "他奉行", "什么", "他|他命令", ""),
)

绝不然，他还没有奉行他所命令他的事务。

#quran-verse(
  ("فَلْيَنظُرِ", "ٱلْإِنسَـٰنُ", "إِلَىٰ", "طَعَامِهِۦٓ", "٢٤"),
  ("falyanẓuri", "l-insānu", "ilā", "ṭaʿāmihi", "(24)"),
  ("他观察|使|然后", "世人", "至", "他的|食物", ""),
)

教人观察自己的食物吧！

#quran-verse(
  ("اَنَّا", "صَبَبْنَا", "ٱلْمَآءَ", "صَبًّۭا", "٢٥"),
  ("annā", "ṣababnā", "l-māa", "ṣabban", "(25)"),
  ("我们|确实", "我们倾注", "水", "大量地", ""),
)

我将雨水大量地倾注下来。

#quran-verse(
  ("ثُمَّ", "شَقَقْنَا", "ٱلْأَرْضَ", "شَقًّۭا", "٢٦"),
  ("thumma", "shaqaqnā", "l-arḍa", "shaqqan", "(26)"),
  ("然后", "我们裂开", "大地", "裂口", ""),
)

然后，我使地面奇异地裂开，

#quran-verse(
  ("فَأَنۢبَتْنَا", "فِيهَا", "حَبًّۭا", "٢٧"),
  ("fa-anbatnā", "fīhā", "ḥabban", "(27)"),
  ("我们使生产|然后", "它|在", "众谷子", ""),
)

我在大地上生产百谷，

#quran-verse(
  ("وَعِنَبًۭا", "وَقَضْبًۭا", "٢٨"),
  ("waʿinaban", "waqaḍban", "(28)"),
  ("众葡萄|和", "众苜蓿|和", ""),
)

与葡萄和苜蓿，

#quran-verse(
  ("وَزَيْتُونًۭا", "وَنَخْلًۭا", "٢٩"),
  ("wazaytūnan", "wanakhlan", "(29)"),
  ("橄榄|和", "枣树|和", ""),
)

与橄榄和海枣，

#quran-verse(
  ("وَحَدَآئِقَ", "غُلْبًۭا", "٣٠"),
  ("waḥadāiqa", "ghul'ban", "(30)"),
  ("花园|和", "茂密的", ""),
)

与茂密的园圃，

#quran-verse(
  ("وَفَـٰكِهَةًۭ", "وَأَبًّۭا", "٣١"),
  ("wafākihatan", "wa-abban", "(31)"),
  ("众水果|和", "牧草|和", ""),
)

水果和牧草，

#quran-verse(
  ("مَّتَـٰعًۭا", "لَّكُمْ", "وَلِأَنْعَـٰمِكُمْ", "٣٢"),
  ("matāʿan", "lakum", "wali-anʿāmikum", "(32)"),
  ("享受供应", "你们|为", "你们的|牲畜|好|和", ""),
)

以供你们和你们的牲畜享受。

#quran-verse(
  ("فَإِذَا", "جَآءَتِ", "ٱلصَّآخَّةُ", "٣٣"),
  ("fa-idhā", "jāati", "l-ṣākhatu", "(33)"),
  ("当|然后", "它来临", "震耳欲聋的轰声", ""),
)

当震耳欲聋的轰声来临的时候，

#quran-verse(
  ("يَوْمَ", "يَفِرُّ", "ٱلْمَرْءُ", "مِنْ", "أَخِيهِ", "٣٤"),
  ("yawma", "yafirru", "l-maru", "min", "akhīhi", "(34)"),
  ("那日", "他逃避", "各人", "从", "他的|弟兄", ""),
)

在那日，各人将逃避自己的弟兄、

#quran-verse(
  ("وَأُمِّهِۦ", "وَأَبِيهِ", "٣٥"),
  ("wa-ummihi", "wa-abīhi", "(35)"),
  ("他的|母亲|和", "他的|父亲|和", ""),
)

自己的父母、

#quran-verse(
  ("وَصَـٰحِبَتِهِۦ", "وَبَنِيهِ", "٣٦"),
  ("waṣāḥibatihi", "wabanīhi", "(36)"),
  ("他的|妻子|和", "他的|孩子|和", ""),
)

自己的妻子儿女；

#quran-verse(
  ("لِكُلِّ", "ٱمْرِئٍۢ", "مِّنْهُمْ", "يَوْمَئِذٍۢ", "شَأْنٌۭ", "يُغْنِيهِ", "٣٧"),
  ("likulli", "im'ri-in", "min'hum", "yawma-idhin", "shanun", "yugh'nīhi", "(37)"),
  ("每一个|对", "人的", "他们|从", "那日", "足够开怀", "他|它使不开心", ""),
)

在那日，各人将自顾不暇；

#quran-verse(
  ("وُجُوهٌۭ", "يَوْمَئِذٍۢ", "مُّسْفِرَةٌۭ", "٣٨"),

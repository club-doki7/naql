#import "../libquran.typ": quran-verse

= Ash-Shams (الشمس)

#quran-verse(
  ("وَٱلشَّمْسِ", "وَضُحَىٰهَا", "١"),
  ("wal-shamsi", "waḍuḥāhā", "(1)"),
  ("太阳|誓", "她(太阳)的|光辉|和", ""),
)

以太阳及其光辉发誓，

#quran-verse(
  ("وَٱلْقَمَرِ", "إِذَا", "تَلَىٰهَا", "٢"),
  ("wal-qamari", "idhā", "talāhā", "(2)"),
  ("月亮|和", "当", "她(太阳)|它(月亮)追随", ""),
)

以追随太阳时的月亮发誓，

#quran-verse(
  ("وَٱلنَّهَارِ", "إِذَا", "جَلَّىٰهَا", "٣"),
  ("wal-nahāri", "idhā", "jallāhā", "(3)"),
  ("白昼|和", "当", "她(太阳)|它(白昼)明显", ""),
)

以揭示太阳时的白昼发誓，

#quran-verse(
  ("وَٱلَّيْلِ", "إِذَا", "يَغْشَىٰهَا", "٤"),
  ("wa-al-layli", "idhā", "yaghshāhā", "(4)"),
  ("黑夜|和", "当", "她(太阳)|它(黑夜)笼罩", ""),
)

以笼罩太阳时的黑夜发誓，

#quran-verse(
  ("وَٱلسَّمَآءِ", "وَمَا", "بَنَىٰهَا", "٥"),
  ("wal-samāi", "wamā", "banāhā", "(5)"),
  ("苍穹|和", "什么|和", "她|他(真主)建筑", ""),
)

以苍穹及其建筑者发誓，

#quran-verse(
  ("وَٱلْأَرْضِ", "وَمَا", "طَحَىٰهَا", "٦"),
  ("wal-arḍi", "wamā", "ṭaḥāhā", "(6)"),
  ("大地|和", "什么|和", "她|他铺展", ""),
)

以大地及其铺展者发誓，

#quran-verse(
  ("وَنَفْسٍۢ", "وَمَا", "سَوَّىٰهَا", "٧"),
  ("wanafsin", "wamā", "sawwāhā", "(7)"),
  ("世人|和", "什么|和", "她|他使均衡", ""),
)

以灵魂及使它均衡，

#quran-verse(
  ("فَأَلْهَمَهَا", "فُجُورَهَا", "وَتَقْوَىٰهَا", "٨"),
  ("fa-alhamahā", "fujūrahā", "wataqwāhā", "(8)"),
  ("她|他启示|然后", "她的|恶", "她的|善|和", ""),
)

并启示他善恶者发誓，

#quran-verse(
  ("قَدْ", "أَفْلَحَ", "مَن", "زَكَّىٰهَا", "٩"),
  ("qad", "aflaḥa", "man", "zakkāhā", "(9)"),
  ("必定", "他成功", "谁", "她|他洁净", ""),
)

凡培养自己的性灵者，必定成功；

#quran-verse(
  ("وَقَدْ", "خَابَ", "مَن", "دَسَّىٰهَا", "١٠"),
  ("waqad", "khāba", "man", "dassāhā", "(10)"),
  ("必定|和", "他失败", "谁", "她|他戕害", ""),
)

凡戕害自己的性灵者，必定失败。

#quran-verse(
  ("كَذَّبَتْ", "ثَمُودُ", "بِطَغْوَىٰهَآ", "١١"),
  ("kadhabat", "thamūdu", "biṭaghwāhā", "(11)"),
  ("她否认", "赛莫德人", "她|违背(过分)|因", ""),
)

赛莫德人已因过分而否认真理。

#quran-verse(
  ("إِذِ", "ٱنۢبَعَثَ", "أَشْقَىٰهَا", "١٢"),
  ("idhi", "inbaʿatha", "ashqāhā", "(12)"),
  ("当时", "他上前", "她的|最薄命者", ""),
)

当时，他们中最薄命者忙上前来，

#quran-verse(
  ("فَقَالَ", "لَهُمْ", "رَسُولُ", "ٱللَّهِ", "نَاقَةَ", "ٱللَّهِ", "وَسُقْيَـٰهَا", "١٣"),
  ("faqāla", "lahum", "rasūlu", "l-lahi", "nāqata", "l-lahi", "wasuq'yāhā", "(13)"),
  ("他说|然后", "他们|对", "使者(沙里哈)", "真主的", "母驼", "真主的", "她的|自由饮水|和", ""),
)

使者就对他们说：你们让真主的母驼自由饮水吧。

#quran-verse(
  ("فَكَذَّبُوهُ", "فَعَقَرُوهَا", "فَدَمْدَمَ", "عَلَيْهِمْ", "رَبُّهُم", "بِذَنۢبِهِمْ", "فَسَوَّىٰهَا", "١٤"),
  ("fakadhabūhu", "faʿaqarūhā", "fadamdama", "ʿalayhim", "rabbuhum", "bidhanbihim", "fasawwāhā", "(14)"),
  ("他|他们否认|然后", "她|他们杀|然后", "他毁灭|因此", "他们|在", "它们的|养主", "他们的|罪|因为", "她(灾难)|他普遍受难|然后", ""),
)

但他们否认使者而宰杀母驼，故他们的主因他们的罪过而毁灭他们，使他们普遍受难。

#quran-verse(
  ("وَلَا", "يَخَافُ", "عُقْبَـٰهَا", "١٥"),
  ("walā", "yakhāfu", "ʿuq'bāhā", "(15)"),
  ("不|和", "他(真主)畏惧", "她(灾难)的|后果", ""),
)

他是不顾虑那灾难的後果的。

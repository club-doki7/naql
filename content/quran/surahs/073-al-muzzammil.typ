#quran-verse(
  ("يَوْمَ", "تَرْجُفُ", "ٱلْأَرْضُ", "وَٱلْجِبَالُ", "وَكَانَتِ", "ٱلْجِبَالُ", "كَثِيبًۭا", "مَّهِيلًا", "١٤"),

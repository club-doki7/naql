故你应当纪念你的主的尊名，你应当专心致志地敬事他。

#quran-verse(
  ("رَّبُّ", "ٱلْمَشْرِقِ", "وَٱلْمَغْرِبِ", "لَآ", "إِلَـٰهَ", "إِلَّا", "هُوَ", "فَٱتَّخِذْهُ", "وَكِيلًۭا", "٩"),
  ("rabbu", "l-mashriqi", "wal-maghribi", "lā", "ilāha", "illā", "huwa", "fa-ittakhidh'hu", "wakīlan", "(9)"),

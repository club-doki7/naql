  [竭力反对我的迹象以为已经成功的人，将受痛苦的刑罚。],
)

#quran-verse(
  verse-num: 6,
  "428",
  ("ﲣ", "ﲤ", "ﲥ", "ﲦ", "ﲧ", "ﲨ", "ﲩ", "ﲪ", "ﲫ", "ﲬ", "ﲭ", "ﲮ", "ﲯ", "ﲰ", "ﲱ", "ﲲ", "ﲳ"),

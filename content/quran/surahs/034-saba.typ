  [他对他们所以有权力者，只为我要辨别谁是信仰后世的，谁是怀疑后世的。你的主，是万物的监护者。],
)

#quran-verse(
  verse-num: 22,
  "430",
  ("ﲾ", "ﲿ", "ﳀ", "ﳁ", "ﳂ", "ﳃ", "ﳄ", "ﳅ", "ﳆ", "ﳇ", "ﳈ", "ﳉ", "ﳊ", "ﳋ", "ﳌ", "ﳍ", "ﳎ", "ﳏ", "ﳐ", "ﳑ", "ﳒ", "ﳓ", "ﳔ", "ﳕ", "ﳖ", "ﳗ", "ﳘ"),
